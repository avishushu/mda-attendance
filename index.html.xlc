        // =====================================================
        // PROFILE
        // =====================================================
        function showProfileView() {
            document.getElementById('prof-name').value = state.userData?.fullName || '';
            document.getElementById('prof-email').value = auth.currentUser?.email || '';
            document.getElementById('prof-current-pass').value = '';
            document.getElementById('prof-new-pass').value = '';
            document.getElementById('prof-confirm-pass').value = '';
            document.getElementById('profile-modal-overlay').classList.remove('hidden');
        }

        async function updateUserPassword() {
            const currentPass = document.getElementById('prof-current-pass').value;
            const newPass = document.getElementById('prof-new-pass').value;
            const confirmPass = document.getElementById('prof-confirm-pass').value;

            if (!currentPass) {
                await appDialog({ title: 'שגיאה', message: 'יש להזין את הסיסמה הנוכחית.', confirmText: 'סגור' });
                return;
            }
            if (newPass.length < 6) {
                await appDialog({ title: 'שגיאה', message: 'הסיסמה החדשה חייבת להיות לפחות 6 תווים.', confirmText: 'סגור' });
                return;
            }
            if (newPass !== confirmPass) {
                await appDialog({ title: 'שגיאה', message: 'הסיסמה החדשה ואימות הסיסמה אינם תואמים.', confirmText: 'סגור' });
                return;
            }

            const btn = document.getElementById('btn-update-password');
            btn.disabled = true; btn.textContent = 'מעדכן...';

            try {
                // Reauthenticate first — Firebase requires recent login for sensitive operations
                const credential = EmailAuthProvider.credential(auth.currentUser.email, currentPass);
                await reauthenticateWithCredential(auth.currentUser, credential);
                await updatePassword(auth.currentUser, newPass);
                showToast('הסיסמה עודכנה בהצלחה!', 'success');
                document.getElementById('prof-current-pass').value = '';
                document.getElementById('prof-new-pass').value = '';
                document.getElementById('prof-confirm-pass').value = '';
            } catch(err) {
                if (err.code === 'auth/wrong-password' || err.code === 'auth/invalid-credential') {
                    await appDialog({ title: 'סיסמה שגויה', message: 'הסיסמה הנוכחית שהזנת אינה נכונה.', confirmText: 'סגור' });
                } else if (err.code === 'auth/too-many-requests') {
                    await appDialog({ title: 'נסיונות רבים מדי', message: 'נחסמת זמנית עקב נסיונות כניסה כושלים. נסה שוב מאוחר יותר.', confirmText: 'סגור' });
                } else {
                    await appDialog({ title: 'שגיאה', message: 'לא ניתן לעדכן סיסמה כעת. נסה להתנתק ולהתחבר מחדש.', confirmText: 'סגור' });
                }
            } finally {
                btn.disabled = false; btn.textContent = 'עדכן סיסמה';
            }
        }

        function goBackToMain() {
            if (isAdmin()) { showView('view-admin'); loadAdminMain(); }
            else if (state.userData?.role === 'instructor') { showView('view-instructor'); loadInstructorMain(); }
            else { showView('view-student'); loadStudentMain(); }
        }

        // =====================================================
        // ADMIN
        // =====================================================
        function loadAdminMain() {
            // reset tabs
            document.querySelectorAll('[data-admin-tab]').forEach(t => t.classList.remove('active'));
            document.querySelector('[data-admin-tab="users"]').classList.add('active');
            document.getElementById('admin-tab-users').classList.remove('hidden');
            document.getElementById('admin-tab-groups').classList.add('hidden');
            document.getElementById('admin-tab-dashboard').classList.add('hidden');
            document.getElementById('admin-tab-messages').classList.add('hidden');
            document.getElementById('admin-tab-broadcasts').classList.add('hidden');
            document.getElementById('admin-tab-log').classList.add('hidden');
            loadAdminUsers();
        }

        async function loadAdminUsers() {
            const list = document.getElementById('admin-users-list');
            list.innerHTML = '<div class="loading-text">טוען משתמשים...</div>';
            const snaps = await getDocs(collection(db, "users"));
            state.adminUsersCache = snaps.docs.map(d => ({ id: d.id, ...d.data() }));
            renderAdminUsers(state.adminUsersCache);
        }

        function renderAdminUsers(usersArray) {
            const list = document.getElementById('admin-users-list');
            list.innerHTML = '';
            const table = document.createElement('table');
            const header = document.createElement('tr');
            ['שם', 'ת.ז', 'תפקיד', 'פעולות'].forEach(h => {
                const th = document.createElement('th');
                th.textContent = h;
                header.appendChild(th);
            });
            table.appendChild(header);
            usersArray.forEach(u => {
                const roleHe = u.role === 'admin' ? 'מנהל' : u.role === 'instructor' ? 'מדריך' : u.role === 'frozen' ? 'קפוא' : 'תלמיד';
                const tr = document.createElement('tr');
                ['fullName', 'idNumber', 'role'].forEach((key, i) => {
                    const td = document.createElement('td');
                    td.textContent = i === 2 ? roleHe : (u[key] || '-');
                    tr.appendChild(td);
                });
                const tdAction = document.createElement('td');
                const editBtn = document.createElement('button');
                editBtn.textContent = 'ערוך';
                editBtn.className = 'action-btn-small outline';
                editBtn.addEventListener('click', () => editAdminUser(u.id));
                tdAction.appendChild(editBtn);
                tr.appendChild(tdAction);
                table.appendChild(tr);
            });
            list.appendChild(table);
        }

        function editAdminUser(uid) {
            const u = state.adminUsersCache.find(x => x.id === uid);
            if (!u) return;
            document.getElementById('admin-eu-id').value = uid;
            document.getElementById('admin-eu-name').value = u.fullName;
            document.getElementById('admin-eu-role').value = u.role || 'student';
            document.getElementById('admin-edit-user-modal').classList.remove('hidden');
        }

        async function saveAdminUserEdit() {
            const uid = document.getElementById('admin-eu-id').value;
            const name = document.getElementById('admin-eu-name').value;
            const role = document.getElementById('admin-eu-role').value;
            const roleHe = role === 'admin' ? 'מנהל' : role === 'instructor' ? 'מדריך' : role === 'frozen' ? 'קפוא' : 'תלמיד';
            await updateDoc(doc(db, "users", uid), { fullName: name, role });
            writeLog('user', `עריכת משתמש: שם "${name}" | תפקיד שונה ל: ${roleHe} | UID: ${uid}`);
            closeModals();
            showToast("המשתמש עודכן!");
            loadAdminUsers();
        }

        async function loadAdminGroups() {
            const list = document.getElementById('admin-groups-list');
            list.innerHTML = '<div class="loading-text">טוען קבוצות...</div>';
            const snaps = await getDocs(collection(db, "groups"));
            list.innerHTML = '';
            snaps.forEach(d => {
                const g = d.data();
                const div = document.createElement('div');
                div.className = "card list-item clickable";
                const info = document.createElement('div');
                info.style.flex = '1';
                const strong = document.createElement('strong');
                strong.textContent = g.name;
                const small = document.createElement('span');
                small.className = 'small-date';
                small.textContent = `חניכים: ${g.members?.length || 0}`;
                info.appendChild(strong);
                info.appendChild(document.createElement('br'));
                info.appendChild(small);
                const deleteBtn = document.createElement('button');
                deleteBtn.className = 'icon-btn';
                deleteBtn.title = 'מחק קבוצה';
                deleteBtn.textContent = '✕';
                deleteBtn.addEventListener('click', (e) => deleteGroup(d.id, e));
                div.appendChild(info);
                div.appendChild(deleteBtn);
                div.addEventListener('click', (e) => { if (!e.target.closest('.icon-btn')) openGroup(d.id, g.name); });
                list.appendChild(div);
            });
        }

        async function loadAdminDashboard() {
            const cont = document.getElementById('admin-stats-container');
            cont.innerHTML = '<div class="loading-text">טוען נתונים...</div>';
            const [usersSnap, groupsSnap] = await Promise.all([
                getDocs(collection(db, "users")),
                getDocs(collection(db, "groups"))
            ]);
            let insts = 0, studs = 0;
            usersSnap.forEach(d => {
                const r = d.data().role;
                if (r === 'instructor') insts++;
                else if (r === 'student') studs++;
            });
            cont.innerHTML = '';
            const stats = [
                { icon: '◉', label: 'סה"כ משתמשים', val: usersSnap.size, color: 'var(--red)' },
                { icon: '▣', label: 'קבוצות לימוד', val: groupsSnap.size, color: 'var(--blue)' },
                { icon: '◈', label: 'מדריכים מוסמכים', val: insts, color: 'var(--green)' },
                { icon: '◆', label: 'חניכים פעילים', val: studs, color: 'var(--amber)' },
            ];
            stats.forEach(s => {
                const div = document.createElement('div');
                div.className = 'admin-stat-card';
                div.innerHTML = `
                    <span style="font-size:1.6rem;display:block;margin-bottom:8px;">${s.icon}</span>
                    <span class="stat-label">${s.label}</span>
                    <span class="stat-value" style="color:${s.color};">${s.val}</span>
                `;
                cont.appendChild(div);
            });
        }

        // =====================================================
        // GROUP MANAGEMENT
        // =====================================================
        function showCreateGroupModal() {
            document.getElementById('cg-name').value = '';
            document.getElementById('create-group-modal').classList.remove('hidden');
        }

        async function submitNewGroup() {
            const name = document.getElementById('cg-name').value.trim();
            if (!name) {
                await appDialog({ title: 'שגיאה', message: 'הכנס שם קבוצה', confirmText: 'סגור' });
                return;
            }

            // FIX 4: When an admin creates a group, they are not necessarily the instructor.
            // Ask for the instructor's ID number so the group is linked to the right instructor.
            // Without this fix, the group's instructorId would be the admin's UID,
            // and the intended instructor would never see it in their instructor view.
            let instructorUid = auth.currentUser.uid;
            if (isAdmin()) {
                const idNumber = await appDialog({
                    title: 'שיוך מדריך לקבוצה',
                    message: 'הכנס תעודת זהות של המדריך האחראי על הקבוצה (השאר ריק לשיוך לעצמך):',
                    input: true, inputPlaceholder: 'תעודת זהות', confirmText: 'המשך', cancelText: 'ביטול'
                });
                if (idNumber === null) return; // user cancelled
                if (idNumber && idNumber.trim() !== '') {
                    const q = query(collection(db, "users"), where("idNumber", "==", idNumber.trim()), where("role", "==", "instructor"));
                    const snaps = await getDocs(q);
                    if (snaps.empty) {
                        await appDialog({ title: 'לא נמצא', message: 'לא נמצא מדריך עם תעודת זהות זו.', confirmText: 'סגור' });
                        return;
                    }
                    instructorUid = snaps.docs[0].id;
                }
            }

            await addDoc(collection(db, "groups"), {
                name, instructorId: instructorUid, coInstructors: [], members: [], createdAt: serverTimestamp()
            });
            writeLog('admin', `יצירת קבוצה חדשה: "${name}" | מדריך: ${instructorUid}`);
            closeModals();
            showToast('הקבוצה נוצרה בהצלחה!');
            if (isAdmin()) loadAdminGroups(); else loadInstructorMain();
        }

        async function deleteGroup(gid, e) {
            e.stopPropagation();
            const confirmed = await appDialog({
                title: 'מחיקת קבוצה',
                message: 'אזהרה: מחיקת קבוצה תמחק את כולה ללא אפשרות שחזור. האם אתה בטוח?',
                confirmText: 'מחק',
                cancelText: 'ביטול',
                danger: true
            });
            if (!confirmed) return;
            // FIX 1: Delete all sub-collections before deleting the group document.
            // Firestore does NOT auto-delete sub-collections — orphaned data accumulates and costs money.
            const subCollections = ['sessions', 'notices'];
            for (const colName of subCollections) {
                const subSnaps = await getDocs(collection(db, "groups", gid, colName));
                for (const subDoc of subSnaps.docs) {
                    await deleteDoc(subDoc.ref);
                }
            }
            await deleteDoc(doc(db, "groups", gid));
            writeLog('delete', `מחיקת קבוצה ${gid}`);
            showToast("הקבוצה נמחקה.");
            if (isAdmin()) loadAdminGroups(); else loadInstructorMain();
        }

        async function loadInstructorMain() {
            const cont = document.getElementById('instructor-groups-container');
            cont.innerHTML = '<div class="loading-text">טוען...</div>';
            // Load inbox in background to update badge only
            loadInstructorInbox();
            const [q1, q2] = await Promise.all([
                getDocs(query(collection(db, "groups"), where("instructorId", "==", auth.currentUser.uid))),
                getDocs(query(collection(db, "groups"), where("coInstructors", "array-contains", auth.currentUser.uid)))
            ]);
            const groupsMap = new Map();
            q1.forEach(d => groupsMap.set(d.id, d));
            q2.forEach(d => groupsMap.set(d.id, d));
            cont.innerHTML = '';
            if (groupsMap.size === 0) { cont.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין קבוצות בניהולך עדיין</p></div>'; return; }

            for (const d of groupsMap.values()) {
                const gData = d.data();
                const memberUids = gData.members || [];

                // ── INSTRUCTOR STATS BANNER ──────────────────────────────
                // Fetch all sessions for this group to build per-group stats
                const sessSnaps = await getDocs(collection(db, "groups", d.id, "sessions"));
                const allSessions = sessSnaps.docs.map(s => ({ id: s.id, ...s.data() }));
                const closedSessions = allSessions.filter(s => s.status === 'closed');
                const openSessions   = allSessions.filter(s => s.status === 'open');

                // Aggregate across all members
                let totalPresences = 0, totalAbsences = 0, totalLates = 0;
                closedSessions.forEach(s => {
                    memberUids.forEach(uid => {
                        const att = s.attendance?.[uid];
                        if (att && ['on_time','late','excused'].includes(att.status)) {
                            totalPresences++;
                            if (att.status === 'late') totalLates++;
                        } else {
                            totalAbsences++;
                        }
                    });
                });
                const totalSlots  = closedSessions.length * memberUids.length;
                const avgPct      = totalSlots > 0 ? Math.round((totalPresences / totalSlots) * 100) : null;
                const statColor   = avgPct === null ? 'var(--muted)' : avgPct >= 80 ? 'var(--green)' : avgPct >= 50 ? 'var(--amber)' : 'var(--danger)';

                // ── PENDING EXCEPTIONS (unresolved manual requests across open sessions) ──
                let pendingExceptions = 0;
                openSessions.forEach(s => {
                    if (s.exceptions) {
                        Object.values(s.exceptions).forEach(exc => {
                            if (exc.type === 'manual_request' && !exc.snoozed) pendingExceptions++;
                        });
                    }
                });

                const banner = document.createElement('div');
                banner.className = 'card';
                banner.style.cssText = `margin-bottom:8px;padding:18px 20px;border-right:4px solid ${statColor};cursor:default;`;
                banner.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                        <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--ink);"> ${safeHTML(gData.name)}</span>
                        ${pendingExceptions > 0 ? `<span class="status-tag bg-red" style="font-size:0.72rem;animation:blinker 1.5s ease-in-out infinite;"> ${pendingExceptions} בקשות חריגות</span>` : (openSessions.length > 0 ? `<span class="status-tag bg-green" style="font-size:0.72rem;">מפגש פתוח</span>` : '')}
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:${closedSessions.length > 0 ? '12px' : '0'};">
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.2rem;font-weight:800;color:var(--ink);font-family:'Syne',sans-serif;">${memberUids.length}</p>
                            <p style="font-size:0.68rem;color:var(--muted);font-weight:600;">חניכים</p>
                        </div>
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.2rem;font-weight:800;color:var(--blue);font-family:'Syne',sans-serif;">${allSessions.length}</p>
                            <p style="font-size:0.68rem;color:var(--muted);font-weight:600;">מפגשים</p>
                        </div>
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.2rem;font-weight:800;color:var(--green);font-family:'Syne',sans-serif;">${totalPresences}</p>
                            <p style="font-size:0.68rem;color:var(--green);font-weight:600;">נוכחויות</p>
                        </div>
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.2rem;font-weight:800;color:var(--danger);font-family:'Syne',sans-serif;">${totalAbsences}</p>
                            <p style="font-size:0.68rem;color:var(--danger);font-weight:600;">חיסורים</p>
                        </div>
                    </div>
                    ${closedSessions.length > 0 && avgPct !== null ? `
                    <div style="margin-bottom:8px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                            <span style="font-size:0.8rem;color:var(--muted);font-weight:600;">ממוצע נוכחות קבוצתי</span>
                            <span style="font-size:0.9rem;font-weight:800;color:${statColor};">${avgPct}%</span>
                        </div>
                        <div style="height:6px;background:#eef0f4;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:${avgPct}%;background:${statColor};border-radius:99px;transition:width 0.8s ease;"></div>
                        </div>
                    </div>` : ''}
                    ${totalLates > 0 ? `<p style="font-size:0.78rem;color:var(--amber);font-weight:600;">⏰ ${totalLates} דיווחי איחור סה"כ</p>` : ''}
                `;
                // ── MERGED: action bar appended above
                // ── GROUP CARD (clickable) ───────────────────────────────
                // Action bar merged into the bottom of the stats banner
                const actionBar = document.createElement('div');
                actionBar.style.cssText = 'display:flex;gap:8px;margin-top:14px;padding-top:12px;border-top:1px solid var(--border-light);';
                const enterBtn = document.createElement('button');
                enterBtn.style.cssText = 'flex:1;font-size:0.88rem;padding:9px 12px;';
                enterBtn.textContent = 'נהל קבוצה';
                enterBtn.addEventListener('click', () => openGroup(d.id, gData.name));
                const delBtn = document.createElement('button');
                delBtn.className = 'icon-btn';
                delBtn.title = 'מחק קבוצה';
                delBtn.textContent = '✕';
                delBtn.addEventListener('click', (e) => deleteGroup(d.id, e));
                actionBar.appendChild(enterBtn);
                actionBar.appendChild(delBtn);
                banner.appendChild(actionBar);
                banner.style.cursor = 'default';
                banner.style.marginBottom = '20px';
                cont.appendChild(banner);
            }
        }

        function backFromGroupDetails() {
            if (isAdmin()) {
                showView('view-admin');
                loadAdminMain();
                // switch to groups tab
                document.querySelectorAll('[data-admin-tab]').forEach(t => t.classList.remove('active'));
                document.querySelector('[data-admin-tab="groups"]').classList.add('active');
                document.getElementById('admin-tab-users').classList.add('hidden');
                document.getElementById('admin-tab-groups').classList.remove('hidden');
                document.getElementById('admin-tab-dashboard').classList.add('hidden');
                document.getElementById('admin-tab-messages').classList.add('hidden');
                document.getElementById('admin-tab-broadcasts').classList.add('hidden');
                document.getElementById('admin-tab-log').classList.add('hidden');
                loadAdminGroups();
            } else {
                showView('view-instructor');
            }
        }

        async function openGroup(id, name) {
            state.curGroupId = id;
            document.querySelectorAll('section').forEach(e => e.classList.add('hidden'));
            document.getElementById('view-instructor').classList.remove('hidden');
            document.getElementById('instructor-main').classList.add('hidden');
            document.getElementById('instructor-group-details').classList.remove('hidden');
            // reset to sessions tab
            document.querySelectorAll('[data-group-tab]').forEach(t => t.classList.remove('active'));
            document.querySelector('[data-group-tab="sessions"]').classList.add('active');
            document.getElementById('tab-sessions').classList.remove('hidden');
            document.getElementById('tab-students').classList.add('hidden');
            document.getElementById('tab-notices').classList.add('hidden');
            safeText(document.getElementById('group-name-header'), name);
            loadSessions();
            loadNotices();

            // Auto-refresh sessions list when sessions are added or updated (e.g. new session created, session auto-closed)
            if (state.sessionsUnsubscribe) { state.sessionsUnsubscribe(); state.sessionsUnsubscribe = null; }
            state.sessionsUnsubscribe = onSnapshot(
                query(collection(db, "groups", id, "sessions"), orderBy("sessionNumber", "desc")),
                () => {
                    // Only refresh if still viewing this group's sessions tab (not inside a session report)
                    const sessionReportVisible = !document.getElementById('session-report-view').classList.contains('hidden');
                    if (!sessionReportVisible && state.curGroupId === id) {
                        loadSessions();
                    }
                }
            );
        }

        // =====================================================
        // SESSIONS
        // =====================================================
        async function loadSessions() {
            const list = document.getElementById('instructor-sessions-list');
            list.innerHTML = '<div class="loading-text">טוען...</div>';
            const snaps = await getDocs(query(collection(db, "groups", state.curGroupId, "sessions"), orderBy("sessionNumber", state.sessionSort)));
            state.allSessionsCache = snaps.docs.map(d => ({ id: d.id, ...d.data() }));
            list.innerHTML = '';
            state.allSessionsCache.forEach(s => {
                let reopenBtn = null;
                if (s.status === 'closed' && s.createdAt) {
                    const diff = (new Date().getTime() - s.createdAt.toDate().getTime()) / (1000 * 60 * 60);
                    if (isAdmin() || diff < 48) {
                        reopenBtn = document.createElement('button');
                        reopenBtn.className = 'outline';
                        reopenBtn.style.cssText = 'width:auto;padding:4px 8px;font-size:0.8rem;margin-right:8px;';
                        reopenBtn.textContent = 'פתח מחדש';
                        reopenBtn.addEventListener('click', (e) => { e.stopPropagation(); reopenSession(s.id); });
                    }
                }
                const dateStr = s.createdAt ? s.createdAt.toDate().toLocaleDateString('he-IL') : '';
                const div = document.createElement('div');
                div.className = "list-item clickable";

                const leftDiv = document.createElement('div');
                const titleSpan = document.createElement('span');
                titleSpan.style.cssText = 'font-weight:600;font-size:1.05rem;';
                titleSpan.textContent = `מפגש ${s.sessionNumber}`;
                const dateSpan = document.createElement('span');
                dateSpan.className = 'small-date';
                const radiusTxt = s.noGpsMode ? ' · ללא GPS' : (s.attendanceRadius ? ` · רדיוס ${s.attendanceRadius}מ׳` : '');
                dateSpan.textContent = dateStr + radiusTxt;
                leftDiv.appendChild(titleSpan);
                leftDiv.appendChild(dateSpan);

                const rightDiv = document.createElement('div');
                rightDiv.style.cssText = 'display:flex;align-items:center;';
                if (reopenBtn) rightDiv.appendChild(reopenBtn);
                const statusTag = document.createElement('span');
                statusTag.className = `status-tag ${s.status === 'open' ? 'bg-green' : 'bg-red'}`;
                statusTag.textContent = s.status === 'open' ? 'פתוח' : 'סגור';
                const deleteBtn = document.createElement('button');
                deleteBtn.className = 'icon-btn';
                deleteBtn.style.marginRight = '10px';
                deleteBtn.title = 'מחק מפגש';
                deleteBtn.textContent = '✕';
                deleteBtn.addEventListener('click', (e) => deleteSession(s.id, e));
                rightDiv.appendChild(statusTag);
                rightDiv.appendChild(deleteBtn);

                div.appendChild(leftDiv);
                div.appendChild(rightDiv);
                div.addEventListener('click', (e) => { if (!e.target.closest('button')) openReportLive(s.id, s.sessionNumber, s.status); });
                list.appendChild(div);
            });
            loadStudentsWithStats();
        }

        async function deleteSession(sid, e) {
            e.stopPropagation();
            const confirmed = await appDialog({ title: 'מחיקת מפגש', message: 'האם למחוק מפגש זה?', confirmText: 'מחק', cancelText: 'ביטול', danger: true });
            if (!confirmed) return;
            try {
                await deleteDoc(doc(db, "groups", state.curGroupId, "sessions", sid));
                writeLog('delete', `מחיקת מפגש ${sid} מקבוצה ${state.curGroupId}`);
                showToast("המפגש נמחק.");
                loadSessions();
            } catch (err) {
                console.error('deleteSession error:', err);
                showToast('שגיאה במחיקת המפגש — נסה שוב', 'error');
            }
        }

        async function reopenSession(sid) {
            const durationStr = await appDialog({
                title: 'פתיחת מפגש מחדש',
                message: 'לכמה דקות לפתוח את המפגש מחדש?',
                input: true,
                inputPlaceholder: 'לדוגמה: 15',
                confirmText: 'פתח מחדש',
                cancelText: 'ביטול'
            });
            if (durationStr === null || durationStr === '') return;
            const durationMins = parseInt(durationStr);
            if (isNaN(durationMins) || durationMins <= 0 || durationMins > 480) {
                await appDialog({ title: 'שגיאה', message: 'אנא הזן מספר דקות תקין (1–480)', confirmText: 'סגור' });
                return;
            }
            const newEnd = new Date(Date.now() + durationMins * 60000);
            const newEndStr = String(newEnd.getHours()).padStart(2, '0') + ':' + String(newEnd.getMinutes()).padStart(2, '0');

            try {
                const sessionSnap = await getDoc(doc(db, "groups", state.curGroupId, "sessions", sid));
                const sdata = sessionSnap.data();
                const updates = { status: 'open', expectedEndTime: newEndStr, reopenedAt: serverTimestamp() };
                if (sdata && sdata.attendance) {
                    Object.entries(sdata.attendance).forEach(([uid, att]) => {
                        if (att.autoMarked) updates[`attendance.${uid}`] = deleteField();
                    });
                }
                await updateDoc(doc(db, "groups", state.curGroupId, "sessions", sid), updates);
                showToast(`המפגש נפתח מחדש ל-${durationMins} דקות — סיום ב-${newEndStr}`, 'success');
                loadSessions();
                loadInstructorMain();
            } catch (err) {
                console.error('reopenSession error:', err);
                showToast('שגיאה בפתיחת המפגש מחדש — נסה שוב', 'error');
            }
        }

        function showNewSessionForm() {
            let nextNum = 1;
            if (state.allSessionsCache?.length > 0) {
                nextNum = Math.max(...state.allSessionsCache.map(s => s.sessionNumber)) + 1;
            }
            document.getElementById('ns-num').value = nextNum;
            // Default start time = current time (HH:MM)
            const now = new Date();
            const hh = String(now.getHours()).padStart(2, '0');
            const mm = String(now.getMinutes()).padStart(2, '0');
            document.getElementById('ns-start').value = `${hh}:${mm}`;
            document.getElementById('ns-radius').value = 50;
            // reset preset highlight
            document.querySelectorAll('.radius-preset').forEach(b => b.classList.remove('active-preset'));
            const defaultPreset = document.querySelector('.radius-preset[data-val="50"]');
            if (defaultPreset) defaultPreset.classList.add('active-preset');
            document.getElementById('ns-end').value = '';
            document.getElementById('ns-access-code').value = '';
            document.getElementById('new-session-modal').classList.remove('hidden');
        }

        async function submitNewSession(e, skipGps = false) {
            // Capture button reference immediately - e.currentTarget becomes null after any await
            const btn = document.getElementById(skipGps ? 'btn-create-session-no-gps' : 'btn-create-session');
            const num = document.getElementById('ns-num').value;
            const start = document.getElementById('ns-start').value;
            const end = document.getElementById('ns-end').value;
            if (!num || !start) {
                await appDialog({ title: 'שגיאה', message: 'יש להזין מספר מפגש ושעת התחלה.', confirmText: 'סגור' });
                return;
            }

            // ── NO-GPS MODE ──────────────────────────────────────────────────────────
            // When the instructor cannot get GPS (permission denied / unsupported device),
            // allow opening a session without a location. In this mode the instructorLocation
            // field is omitted, and student attendance validation is automatically bypassed
            // (students will be able to report presence without distance check).
            if (skipGps) {
                const confirmed = await appDialog({
                    title: 'פתיחה ללא GPS',
                    message: 'במצב זה לא תתבצע בדיקת מרחק לתלמידים — כל תלמיד יוכל לרשום נוכחות ללא אימות מיקום. האם להמשיך?',
                    confirmText: 'כן, פתח ללא GPS',
                    cancelText: 'ביטול',
                    danger: true
                });
                if (!confirmed) return;
                btn.disabled = true;
                btn.textContent = "פותח מפגש...";
                await addDoc(collection(db, "groups", state.curGroupId, "sessions"), {
                    sessionNumber: Number(num), expectedStartTime: start, expectedEndTime: end,
                    status: 'open', attendance: {}, exceptions: {}, createdAt: serverTimestamp(),
                    instructorLocation: null, noGpsMode: true, attendanceRadius: 0,
                    accessCode: document.getElementById('ns-access-code').value.trim() || null,
                    graceMins: state.graceMins ?? 15
                });
                writeLog('session', `פתיחת מפגש ${num} ללא GPS | שעת התחלה: ${start}${end ? ` | סיום: ${end}` : ''} | קבוצה: ${state.curGroupId}`);
                closeModals();
                showToast('מפגש נפתח ללא GPS — תלמידים לא יעברו בדיקת מרחק', 'warning');
                loadSessions();
                return;
            }

            // ── NORMAL GPS MODE ──────────────────────────────────────────────────────
            btn.disabled = true;
            btn.textContent = "דוגם מיקום...";
            navigator.geolocation.getCurrentPosition(
                async (pos) => {
                    const radiusVal = Math.max(10, Math.min(2000, Number(document.getElementById('ns-radius').value) || 50));
                    await addDoc(collection(db, "groups", state.curGroupId, "sessions"), {
                        sessionNumber: Number(num), expectedStartTime: start, expectedEndTime: end,
                        status: 'open', attendance: {}, exceptions: {}, createdAt: serverTimestamp(),
                        instructorLocation: { lat: pos.coords.latitude, lng: pos.coords.longitude },
                        attendanceRadius: radiusVal,
                        accessCode: document.getElementById('ns-access-code').value.trim() || null,
                        graceMins: state.graceMins ?? 15
                    });
                    writeLog('session', `פתיחת מפגש ${num} | שעת התחלה: ${start}${end ? ` | סיום: ${end}` : ''} | רדיוס: ${radiusVal}מ' | קבוצה: ${state.curGroupId}`);
                    btn.disabled = false;
                    btn.textContent = "פתח ודגום מיקום";
                    closeModals();
                    showToast('מפגש נפתח בהצלחה! המיקום נדגם', 'success');
                    loadSessions();
                },
                async (geoError) => {
                    btn.disabled = false;
                    btn.textContent = "פתח ודגום מיקום";
                    if (geoError && geoError.code === 1) {
                        // PERMISSION_DENIED — browser already blocked location, will not re-prompt.
                        // Give the user clear reset instructions AND the option to open without GPS.
                        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
                        const resetSteps = isIOS
                            ? 'כיצד לאפס:\nהגדרות ← פרטיות ← שירותי מיקום ← Safari ← "בעת השימוש"\nלאחר מכן רענן את הדף ונסה שוב.'
                            : 'כיצד לאפס (Chrome):\nלחץ על 🔒 בשורת הכתובת ← הגדרות האתר ← מיקום ← אפשר.\nלאחר מכן רענן את הדף ונסה שוב.\n\nאם לא מצליח — השתמש בכפתור "פתח ללא GPS".';
                        await appDialog({
                            title: 'הרשאת מיקום נדחתה',
                            message: 'הדפדפן חסם גישה למיקום (ייתכן שנדחה בעבר).\n\n' + resetSteps,
                            confirmText: 'הבנתי'
                        });
                    } else {
                        await appDialog({
                            title: 'שגיאת GPS',
                            message: 'לא ניתן לקבל מיקום. ודא שה-GPS דלוק ושהאתר מאושר לגישה למיקום.\nאם הבעיה נמשכת — השתמש בכפתור "פתח ללא GPS".',
                            confirmText: 'סגור'
                        });
                    }
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }

        // =====================================================
        // LIVE SESSION REPORT
        // =====================================================
        function openReportLive(sid, snum, status) {
            state.curSessionId = sid;
            state.liveSessionNumber = snum;
            state.viewingRound = null; // start at current/live round
            state._lastKnownSessionStatus = null; // reset so onSnapshot tracks fresh transitions
            document.getElementById('instructor-group-details').classList.add('hidden');
            document.getElementById('session-report-view').classList.remove('hidden');
            safeText(document.getElementById('report-title'), `מפגש ${snum}`);
            document.getElementById('btn-lock-session').classList.toggle('hidden', status !== 'open');
            document.getElementById('btn-bypass-gps').classList.toggle('hidden', status !== 'open');
            // Edit always visible so instructor/admin can fix attendance on closed sessions too
            document.getElementById('btn-edit-session').classList.remove('hidden');
            // Multi-round: show "add round" button only for open sessions
            const addRoundBtn = document.getElementById('btn-add-round');
            if (addRoundBtn) {
                // FEATURE 1: Always show the button — addAttendanceRound handles open vs closed logic
                addRoundBtn.style.display = '';
                addRoundBtn.textContent = (status === 'open') ? 'בדיקה נוספת' : 'בדיקה נוספת (פתח מחדש)';
            }

            if (state.liveUnsubscribe) state.liveUnsubscribe();
            state.liveUnsubscribe = onSnapshot(doc(db, "groups", state.curGroupId, "sessions", sid), async (snap) => {
                // FIX A: If we already navigated away (e.g. after auto-lock), ignore stale snapshots.
                if (state.curSessionId !== sid) return;
                state.liveSessionData = snap.data();
                const sdata = state.liveSessionData;

                // ── AUTO-LOCK: check end-time passed OR all members registered ──────
                // Guard: if already locking, skip auto-lock logic but continue to render
                if (!state._autoLocking && sdata && sdata.status === 'open') {
                    let shouldAutoLock = false;
                    let lockReason = '';

                    // 1. End-time passed
                    if (sdata.expectedEndTime) {
                        const now = new Date();
                        const [endH, endM] = sdata.expectedEndTime.split(':').map(Number);
                        const endDate = new Date();
                        endDate.setHours(endH, endM, 0, 0);
                        // Guard: only auto-lock if the session end-time was within the last 12 hours.
                        // This prevents stale Firestore snapshots from triggering auto-lock for
                        // sessions that were already handled (or were reopened just after midnight).
                        const msSinceEnd = now - endDate;
                        if (msSinceEnd >= 0 && msSinceEnd < 12 * 60 * 60 * 1000) {
                            shouldAutoLock = true;
                            lockReason = 'שעת הסיום עברה';
                        }
                    }

                    // 2. All group members have a registration (att exists) in this session
                    // אם המפגש נפתח מחדש — בודקים רק רישומים שנוצרו אחרי זמן הפתיחה מחדש
                    if (!shouldAutoLock && state.membersCache && state.membersCache.length > 0) {
                        const reopenedAt = sdata.reopenedAt; // Firestore Timestamp or null
                        const allRegistered = state.membersCache.every(m => {
                            const att = sdata.attendance?.[m.uid];
                            if (!att || !['on_time', 'late', 'excused', 'absent'].includes(att.status)) return false;
                            // אם המפגש נפתח מחדש — רישום ישן (לפני הפתיחה מחדש) לא נחשב
                            if (reopenedAt && att.timestamp) {
                                const attTime = att.timestamp.toMillis ? att.timestamp.toMillis() : (att.timestamp.seconds ? att.timestamp.seconds * 1000 : null);
                                const reopenTime = reopenedAt.toMillis ? reopenedAt.toMillis() : (reopenedAt.seconds ? reopenedAt.seconds * 1000 : null);
                                if (attTime !== null && reopenTime !== null && attTime < reopenTime) return false;
                            }
                            return true;
                        });
                        if (allRegistered) {
                            shouldAutoLock = true;
                            lockReason = 'כל החניכים נרשמו';
                        }
                    }

                    if (shouldAutoLock) {
                        // Mark absent any member without attendance
                        const updates = {};
                        if (state.membersCache) {
                            state.membersCache.forEach(m => {
                                if (!sdata.attendance?.[m.uid]) {
                                    updates[`attendance.${m.uid}`] = { status: 'absent', autoMarked: true, timestamp: new Date() };
                                }
                            });
                        }
                        updates.status = 'closed';
                        // Archive final round if multi-round is active
                        if (sdata.rounds > 1 && sdata.attendance) {
                            const lastRound = sdata.rounds - 1;
                            // FIX 2: Store full status object in auto-lock round archive (not just boolean)
                            Object.entries(sdata.attendance).forEach(([uid, att]) => {
                                if (att) {
                                    updates[`roundAttendance.${uid}.${lastRound}`] = {
                                        status: att.status,
                                        minutes: att.minutes || 0,
                                        setByInstructor: att.setByInstructor || false
                                    };
                                } else {
                                    updates[`roundAttendance.${uid}.${lastRound}`] = { status: 'absent', minutes: 0 };
                                }
                            });
                        }
                        state._autoLocking = true;
                        try {
                            await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), updates);
                        } finally {
                            state._autoLocking = false;
                        }
                        showToast(`המפגש נסגר אוטומטית — ${lockReason}`, 'success');
                        // FIX A: Unsubscribe, reload sessions list, and navigate back to group view
                        // so the instructor sees the updated closed status immediately without manual refresh.
                        if (state.liveUnsubscribe) { state.liveUnsubscribe(); state.liveUnsubscribe = null; }
                        document.getElementById('session-report-view').classList.add('hidden');
                        // Restore group-details panel and ensure sessions tab is active
                        document.getElementById('instructor-group-details').classList.remove('hidden');
                        document.querySelectorAll('[data-group-tab]').forEach(t => t.classList.remove('active'));
                        const sessTabBtn = document.querySelector('[data-group-tab="sessions"]');
                        if (sessTabBtn) sessTabBtn.classList.add('active');
                        document.getElementById('tab-sessions').classList.remove('hidden');
                        document.getElementById('tab-students').classList.add('hidden');
                        document.getElementById('tab-notices').classList.add('hidden');
                        state.liveSessionData = null;
                        state.curSessionId = null;
                        await loadSessions();
                        loadInstructorMain();
                        return; // stop processing this snapshot
                    }
                }

                const bypassText = document.getElementById('bypass-status-text');
                if (state.liveSessionData.gpsBypassUntil && state.liveSessionData.gpsBypassUntil > Date.now()) {
                    const secs = Math.round((state.liveSessionData.gpsBypassUntil - Date.now()) / 1000);
                    safeText(bypassText, `מצב מעקף מיקום פעיל לעוד ${secs} שניות`);
                    bypassText.classList.remove('hidden');
                } else {
                    bypassText.classList.add('hidden');
                }

                // ── Sync action-buttons visibility with live session status ──
                const isSessionOpen = sdata.status === 'open';
                document.getElementById('btn-lock-session').classList.toggle('hidden', !isSessionOpen);
                document.getElementById('btn-bypass-gps').classList.toggle('hidden', !isSessionOpen);

                // Update "add round" button: hide when max rounds reached or session closed
                const addRoundBtnSnap = document.getElementById('btn-add-round');
                if (addRoundBtnSnap) {
                    const isOpen = sdata.status === 'open';
                    const underMax = (sdata.rounds || 1) < 3;
                    // FEATURE 1: Show for closed sessions too (handler checks 48h & reopens)
                    addRoundBtnSnap.style.display = underMax ? '' : 'none';
                    addRoundBtnSnap.textContent = isOpen ? 'בדיקה נוספת' : 'פתח בדיקה נוספת';
                }

                // ── Refresh sessions list whenever status changes ──
                // This ensures the instructor group list always shows the correct open/closed state
                // (auto-lock already calls loadSessions separately, this handles all other transitions)
                const prevStatus = state._lastKnownSessionStatus;
                const curStatus = sdata.status;
                if (prevStatus && prevStatus !== curStatus) {
                    loadSessions();
                    loadInstructorMain();
                }
                state._lastKnownSessionStatus = curStatus;

                renderReport(state.liveSessionData);
            });
        }

        // buildRoundTabs is kept as a no-op so existing callers don't break.
        // Round navigation is now handled inline inside renderReport.
        function buildRoundTabs(sdata) { /* rounds shown inline per student — no tab bar needed */ }

        async function renderReport(sdata) {
            buildRoundTabs(sdata); // no-op, kept for compatibility
            const container = document.getElementById('report-container');
            container.innerHTML = '';

            const totalRounds = sdata.rounds || 1;
            const isMultiRound = totalRounds > 1;
            const isSessionOpen = sdata.status === 'open';

            // ── Sort members according to state.reportSort ────────────────
            // STATUS ORDER (asc): exception-unread → exception → not-reported → snoozed/absent-manual →
            //   late (sorted desc by minutes within group) → on_time → excused
            function getStatusRank(uid) {
                const att = sdata.attendance?.[uid];
                const exc = sdata.exceptions?.[uid];
                if (exc && !exc.snoozed && exc.type === 'manual_request' && !exc.viewed) return 0;  // בקשה חריגה לא נצפתה
                if (exc && !exc.snoozed)                                                  return 1;  // חריג נצפה
                if (!att)                                                                 return 2;  // טרם דיווח
                if (exc?.snoozed)                                                        return 3;  // לטיפול
                if (att.status === 'absent')                                             return 4;  // חיסור
                if (att.status === 'late')                                               return 5;  // איחור
                if (att.status === 'on_time')                                            return 6;  // הגיע בזמן
                if (att.status === 'excused')                                            return 7;  // חיסור באישור
                return 8;
            }

            function getArrivalTime(uid) {
                const att = sdata.attendance?.[uid];
                if (!att || !att.timestamp) return Infinity; // לא הגיע — סוף הרשימה
                const ts = att.timestamp;
                return ts.toMillis ? ts.toMillis() : (ts.seconds ? ts.seconds * 1000 : Infinity);
            }

            const { key: sKey, dir: sDir } = (state.reportSort || { key: 'status', dir: 'asc' });
            const mul = sDir === 'asc' ? 1 : -1;

            const sorted = [...state.membersCache].sort((a, b) => {
                if (sKey === 'name') {
                    return mul * a.name.localeCompare(b.name, 'he');
                }
                if (sKey === 'time') {
                    const ta = getArrivalTime(a.uid), tb = getArrivalTime(b.uid);
                    // For asc: earliest first. Infinity (no arrival) always last regardless of dir.
                    if (ta === Infinity && tb === Infinity) return a.name.localeCompare(b.name, 'he');
                    if (ta === Infinity) return 1;
                    if (tb === Infinity) return -1;
                    return mul * (ta - tb);
                }
                // Default: status
                const ra = getStatusRank(a.uid), rb = getStatusRank(b.uid);
                if (ra !== rb) return mul * (ra - rb);
                // Within the late group: secondary sort by minutes descending (most late first)
                if (ra === 5) {
                    const ma = sdata.attendance?.[a.uid]?.minutes || 0;
                    const mb = sdata.attendance?.[b.uid]?.minutes || 0;
                    return mb - ma; // always most-late first regardless of asc/desc
                }
                return a.name.localeCompare(b.name, 'he');
            });

            // ── CSS colour tokens for live status ─────────────────────────
            // Returns { borderColor, bgColor, statusText, statusCls }
            function getLiveStyle(uid) {
                const att = sdata.attendance?.[uid];
                const exc = sdata.exceptions?.[uid];
                if (exc && !exc.snoozed && exc.type === 'manual_request') {
                    const isUnread = !exc.viewed;
                    return {
                        borderColor: isUnread ? 'var(--danger)' : 'var(--amber)',
                        bgColor: isUnread ? 'rgba(220,38,38,0.07)' : 'var(--amber-soft)',
                        statusText: 'בקשה חריגה',
                        statusCls: isUnread ? 'exc-intense' : 'bg-blink-warn',
                        distTxt: exc.timestamp?.toDate
                            ? `\n${exc.timestamp.toDate().toLocaleTimeString('he-IL',{hour:'2-digit',minute:'2-digit'})} | ${exc.distance || 'לא נדגם'}מ'`
                            : ''
                    };
                }
                if (exc?.snoozed) return { borderColor: 'var(--danger)', bgColor: 'rgba(220,38,38,0.06)', statusText: 'לטיפול (חסר)', statusCls: 'bg-absent-static', distTxt: '' };
                if (!att) {
                    if (isSessionOpen) return { borderColor: 'var(--border)', bgColor: 'var(--surface)', statusText: 'טרם נרשם', statusCls: 'bg-blink-warn', distTxt: '' };
                    return { borderColor: 'var(--border)', bgColor: 'var(--surface-2)', statusText: 'חיסור', statusCls: 'bg-absent-static', distTxt: '' };
                }
                const dist = att.distance ? ` (${att.distance}מ')` : '';
                if (att.status === 'on_time')  return { borderColor: 'var(--green)',  bgColor: 'var(--green-soft)',           statusText: 'נוכח',                          statusCls: 'bg-green',        distTxt: dist };
                if (att.status === 'late')     return { borderColor: 'var(--amber)',  bgColor: 'var(--amber-soft)',           statusText: `איחור (${att.minutes || 0}דק')`, statusCls: 'bg-yellow',       distTxt: dist };
                if (att.status === 'excused')  return { borderColor: 'var(--blue)',   bgColor: 'var(--blue-soft)',            statusText: 'באישור',                        statusCls: 'bg-blue',         distTxt: dist };
                if (att.status === 'absent')   return { borderColor: 'var(--danger)', bgColor: 'rgba(220,38,38,0.07)',        statusText: 'חיסור',                         statusCls: 'bg-red',          distTxt: '' };
                return { borderColor: 'var(--border)', bgColor: 'var(--surface)', statusText: '—', statusCls: '', distTxt: '' };
            }

            // ── Chip data for an ARCHIVED round (ri < totalRounds-1) ──────
            function getArchivedChip(uid, ri) {
                const entry = sdata.roundAttendance?.[uid]?.[ri];
                if (!entry) return { txt: 'חיסור', cls: 'c-red' };
                const st  = typeof entry === 'object' ? entry.status : (entry ? 'on_time' : 'absent');
                const min = typeof entry === 'object' ? (entry.minutes || 0) : 0;
                if (st === 'on_time')  return { txt: 'נוכח',           cls: 'c-green' };
                if (st === 'late')     return { txt: `⏰ ${min}′`,      cls: 'c-yellow' };
                if (st === 'excused')  return { txt: 'באישור',         cls: 'c-blue' };
                return { txt: 'חיסור', cls: 'c-red' };
            }

            // ── Open edit modal for a specific round ──────────────────────
            async function openEditForRound(uid, roundIndex, studentName) {
                if (!isAdmin() && sdata.status === 'closed') {
                    const createdAt = sdata.createdAt;
                    if (createdAt) {
                        const t = createdAt.toMillis ? createdAt.toMillis() : (createdAt.seconds ? createdAt.seconds * 1000 : 0);
                        if ((Date.now() - t) / 3600000 >= 48) {
                            await appDialog({ title: 'לא ניתן לערוך', message: 'ניתן לערוך נוכחות רק תוך 48 שעות מסגירת המפגש.', confirmText: 'סגור' });
                            return;
                        }
                    }
                }
                const isLiveRound = (roundIndex === totalRounds - 1);
                state.curEditUid = uid;
                if (isLiveRound) {
                    state._editingArchivedRound = null;
                    const att = sdata.attendance?.[uid];
                    const exc = sdata.exceptions?.[uid];
                    safeText(document.getElementById('es-name'), studentName);
                    document.getElementById('es-late-mins').value = att?.minutes || '';
                    if (exc?.type === 'manual_request') {
                        const excTime = exc.timestamp?.toDate ? exc.timestamp.toDate().toLocaleString('he-IL') : 'לא זמין';
                        safeText(document.getElementById('es-exception-info'), `בקשה חריגה | מרחק: ${exc.distance || 'לא נדגם'}מ' | נשלחה: ${excTime}`);
                    } else {
                        safeText(document.getElementById('es-exception-info'), '');
                    }
                    document.getElementById('btn-snooze-action').classList.toggle('hidden',
                        !!(sdata.attendance?.[uid]) || !!(sdata.exceptions?.[uid]?.snoozed) || sdata.status === 'closed');
                } else {
                    state._editingArchivedRound = roundIndex;
                    const entry = sdata.roundAttendance?.[uid]?.[roundIndex];
                    safeText(document.getElementById('es-name'), `${studentName} — סיבוב ${roundIndex + 1}`);
                    document.getElementById('es-late-mins').value = (entry && typeof entry === 'object' && entry.minutes) ? entry.minutes : '';
                    safeText(document.getElementById('es-exception-info'), '');
                    document.getElementById('btn-snooze-action').classList.add('hidden');
                }
                document.getElementById('edit-student-modal').classList.remove('hidden');
            }

            // ── Collect pending exception (outside loop) ──────────────────
            let pendingExceptionStudent = null;

            // ── Render each student ───────────────────────────────────────
            for (const student of sorted) {
                const exc = sdata.exceptions?.[student.uid];
                if (exc?.type === 'manual_request' && !exc.viewed && !pendingExceptionStudent) {
                    pendingExceptionStudent = { student, exc };
                }

                const { borderColor, bgColor, statusText, statusCls, distTxt } = getLiveStyle(student.uid);

                // ── Outer card ────────────────────────────────────────────
                const card = document.createElement('div');
                card.style.cssText = `
                    display:flex; align-items:stretch;
                    border:2.5px solid ${borderColor};
                    background:${bgColor};
                    border-radius:var(--r-md);
                    margin-bottom:7px;
                    overflow:hidden;
                    cursor:pointer;
                    transition: box-shadow 0.15s, border-color 0.12s, transform 0.1s;
                    -webkit-tap-highlight-color:transparent;
                    touch-action:manipulation;
                    box-shadow: 0 1px 4px rgba(0,0,0,0.07);
                `;
                card.addEventListener('mouseenter', () => { card.style.boxShadow = 'var(--shadow-sm)'; card.style.transform = 'translateY(-1px)'; });
                card.addEventListener('mouseleave', () => { card.style.boxShadow = '0 1px 4px rgba(0,0,0,0.07)'; card.style.transform = ''; });
                card.addEventListener('click', () => openEditForRound(student.uid, totalRounds - 1, student.name));

                // ── Main section (name + live status) ────────────────────
                const main = document.createElement('div');
                main.style.cssText = 'flex:1;min-width:0;display:flex;align-items:center;justify-content:space-between;padding:12px 14px;gap:8px;';

                const nameEl = document.createElement('span');
                nameEl.style.cssText = 'font-weight:700;font-size:0.95rem;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0;';
                nameEl.textContent = student.name;

                const statusWrap = document.createElement('div');
                statusWrap.style.cssText = 'display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0;';

                const statusBadge = document.createElement('strong');
                // Style the badge as a pill for the live (current) round
                statusBadge.style.cssText = `
                    display:inline-flex; align-items:center;
                    padding:3px 10px; border-radius:99px;
                    font-size:0.8rem; font-weight:800; white-space:nowrap;
                    background: ${borderColor}22;
                    color: ${borderColor === 'var(--border)' ? 'var(--muted)' : borderColor};
                    border: 1.5px solid ${borderColor}55;
                `;
                if (distTxt && distTxt.includes('\n')) {
                    const parts = distTxt.split('\n');
                    statusBadge.textContent = statusText + (parts[0] || '');
                    const det = document.createElement('span');
                    det.className = 'exc-detail';
                    det.textContent = parts[1] || '';
                    statusBadge.appendChild(det);
                } else {
                    statusBadge.textContent = statusText + (distTxt || '');
                }
                statusWrap.appendChild(statusBadge);
                main.appendChild(nameEl);
                main.appendChild(statusWrap);
                card.appendChild(main);

                // ── Past round chips ──────────────────────────────────────────
                // Visual layout (RTL, right→left):
                //   [בדיקה נוכחית] | [בדיקה 2] | [בדיקה 1]
                // בדיקה 1 = leftmost, בדיקה נוכחית = rightmost (main card).
                // Implementation: card is normal LTR-order flex row (no row-reverse).
                // Main section appended FIRST = rightmost in RTL page.
                // Chips appended AFTER = flow to the left in RTL.
                if (isMultiRound) {
                    // Force LTR on the card so DOM order = visual order:
                    //   main (index 0, leftmost in LTR) | chips left→right
                    // But we WANT: main on RIGHT, chips on LEFT.
                    // So: use LTR order but put chips first in DOM (they appear on left),
                    // then main (appears on right). card.dir = 'ltr'.
                    card.setAttribute('dir', 'ltr');
                    card.style.flexDirection = 'row';

                    // Remove main temporarily — we will re-insert it AFTER chips (= visually right in LTR)
                    card.removeChild(main);

                    // Separator: right border on main (= its left edge facing chips)
                    main.style.cssText += `border-left: 3px solid ${borderColor};`;
                    // Keep text RTL inside main
                    main.setAttribute('dir', 'rtl');

                    const archivedCount = totalRounds - 1;
                    const chipBgMap    = { 'c-green':'rgba(5,150,105,0.12)', 'c-red':'rgba(220,38,38,0.09)', 'c-yellow':'rgba(217,119,6,0.11)', 'c-blue':'rgba(37,99,235,0.09)', 'c-grey':'rgba(0,0,0,0.04)' };
                    const chipClrMap   = { 'c-green':'var(--green)',          'c-red':'var(--danger)',         'c-yellow':'var(--amber)',          'c-blue':'var(--blue)',          'c-grey':'var(--muted)' };
                    const chipBorderMap= { 'c-green':'rgba(5,150,105,0.35)', 'c-red':'rgba(220,38,38,0.30)', 'c-yellow':'rgba(217,119,6,0.35)', 'c-blue':'rgba(37,99,235,0.30)', 'c-grey':'rgba(0,0,0,0.10)' };

                    // Chips in DOM order 0→archivedCount-1 = בדיקה 1 leftmost, highest rightmost (adjacent to main)
                    for (let ri = 0; ri < archivedCount; ri++) {
                        const { txt, cls } = getArchivedChip(student.uid, ri);

                        const chip = document.createElement('div');
                        chip.setAttribute('dir', 'rtl');
                        chip.style.cssText = `
                            width:20vw; max-width:82px; min-width:50px;
                            display:flex; flex-direction:column; align-items:center; justify-content:center;
                            padding:6px 4px; gap:3px;
                            cursor:pointer;
                            background:${chipBgMap[cls] || 'rgba(0,0,0,0.04)'};
                            border: 2px solid ${chipBorderMap[cls] || 'rgba(0,0,0,0.10)'};
                            border-radius: var(--r-md);
                            margin: 4px 4px 4px 0;
                            -webkit-tap-highlight-color:transparent;
                            touch-action:manipulation;
                            transition: opacity 0.12s, transform 0.1s;
                            flex-shrink:0;
                        `;

                        const lbl = document.createElement('span');
                        lbl.style.cssText = `font-size:0.55rem;font-weight:700;color:var(--muted);letter-spacing:0.3px;white-space:nowrap;`;
                        lbl.textContent = `בדיקה ${ri + 1}`;

                        const val = document.createElement('span');
                        val.style.cssText = `font-size:0.75rem;font-weight:800;color:${chipClrMap[cls] || 'var(--muted)'};text-align:center;white-space:nowrap;`;
                        val.textContent = txt;

                        chip.appendChild(lbl);
                        chip.appendChild(val);

                        chip.addEventListener('mouseenter', () => { chip.style.opacity = '0.75'; chip.style.transform = 'scale(0.97)'; });
                        chip.addEventListener('mouseleave', () => { chip.style.opacity = '1';    chip.style.transform = ''; });
                        chip.addEventListener('click', (e) => {
                            e.stopPropagation();
                            openEditForRound(student.uid, ri, student.name);
                        });

                        card.appendChild(chip);
                    }

                    // Main appended last = rightmost in LTR, which is what we want
                    card.appendChild(main);
                }

                container.appendChild(card);
            }

            // ── Post-loop: show exception alert if pending ────────────────
            if (pendingExceptionStudent) {
                const { student, exc } = pendingExceptionStudent;
                const eamText = document.getElementById('eam-text');
                eamText.innerHTML = '';
                const p1 = document.createElement('p');
                p1.textContent = `התקבלה בקשת אישור רישום ידני מאת `;
                const strong = document.createElement('strong');
                strong.textContent = student.name;
                p1.appendChild(strong);
                p1.appendChild(document.createTextNode('.'));
                const p2 = document.createElement('p');
                p2.innerHTML = `מרחק שנמדד: <strong style="color:var(--danger);">${safeHTML(exc.distance || 'לא צוין')} מטרים</strong>`;
                eamText.appendChild(p1);
                eamText.appendChild(document.createElement('br'));
                eamText.appendChild(p2);
                document.getElementById('exception-alert-modal').classList.remove('hidden');
                await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), {
                    [`exceptions.${student.uid}.viewed`]: true
                });
            }
        }

        function getRank(uid, sdata) {
            const att = sdata.attendance?.[uid];
            const exc = sdata.exceptions?.[uid];
            if (exc && !exc.snoozed && exc.type === 'manual_request' && !exc.viewed) return -1;
            if (exc && !exc.snoozed) return 0;
            if (!att && !exc) return 1;
            if (exc?.snoozed) return 2;
            return 3;
        }

        async function updateStatus(type) {
            const ref = doc(db, "groups", state.curGroupId, "sessions", state.curSessionId);
            const mins = parseInt(document.getElementById('es-late-mins').value) || 0;
            const studentNameRaw = document.getElementById('es-name').textContent;
            const studentName = studentNameRaw.replace(/ — סיבוב \d+$/, ''); // strip round label if present
            const statusLabels = { absent: 'חיסור', on_time: 'נוכח', late: `איחור (${mins} דק')`, excused: 'באישור' };
            const modalBtns = document.querySelectorAll('#edit-student-modal button');

            // FIX 2: Enforce 48h edit window for non-admin instructors on closed sessions.
            // Admins can always edit. Instructors can only edit within 48 hours of session creation.
            if (!isAdmin() && state.liveSessionData?.status === 'closed') {
                const createdAt = state.liveSessionData?.createdAt;
                if (createdAt) {
                    const createdTime = createdAt.toMillis ? createdAt.toMillis() : (createdAt.seconds ? createdAt.seconds * 1000 : 0);
                    const diffHours = (Date.now() - createdTime) / (1000 * 60 * 60);
                    if (diffHours >= 48) {
                        await appDialog({ title: 'לא ניתן לערוך', message: 'ניתן לערוך נוכחות רק תוך 48 שעות מסגירת המפגש. לאחר מכן יש לפנות למנהל מערכת.', confirmText: 'סגור' });
                        return;
                    }
                }
            }

            modalBtns.forEach(b => b.disabled = true);

            // ── עריכת סיבוב ארכיוני ──────────────────────────────────────────
            if (state._editingArchivedRound !== null && state._editingArchivedRound !== undefined) {
                const roundIdx = state._editingArchivedRound;
                // FIX 2: Store full status object for archived round edit (not just boolean)
                const archivedEntry = { status: type, minutes: (type === 'late' && mins > 0) ? mins : 0, setByInstructor: true };
                await withTimeout(async () => {
                    await updateDoc(ref, { [`roundAttendance.${state.curEditUid}.${roundIdx}`]: archivedEntry });
                    closeModals();
                    writeLog('edit', `עריכת נוכחות סיבוב ${roundIdx + 1}: ${studentName} → ${statusLabels[type]||type} | מפגש ${state.liveSessionNumber} | קבוצה ${state.curGroupId}`);
                }, null, null);
                modalBtns.forEach(b => b.disabled = false);
                state._editingArchivedRound = null;
                return;
            }

            await withTimeout(async () => {
                // Check if there was an exception — store resolution so student can see it
                const sessionSnap = await getDoc(ref);
                const excData = sessionSnap.data()?.exceptions?.[state.curEditUid];
                if (type === 'absent') {
                    if (excData?.type === 'manual_request') {
                        await updateDoc(ref, { [`exceptions.${state.curEditUid}.resolvedStatus`]: 'denied' });
                        await new Promise(r => setTimeout(r, 300));
                    }
                    await updateDoc(ref, {
                        [`attendance.${state.curEditUid}`]: { status: 'absent', timestamp: serverTimestamp(), setByInstructor: true },
                        [`exceptions.${state.curEditUid}`]: deleteField()
                    });
                } else {
                    const dataToSave = { status: type, timestamp: serverTimestamp() };
                    if (type === 'late' && mins > 0) dataToSave.minutes = mins;
                    if (excData?.type === 'manual_request') {
                        await updateDoc(ref, { [`exceptions.${state.curEditUid}.resolvedStatus`]: 'approved' });
                        await new Promise(r => setTimeout(r, 300));
                    }
                    await updateDoc(ref, { [`attendance.${state.curEditUid}`]: dataToSave, [`exceptions.${state.curEditUid}`]: deleteField() });
                }
                closeModals();
                writeLog('edit', `עריכת נוכחות: ${studentName} → ${statusLabels[type]||type} | מפגש ${state.liveSessionNumber} | קבוצה ${state.curGroupId}`);
            }, null, null);
            modalBtns.forEach(b => b.disabled = false);
        }

        async function snoozeException() {
            await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), { [`exceptions.${state.curEditUid}.snoozed`]: true });
            closeModals();
        }

        // =====================================================
        // MULTI-ROUND ATTENDANCE
        // =====================================================
        async function addAttendanceRound() {
            // Check max rounds
            const sessionRef = doc(db, "groups", state.curGroupId, "sessions", state.curSessionId);
            const snapCheck = await getDoc(sessionRef);
            const sdataCheck = snapCheck.data();
            if ((sdataCheck.rounds || 1) >= 3) {
                await appDialog({ title: 'הגעת למקסימום', message: 'ניתן לפתוח עד 3 בדיקות נוכחות לכל מפגש.', confirmText: 'סגור' });
                return;
            }

            const isClosed = sdataCheck.status === 'closed';

            // FEATURE 1: If session is closed, ask how many minutes to reopen and compute new endTime
            let extraMinutes = 0;
            let newEndTime = null;
            if (isClosed) {
                const minsRaw = await appDialog({
                    title: 'פתיחת בדיקה נוספת',
                    message: 'המפגש סגור. לכמה דקות לפתוח בדיקת נוכחות נוספת?',
                    input: true, inputPlaceholder: 'לדוגמה: 10',
                    confirmText: 'פתח', cancelText: 'ביטול'
                });
                if (minsRaw === null) return;
                extraMinutes = Math.max(1, parseInt(minsRaw) || 10);
                // Compute new end time: now + extraMinutes
                const newEnd = new Date(Date.now() + extraMinutes * 60 * 1000);
                newEndTime = `${String(newEnd.getHours()).padStart(2,'0')}:${String(newEnd.getMinutes()).padStart(2,'0')}`;
            } else {
                const confirmed = await appDialog({
                    title: 'פתיחת בדיקת נוכחות נוספת',
                    message: 'כל החניכים יתבקשו לדווח נוכחות שוב. הנוכחות הנוכחית תישמר ותוצג עם חלוקה לסיבובים.',
                    confirmText: 'פתח בדיקה נוספת',
                    cancelText: 'ביטול'
                });
                if (!confirmed) return;
            }

            const snap = await getDoc(sessionRef);
            const sdata = snap.data();
            const currentRound = (sdata.rounds || 1) - 1; // 0-indexed current round number
            const newRoundIndex = currentRound + 1;

            // Archive current attendance into roundAttendance[currentRound]
            const roundAttUpdates = {};
            if (sdata.attendance) {
                Object.entries(sdata.attendance).forEach(([uid, att]) => {
                    if (att) {
                        roundAttUpdates[`roundAttendance.${uid}.${currentRound}`] = {
                            status: att.status,
                            minutes: att.minutes || 0,
                            setByInstructor: att.setByInstructor || false
                        };
                    } else {
                        roundAttUpdates[`roundAttendance.${uid}.${currentRound}`] = { status: 'absent', minutes: 0 };
                    }
                });
            }

            // Build the update payload
            const updatePayload = {
                ...roundAttUpdates,
                attendance: {},
                exceptions: {},
                rounds: newRoundIndex + 1,
                status: 'open',   // reopen if was closed
                // Store the wall-clock time this round started — used for late calculation
                // so each round has its own grace window, not the original session start.
                roundStartedAt: Date.now()
            };
            // FEATURE 1: update endTime so auto-lock fires correctly after the extra window
            if (newEndTime) updatePayload.endTime = newEndTime;

            await updateDoc(sessionRef, updatePayload);

            // Update UI button states (show lock, hide reopen label)
            document.getElementById('btn-lock-session').classList.remove('hidden');
            const addRoundBtnNow = document.getElementById('btn-add-round');
            if (addRoundBtnNow) addRoundBtnNow.textContent = 'בדיקה נוספת';

            const msg = isClosed
                ? `המפגש נפתח מחדש לבדיקת נוכחות ${newRoundIndex + 1} — ייסגר בעוד ${extraMinutes} דקות`
                : `בדיקת נוכחות ${newRoundIndex + 1} נפתחה — חניכים יכולים לדווח שוב`;
            showToast(msg, 'success');
            writeLog('edit', `פתיחת בדיקת נוכחות נוספת (סיבוב ${newRoundIndex + 1}) במפגש ${state.liveSessionNumber}${isClosed ? ' — מפגש נפתח מחדש' : ''}`);
        }

        async function bypassGpsFor5Mins() {
            const until = Date.now() + (5 * 60 * 1000);
            await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), { gpsBypassUntil: until });
            showToast("בדיקת מיקום בוטלה ל-5 דקות הבאות", "success");
        }

        async function manualLock() {
            const confirmed = await appDialog({ title: 'סגירת מפגש', message: 'לסגור את רישום הנוכחות? לא ניתן לשחזר.', confirmText: 'סגור רישום', cancelText: 'ביטול', danger: true });
            if (!confirmed) return;
            const lockBtn = document.getElementById('btn-lock-session');
            await withTimeout(async () => {
                // Archive final round attendance if multi-round is active
                const sessionRef = doc(db, "groups", state.curGroupId, "sessions", state.curSessionId);
                const snapLock = await getDoc(sessionRef);
                const sdataLock = snapLock.data();
                const finalUpdates = { status: 'closed' };
                if (sdataLock && sdataLock.rounds > 1 && sdataLock.attendance) {
                    const lastRound = sdataLock.rounds - 1;
                    // FIX 2: Store full status object in final round archive (not just boolean)
                    Object.entries(sdataLock.attendance).forEach(([uid, att]) => {
                        if (att) {
                            finalUpdates[`roundAttendance.${uid}.${lastRound}`] = {
                                status: att.status,
                                minutes: att.minutes || 0,
                                setByInstructor: att.setByInstructor || false
                            };
                        } else {
                            finalUpdates[`roundAttendance.${uid}.${lastRound}`] = { status: 'absent', minutes: 0 };
                        }
                    });
                }
                await updateDoc(sessionRef, finalUpdates);
                writeLog('session', `נעילה ידנית של מפגש ${state.liveSessionNumber} | קבוצה: ${state.curGroupId}`);
                if (state.liveUnsubscribe) { state.liveUnsubscribe(); state.liveUnsubscribe = null; }
                document.getElementById('session-report-view').classList.add('hidden');
                document.getElementById('instructor-group-details').classList.remove('hidden');
                showToast('הרישום נסגר בהצלחה', 'success');
                await loadSessions();
                // Refresh instructor main so session status updates in group cards
                loadInstructorMain();
            }, lockBtn, 'סגור');
        }

        function getStudentRoundSummary(uid, sdata) {
            const totalRounds = sdata.rounds || 1;
            let presentCount = 0, lateCount = 0;
            const myArchived = sdata.roundAttendance?.[uid] || {};
            for (let ri = 0; ri < totalRounds - 1; ri++) {
                const entry = myArchived[ri];
                // FIX 2: Support both new object format {status,minutes} and legacy boolean
                let wasPresent = false, wasLate = false;
                if (entry && typeof entry === 'object') {
                    wasPresent = ['on_time', 'late', 'excused'].includes(entry.status);
                    wasLate = entry.status === 'late';
                } else {
                    wasPresent = entry === true;
                }
                if (wasPresent) presentCount++;
                if (wasLate) lateCount++;
            }
            const curAtt = sdata.attendance?.[uid];
            if (curAtt && ['on_time','late','excused'].includes(curAtt.status)) {
                presentCount++;
                if (curAtt.status === 'late') lateCount++;
            }
            return { presentCount, totalRounds, lateCount, wasEverPresent: presentCount > 0 };
        }

        function copySessionData() {
            if (!state.liveSessionData) return;
            const sdata = state.liveSessionData;
            const totalRounds = sdata.rounds || 1;
            let present = [], excused = [], absent = [];
            state.membersCache.forEach(student => {
                if (totalRounds > 1) {
                    const { presentCount, lateCount, wasEverPresent } = getStudentRoundSummary(student.uid, sdata);
                    if (wasEverPresent) {
                        const lateNote = lateCount > 0 ? ` | ${lateCount} איחור` : '';
                        present.push(`${student.name} (${presentCount}/${totalRounds}${lateNote})`);
                    } else { absent.push(student.name); }
                } else {
                    const att = sdata.attendance?.[student.uid];
                    if (att) {
                        if (att.status === 'on_time') present.push(student.name);
                        else if (att.status === 'late') present.push(`${student.name} (איחור ${att.minutes||0} דק')`);
                        else if (att.status === 'excused') excused.push(student.name);
                        else absent.push(student.name);
                    } else { absent.push(student.name); }
                }
            });
            let txt = `דוח נוכחות - מפגש ${state.liveSessionNumber}`;
            if (totalRounds > 1) txt += ` (${totalRounds} בדיקות)`;
            txt += '\n\n';
            txt += `*נכחו:*\n${present.length > 0 ? present.join('\n') : 'אין'}\n\n`;
            if (excused.length > 0) txt += `*חיסור באישור:*\n${excused.join('\n')}\n\n`;
            txt += `*לא הגיעו:*\n${absent.length > 0 ? absent.join('\n') : 'אין'}`;
            navigator.clipboard.writeText(txt).then(() => showToast("הנתונים הועתקו ללוח!")).catch(() => showToast("לא ניתן להעתיק — נסה ידנית", "error"));
        }
        function downloadSessionCSV() {
            if (!state.liveSessionData) return;
            const sdata = state.liveSessionData;
            const totalRounds = sdata.rounds || 1;
            let csvContent = "data:text/csv;charset=utf-8,\uFEFF";

            function fmtStatus(att) {
                if (!att) return "חיסור";
                if (att.status === 'on_time') return "נוכח";
                if (att.status === 'late') return `איחור (${att.minutes || 0} דק')`;
                if (att.status === 'excused') return "באישור";
                return "חיסור";
            }
            function fmtTime(att) {
                if (!att || !att.timestamp) return "";
                const ts = att.timestamp;
                const d = ts.toDate ? ts.toDate() : (ts.seconds ? new Date(ts.seconds * 1000) : new Date(ts));
                return d.toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' });
            }
            function fmtDist(att) {
                if (!att || att.distance === undefined || att.distance === null || att.distance === '') return "";
                return String(att.distance);
            }

            if (totalRounds > 1) {
                const header = ["שם", "תז"];
                for (let r = 1; r <= totalRounds; r++) {
                    header.push(`בדיקה ${r} סטטוס נוכחות`);
                    header.push(`בדיקה ${r} זמן רישום`);
                    header.push(`בדיקה ${r} מרחק רישום`);
                }
                csvContent += header.join(",") + "\r\n";
                state.membersCache.forEach(student => {
                    const row = [csvCell(student.name), csvCell(student.idNumber || '')];
                    for (let r = 1; r <= totalRounds; r++) {
                        const roundAtt = sdata.roundAttendance?.[student.uid]?.[`round_${r}`];
                        row.push(csvCell(fmtStatus(roundAtt)));
                        row.push(csvCell(fmtTime(roundAtt)));
                        row.push(csvCell(fmtDist(roundAtt)));
                    }
                    csvContent += row.join(",") + "\r\n";
                });
            } else {
                csvContent += `שם,תז,סטטוס נוכחות,זמן רישום,מרחק רישום\r\n`;
                state.membersCache.forEach(student => {
                    const att = sdata.attendance?.[student.uid];
                    csvContent += [
                        csvCell(student.name),
                        csvCell(student.idNumber || ''),
                        csvCell(fmtStatus(att)),
                        csvCell(fmtTime(att)),
                        csvCell(fmtDist(att))
                    ].join(",") + "\r\n";
                });
            }
            downloadCSV(csvContent, `מפגש_${state.liveSessionNumber}.csv`);
        }
        function downloadCSV(csvContent, filename) {
            // Remove the data URI prefix — we'll create a proper Blob instead.
            // encodeURI breaks on certain Hebrew characters and special symbols.
            const withoutPrefix = csvContent.replace(/^data:text\/csv;charset=utf-8,/, '');
            const blob = new Blob([withoutPrefix], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", filename);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }

        // =====================================================
        // STUDENTS (Instructor view)
        // =====================================================
        async function loadStudentsWithStats() {
            // FIX B: Prevent concurrent duplicate renders — if a load is already in progress, skip.
            if (state._loadingStudents) return;
            state._loadingStudents = true;
            try { await _loadStudentsWithStatsInner(); } finally { state._loadingStudents = false; }
        }
        async function _loadStudentsWithStatsInner() {
            const list = document.getElementById('instructor-students-list');
            const gDoc = await getDoc(doc(db, "groups", state.curGroupId));
            const uids = gDoc.data().members || [];
            state.membersCache = [];
            list.innerHTML = '';
            if (uids.length === 0) { list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין חניכים בקבוצה עדיין</p></div>'; return; }

            // Batch fetch — avoids N+1 queries
            const usersMap = await fetchUsersByUids(uids);

            uids.forEach(uid => {
                const u = usersMap[uid];
                if (!u) return;
                let present = 0, lateMins = 0;
                state.allSessionsCache.forEach(s => {
                    if (s.attendance?.[uid]) {
                        present++;
                        if (s.attendance[uid].minutes) lateMins += s.attendance[uid].minutes;
                    }
                });
                const pct = state.allSessionsCache.length ? Math.round((present / state.allSessionsCache.length) * 100) : 0;
                let colorClass = 'text-green';
                if (pct < 50) colorClass = 'text-red';
                else if (pct < 80) colorClass = 'text-orange';

                state.membersCache.push({ uid, name: u.fullName, idNumber: u.idNumber || '', pct, lateMins });

                const div = document.createElement('div');
                div.className = "list-item clickable";
                const info = document.createElement('div');
                info.style.flex = '1';
                info.style.cursor = 'pointer';
                const nameSpan = document.createElement('span');
                nameSpan.textContent = u.fullName + ' ';
                const pctStrong = document.createElement('strong');
                pctStrong.className = colorClass;
                pctStrong.textContent = `${pct}% נוכחות`;
                if (lateMins > 0) {
                    const lateSpan = document.createElement('span');
                    lateSpan.style.cssText = 'font-size:0.8rem;color:var(--amber);';
                    lateSpan.textContent = ` (${lateMins} דק' איחור)`;
                    pctStrong.appendChild(lateSpan);
                }
                info.appendChild(nameSpan);
                info.appendChild(pctStrong);
                info.addEventListener('click', () => showStudentHistory(uid, u.fullName));

                const removeBtn = document.createElement('button');
                removeBtn.className = 'icon-btn';
                removeBtn.style.marginRight = '10px';
                removeBtn.title = 'הסר מהקבוצה';
                removeBtn.textContent = '✕';
                removeBtn.addEventListener('click', (e) => removeUserFromGroup(uid, e));

                div.appendChild(info);
                div.appendChild(removeBtn);
                list.appendChild(div);
            });
        }

        async function addStudentById() {
            const idNumber = await appDialog({ title: 'הוספת חניך', message: 'הכנס תעודת זהות של החניך:', input: true, inputPlaceholder: '9 ספרות', confirmText: 'הוסף', cancelText: 'ביטול' });
            if (!idNumber) return;
            try {
                const q = query(collection(db, "users"), where("idNumber", "==", idNumber), where("role", "==", "student"));
                const snaps = await getDocs(q);
                if (snaps.empty) { await appDialog({ title: 'לא נמצא', message: 'לא נמצא תלמיד עם תעודת זהות זו. ודא שהוא נרשם למערכת.', confirmText: 'סגור' }); return; }
                const studentUid = snaps.docs[0].id;
                await updateDoc(doc(db, "groups", state.curGroupId), { members: arrayUnion(studentUid) });
                showToast("חניך צורף בהצלחה לקבוצה!");
                loadStudentsWithStats();
            } catch (err) {
                console.error('addStudentById error:', err);
                showToast('שגיאה בהוספת החניך — נסה שוב', 'error');
            }
        }

        async function addInstructorById() {
            const idNumber = await appDialog({ title: 'הוספת מדריך', message: 'הכנס תעודת זהות של המדריך הנוסף:', input: true, inputPlaceholder: 'תעודת זהות', confirmText: 'הוסף', cancelText: 'ביטול' });
            if (!idNumber) return;
            try {
                const q = query(collection(db, "users"), where("idNumber", "==", idNumber), where("role", "==", "instructor"));
                const snaps = await getDocs(q);
                if (snaps.empty) { await appDialog({ title: 'לא נמצא', message: 'לא נמצא מדריך עם תעודת זהות זו.', confirmText: 'סגור' }); return; }
                const instUid = snaps.docs[0].id;
                await updateDoc(doc(db, "groups", state.curGroupId), { coInstructors: arrayUnion(instUid) });
                showToast("מדריך נוסף צורף בהצלחה!");
            } catch (err) {
                console.error('addInstructorById error:', err);
                showToast('שגיאה בהוספת המדריך — נסה שוב', 'error');
            }
        }

        async function removeUserFromGroup(uid, e) {
            e.stopPropagation();
            const confirmed = await appDialog({ title: 'הסרת משתמש', message: 'האם להסיר משתמש זה מהקבוצה?', confirmText: 'הסר', cancelText: 'ביטול', danger: true });
            if (!confirmed) return;
            await updateDoc(doc(db, "groups", state.curGroupId), { members: arrayRemove(uid), coInstructors: arrayRemove(uid) });
            showToast("משתמש הוסר בהצלחה");
            loadStudentsWithStats();
        }

        function showStudentHistory(uid, name) {
            safeText(document.getElementById('sh-name'), name);
            const list = document.getElementById('sh-list');
            list.innerHTML = '';
            state.allSessionsCache.forEach(s => {
                const att = s.attendance?.[uid];
                let t = "חיסור", c = "bg-red";
                if (att) {
                    if (att.status === 'on_time') { t = "נוכח"; c = "bg-green"; }
                    else if (att.status === 'late') { t = `איחור (${att.minutes || 0} דק')`; c = "bg-yellow"; }
                    else if (att.status === 'excused') { t = "באישור"; c = "bg-blue"; }
                }
                // Multi-round: show fraction if applicable
                // FIX 2: Support both new object format and legacy boolean
                if (s.rounds > 1) {
                    const uidRounds = s.roundAttendance?.[uid] || {};
                    const rP = Object.values(uidRounds).filter(v =>
                        v && typeof v === 'object' ? ['on_time','late','excused'].includes(v.status) : v === true
                    ).length;
                    t += ` ${rP}/${s.rounds}`;
                }
                const div = document.createElement('div');
                div.className = 'list-item';
                const sessionSpan = document.createElement('span');
                sessionSpan.textContent = `מפגש ${s.sessionNumber}`;
                const statusSpan = document.createElement('span');
                statusSpan.className = `status-tag ${c}`;
                statusSpan.textContent = t;
                div.appendChild(sessionSpan);
                div.appendChild(statusSpan);
                list.appendChild(div);
            });
            document.getElementById('student-history-modal').classList.remove('hidden');
        }

        async function exportReportCSV() {
            if (state.membersCache.length === 0 || state.allSessionsCache.length === 0) { await appDialog({ title: 'שגיאה', message: 'אין מספיק נתונים לדוח', confirmText: 'סגור' }); return; }
            let csvContent = "data:text/csv;charset=utf-8,\uFEFF";
            const header = ["שם", "תז", "אחוזי נוכחות בקורס"];
            state.allSessionsCache.forEach(s => {
                const base = `מפגש ${s.sessionNumber}`;
                if (s.rounds && s.rounds > 1) {
                    for (let r = 1; r <= s.rounds; r++) {
                        header.push(`${base} בדיקה ${r} סטטוס נוכחות`);
                        header.push(`${base} בדיקה ${r} זמן רישום`);
                        header.push(`${base} בדיקה ${r} מרחק רישום`);
                    }
                } else {
                    header.push(`${base} סטטוס נוכחות`);
                    header.push(`${base} זמן רישום`);
                    header.push(`${base} מרחק רישום`);
                }
            });
            csvContent += header.join(",") + "\r\n";

            function attStatus(att) {
                if (!att) return "חיסור";
                if (att.status === 'on_time') return "נוכח";
                if (att.status === 'late') return `איחור (${att.minutes || 0} דק')`;
                if (att.status === 'excused') return "באישור";
                return "חיסור";
            }
            function attTime(att) {
                if (!att || !att.timestamp) return "";
                const ts = att.timestamp;
                const d = ts.toDate ? ts.toDate() : (ts.seconds ? new Date(ts.seconds * 1000) : new Date(ts));
                return d.toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' });
            }
            function attDist(att) {
                if (!att || att.distance === undefined || att.distance === null || att.distance === '') return "";
                return String(att.distance);
            }

            state.membersCache.forEach(m => {
                const row = [csvCell(m.name), csvCell(m.idNumber || ''), csvCell(`${m.pct}%`)];
                state.allSessionsCache.forEach(s => {
                    if (s.rounds && s.rounds > 1) {
                        for (let r = 1; r <= s.rounds; r++) {
                            const roundAtt = s.roundAttendance?.[m.uid]?.[`round_${r}`];
                            row.push(csvCell(attStatus(roundAtt)));
                            row.push(csvCell(attTime(roundAtt)));
                            row.push(csvCell(attDist(roundAtt)));
                        }
                    } else {
                        const att = s.attendance?.[m.uid];
                        row.push(csvCell(attStatus(att)));
                        row.push(csvCell(attTime(att)));
                        row.push(csvCell(attDist(att)));
                    }
                });
                csvContent += row.join(",") + "\r\n";
            });
            downloadCSV(csvContent, "דוח_נוכחות_מלא.csv");
        }

        // =====================================================
        // NOTICE BOARD
        // =====================================================
        async function loadNotices() {
            const list = document.getElementById('instructor-notices-list');
            list.innerHTML = '<div class="loading-text">טוען...</div>';
            const snaps = await getDocs(query(collection(db, "groups", state.curGroupId, "notices"), orderBy("createdAt", "desc")));
            list.innerHTML = '';
            snaps.forEach(d => {
                const n = d.data();
                const dateStr = n.createdAt ? n.createdAt.toDate().toLocaleDateString('he-IL') : '';
                const reads = n.readBy ? n.readBy.length : 0;
                const card = document.createElement('div');
                card.className = 'notice-card';
                const p = document.createElement('p');
                p.className = 'notice-text';
                p.textContent = n.text; // safe textContent
                const meta = document.createElement('div');
                meta.className = 'notice-meta';
                const dateSpan = document.createElement('span');
                dateSpan.textContent = dateStr;
                const readsSpan = document.createElement('span');
                readsSpan.textContent = `${reads} קריאות`;
                meta.appendChild(dateSpan);
                meta.appendChild(readsSpan);
                card.appendChild(p);
                card.appendChild(meta);
                list.appendChild(card);
            });
        }

        async function submitNotice() {
            const txt = document.getElementById('notice-text').value.trim();
            if (!txt) { await appDialog({ title: 'שגיאה', message: 'אנא הזן תוכן', confirmText: 'סגור' }); return; }
            await addDoc(collection(db, "groups", state.curGroupId, "notices"), { text: txt, createdAt: serverTimestamp(), readBy: [] });
            closeModals();
            showToast("הודעה פורסמה!");
            loadNotices();
        }

        // =====================================================
        // STUDENT LOGIC
        // =====================================================
        async function loadStudentMain() {
            const alerts = document.getElementById('student-active-alerts');
            const cont = document.getElementById('student-groups-container');
            const statsCont = document.getElementById('student-stats-container');
            alerts.innerHTML = '';
            cont.innerHTML = '<div class="loading-text">טוען...</div>';

            const snaps = await getDocs(query(collection(db, "groups"), where("members", "array-contains", auth.currentUser.uid)));
            cont.innerHTML = snaps.empty ? '<div class="empty-state"><span class="empty-icon"></span><p>לא רשום לקורסים כרגע</p></div>' : "";

            let totalSessions = 0, totalPresent = 0, totalLateMins = 0, totalLatesCount = 0, totalAbsences = 0;

            for (const gd of snaps.docs) {
                const [noticeSnaps, sSnaps] = await Promise.all([
                    getDocs(query(collection(db, "groups", gd.id, "notices"))),
                    getDocs(collection(db, "groups", gd.id, "sessions"))
                ]);

                noticeSnaps.forEach(nd => {
                    const n = nd.data();
                    if (!n.readBy || !n.readBy.includes(auth.currentUser.uid)) {
                        const card = document.createElement('div');
                        card.className = 'card bg-blink-warn';
                        card.style.cssText = 'margin-bottom:15px;padding:20px;border-color:var(--blue);';
                        const title = document.createElement('strong');
                        title.style.cssText = 'display:block;margin-bottom:10px;font-size:1.1rem;color:var(--blue);';
                        title.textContent = `הודעה חדשה ממדריך (${gd.data().name})`;
                        const msg = document.createElement('p');
                        msg.style.marginBottom = '15px';
                        msg.textContent = n.text; // safe
                        const approveBtn = document.createElement('button');
                        approveBtn.className = 'secondary';
                        approveBtn.textContent = 'קראתי ואישרתי';
                        approveBtn.addEventListener('click', (e) => { e.stopPropagation(); approveNotice(gd.id, nd.id, approveBtn); });
                        card.appendChild(title);
                        card.appendChild(msg);
                        card.appendChild(approveBtn);
                        alerts.appendChild(card);
                    }
                });

                sSnaps.forEach(sd => {
    const session = sd.data();
    const myAtt = session.attendance?.[auth.currentUser.uid];
    const exc = session.exceptions?.[auth.currentUser.uid];

    // 1. חישובי סטטיסטיקה - מתבצעים רק עבור מפגשים סגורים
    if (session.status === 'closed') {
        totalSessions++;
        
        if (myAtt) {
            if (['on_time', 'late', 'excused'].includes(myAtt.status)) {
                totalPresent++;
            } else {
                // status === 'absent' (set by instructor or auto-lock)
                totalAbsences++;
            }
            if (myAtt.status === 'late') { 
                totalLatesCount++; 
                if (myAtt.minutes) totalLateMins += myAtt.minutes; 
            }
        } else { 
            // אם המפגש סגור ואין נתוני נוכחות - זו היעדרות
            totalAbsences++; 
        }
    }

    // 2. הצגת כרטיס דיווח - מתבצע רק עבור מפגשים פתוחים שהמשתמש טרם דיווח בהם
    if (session.status === "open" && !myAtt) {
        const expectedTxt = session.expectedStartTime ? ` | שעת התחלה: ${session.expectedStartTime}` : "";
        const card = document.createElement('div');
        card.style.cssText = 'margin-bottom:15px;padding:20px;';
        
        const title = document.createElement('strong');
        title.style.cssText = 'display:block;margin-bottom:10px;font-size:1.1rem;';
        title.textContent = `מפגש פתוח: ${gd.data().name}`;
        
        const info = document.createElement('p');
        info.style.cssText = 'margin-bottom:10px;font-weight:bold;';
        info.textContent = `מפגש מס' ${session.sessionNumber}${expectedTxt}`;

        if (exc && exc.type === 'manual_request') {
            // Show appropriate status based on instructor's action
            const excStatus = exc.resolvedStatus; // 'pending' | 'approved' | 'denied' | undefined
            if (excStatus === 'approved') {
                card.className = 'card exc-approved-card';
                const statusBtn = document.createElement('button');
                statusBtn.disabled = true;
                statusBtn.style.cssText = 'background:var(--green);color:white;cursor:default;';
                statusBtn.textContent = 'הבקשה אושרה על ידי המדריך';
                card.appendChild(title);
                card.appendChild(info);
                card.appendChild(statusBtn);
            } else if (excStatus === 'denied') {
                card.className = 'card exc-denied-card';
                const statusBtn = document.createElement('button');
                statusBtn.disabled = true;
                statusBtn.style.cssText = 'background:var(--danger);color:white;cursor:default;';
                statusBtn.textContent = 'הבקשה נדחתה על ידי המדריך';
                card.appendChild(title);
                card.appendChild(info);
                card.appendChild(statusBtn);
            } else {
                // pending
                card.className = 'card exc-pending-card';
                const waitBtn = document.createElement('button');
                waitBtn.disabled = true;
                waitBtn.style.cssText = 'background:var(--amber);color:white;cursor:default;';
                waitBtn.textContent = '⏳ בקשה חריגה בטיפול — ממתין לאישור מדריך';
                card.appendChild(title);
                card.appendChild(info);
                card.appendChild(waitBtn);
            }
        } else {
            // בדיקה אם קיים דיווח אופליין ממתין לסנכרון
            const pendingOffline = state.offlineQueue.find(q => q.gid === gd.id && q.sid === sd.id && q.uid === auth.currentUser.uid);
            if (pendingOffline) {
                card.className = 'card bg-absent-static';
                const pendingBtn = document.createElement('button');
                pendingBtn.disabled = true;
                pendingBtn.style.cssText = 'background-color:var(--amber);color:white;cursor:default;';
                pendingBtn.textContent = 'נוכחות ממתינה לסנכרון...';
                card.appendChild(title);
                card.appendChild(info);
                card.appendChild(pendingBtn);
            } else {
                card.className = 'card session-alert-card bg-blink-warn';
                const btn = document.createElement('button');
                btn.classList.add('attend-btn');
                btn.textContent = 'דווח נוכחות';
                const iLat = session.instructorLocation?.lat;
                const iLng = session.instructorLocation?.lng;
                btn.addEventListener('click', (e) => { e.stopPropagation(); startAttendProcess(gd.id, sd.id, iLat, iLng, session.expectedStartTime, 0, e, btn, session.roundStartedAt); });
                card.appendChild(title);
                card.appendChild(info);
                card.appendChild(btn);
            }
        }
        alerts.appendChild(card);
    }
});


                const div = document.createElement('div');
                div.className = "card clickable list-item";
                const h3 = document.createElement('h3');
                h3.style.cssText = 'margin:0;font-size:1.1rem;';
                h3.textContent = gd.data().name;
                div.appendChild(h3);
                div.addEventListener('click', () => openStudentGroup(gd.id, gd.data().name));
                cont.appendChild(div);
            }

            if (totalSessions > 0) {
                const pct = Math.round((totalPresent / totalSessions) * 100);
                let color = "var(--green)", msg = "כל הכבוד! המשך כך!";
                if (pct < 50) { color = "var(--danger)"; msg = "שים לב, הנוכחות שלך נמוכה, כדי לעבור את הקורס עליך להשתפר!"; }
                else if (pct < 80) { color = "var(--amber)"; msg = "אתה בדרך הנכונה, אך השתדל לא לפספס מפגשים נוספים."; }

                const card = document.createElement('div');
                card.className = 'card';
                card.style.cssText = `border-top: 4px solid ${color}; padding: 24px;`;
                card.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
                        <div>
                            <p style="font-size:0.78rem;font-weight:700;color:var(--muted);letter-spacing:0.5px;text-transform:uppercase;margin-bottom:4px;">נוכחות כוללת</p>
                            <p style="font-family:'Syne',sans-serif;font-size:2.4rem;font-weight:800;color:${color};line-height:1;">${pct}%</p>
                            <p style="font-size:0.85rem;color:var(--muted);margin-top:2px;">${totalPresent} מתוך ${totalSessions} מפגשים</p>
                        </div>
                        <div style="width:52px;height:52px;border-radius:50%;background:${color}1a;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">${pct >= 80 ? '★' : pct >= 50 ? '📈' : '⚠️'}</div>
                    </div>
                    <div style="height:8px;background:#eef0f4;border-radius:99px;overflow:hidden;margin-bottom:18px;">
                        <div style="height:100%;width:${pct}%;background:${color};border-radius:99px;transition:width 0.8s ease;"></div>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:${totalLateMins > 0 ? '14px' : '0'};">
                        <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.3rem;font-weight:800;color:var(--green);font-family:'Syne',sans-serif;">${totalPresent}</p>
                            <p style="font-size:0.72rem;color:#15803d;font-weight:600;">נוכחויות</p>
                        </div>
                        <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.3rem;font-weight:800;color:var(--amber);font-family:'Syne',sans-serif;">${totalLatesCount}</p>
                            <p style="font-size:0.72rem;color:#b45309;font-weight:600;">איחורים</p>
                        </div>
                        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px;text-align:center;">
                            <p style="font-size:1.3rem;font-weight:800;color:var(--danger);font-family:'Syne',sans-serif;">${totalAbsences}</p>
                            <p style="font-size:0.72rem;color:#b91c1c;font-weight:600;">חיסורים</p>
                        </div>
                    </div>
                    ${totalLateMins > 0 ? `<p style="color:var(--amber);font-size:0.85rem;text-align:center;margin-bottom:14px;">סה"כ זמן איחורים: <strong>${totalLateMins} דקות</strong></p>` : ''}
                    <div style="background:${color}0f;border:1px solid ${color}30;border-radius:10px;padding:12px 16px;font-size:0.88rem;font-weight:600;color:${color};text-align:center;">${msg}</div>
                `;
                statsCont.innerHTML = '';
                statsCont.appendChild(card);
            } else {
                statsCont.innerHTML = '';
            }
        }

        async function approveNotice(gid, nid, btnEl) {
    btnEl.disabled = true;
    const originalText = btnEl.textContent;
    btnEl.textContent = "מאשר...";
    
    try {
        await updateDoc(doc(db, "groups", gid, "notices", nid), { readBy: arrayUnion(auth.currentUser.uid) });
        await loadStudentMain();
    } catch (error) {
        console.error("Error approving notice:", error);
        btnEl.disabled = false;
        btnEl.textContent = originalText;
        showToast("אירעה שגיאה באישור ההודעה", "error");
    }
}


        async function openStudentGroup(gid, name) {
            state._curStudentGroupId = gid;
            state._curStudentGroupName = name;
            document.getElementById('student-main-dashboard').classList.add('hidden');
            document.getElementById('student-group-details').classList.remove('hidden');
            safeText(document.getElementById('student-group-name-header'), name);
            const list = document.getElementById('student-history-list');
            list.innerHTML = '<div class="loading-text">טוען...</div>';
            const snaps = await getDocs(query(collection(db, "groups", gid, "sessions"), orderBy("sessionNumber", "desc")));
            list.innerHTML = snaps.empty ? '<div class="empty-state"><span class="empty-icon"></span><p>אין מפגשים עדיין</p></div>' : "";
            snaps.forEach(sd => {
                const s = sd.data();
                const att = s.attendance?.[auth.currentUser.uid];
                let t = s.status === 'open' ? 'פתוח' : 'חיסור', c = s.status === 'open' ? 'bg-blink-warn' : 'bg-red';
                if (att) {
                    if (att.status === 'on_time') { t = "נוכח"; c = "bg-green"; }
                    else if (att.status === 'late') { t = `איחור (${att.minutes || 0}דק')`; c = "bg-yellow"; }
                    else if (att.status === 'excused') { t = "באישור"; c = "bg-blue"; }
                }
                // Multi-round: show fraction if applicable
                // FIX 2: Support both new object format {status} and legacy boolean
                if (s.rounds > 1) {
                    const myRounds = s.roundAttendance?.[auth.currentUser.uid] || {};
                    const rPresent = Object.values(myRounds).filter(v =>
                        v && typeof v === 'object' ? ['on_time','late','excused'].includes(v.status) : v === true
                    ).length;
                    t += ` (${rPresent}/${s.rounds})`;
                }
                const div = document.createElement('div');
                div.className = 'list-item';
                const sessionSpan = document.createElement('span');
                sessionSpan.textContent = `מפגש ${s.sessionNumber}`;
                const statusSpan = document.createElement('span');
                statusSpan.className = `status-tag ${c}`;
                statusSpan.textContent = t;
                div.appendChild(sessionSpan);
                div.appendChild(statusSpan);
                list.appendChild(div);
            });
        }

        // =====================================================
        // ATTENDANCE PROCESS (Student)
        // =====================================================
        async function startAttendProcess(gid, sid, iLat, iLng, start, retryCount, _event, btnEl, roundStartedAt) {
            if (!btnEl || btnEl.disabled) return;

            btnEl.disabled = true;
            btnEl.textContent = 'מעבד...';

            const resetBtn = () => {
                if (btnEl) { btnEl.disabled = false; btnEl.textContent = 'דווח נוכחות'; }
            };

            try {
                // 1. Fetch session data
                const sessionDoc = await getDoc(doc(db, 'groups', gid, 'sessions', sid));
                if (!sessionDoc.exists()) { showToast('המפגש לא נמצא', 'error'); resetBtn(); return; }
                const sessionData = sessionDoc.data();

                if (sessionData.status !== 'open') { showToast('המפגש כבר סגור', 'error'); resetBtn(); return; }

                const bypassActive = !!(sessionData.gpsBypassUntil && sessionData.gpsBypassUntil > Date.now());
                if (!roundStartedAt && sessionData.roundStartedAt) roundStartedAt = sessionData.roundStartedAt;

                // 2. Access code check (if required)
                if (sessionData.accessCode) {
                    resetBtn();
                    const inp = document.getElementById('student-access-code-input');
                    if (inp) inp.value = '';
                    const modal = document.getElementById('access-code-modal');
                    modal?.classList.remove('hidden');

                    const enteredCode = await new Promise((resolve) => {
                        const submitBtn = document.getElementById('btn-submit-access-code');
                        const cancelBtn = document.getElementById('btn-cancel-access-code');
                        const cleanup = () => {
                            submitBtn?.removeEventListener('click', onSubmit);
                            cancelBtn?.removeEventListener('click', onCancel);
                        };
                        const onSubmit = () => { modal?.classList.add('hidden'); cleanup(); resolve(inp?.value.trim() || ''); };
                        const onCancel = () => { modal?.classList.add('hidden'); cleanup(); resolve(null); };
                        submitBtn?.addEventListener('click', onSubmit, { once: true });
                        cancelBtn?.addEventListener('click', onCancel, { once: true });
                    });

                    if (!enteredCode) return; // user cancelled
                    if (String(enteredCode) !== String(sessionData.accessCode)) {
                        showToast('קוד שגוי — נסה שוב', 'error');
                        return;
                    }
                    // Code OK — re-disable button for processing
                    btnEl.disabled = true;
                    btnEl.textContent = 'מעבד...';
                }

                // 3. Compute late status
                const graceMs = ((sessionData.graceMins != null ? sessionData.graceMins : (state.graceMins ?? 15))) * 60000;
                const now = new Date();
                let stat = 'on_time', lateMinutes = 0;
                const refTime = roundStartedAt ? new Date(roundStartedAt) : (() => {
                    if (!start) return null;
                    const [h, m] = start.split(':').map(Number);
                    const d = new Date(); d.setHours(h, m, 0, 0); return d;
                })();
                if (refTime && now > new Date(refTime.getTime() + graceMs)) {
                    stat = 'late';
                    lateMinutes = Math.floor((now - refTime) / 60000);
                }

                // 4. Save attendance
                const saveAttendance = async (distanceStr) => {
                    const dataToSave = { status: stat, timestamp: serverTimestamp(), distance: distanceStr };
                    if (stat === 'late') dataToSave.minutes = lateMinutes;

                    if (!navigator.onLine) {
                        queueOfflineAttendance(gid, sid, auth.currentUser.uid, { ...dataToSave, timestamp: new Date().toISOString() });
                        showToast('אופליין — נוכחות נשמרה לסנכרון אוטומטי', 'warning');
                    } else {
                        // Build update object — only include exceptions field if the student
                        // actually has an exception entry. Writing deleteField() on a key that
                        // doesn't exist causes Firestore security rules to evaluate the diff
                        // as touching the "exceptions" map, which can trigger permission-denied
                        // even when the student has no exception to clear.
                        const attendUpdate = {
                            [`attendance.${auth.currentUser.uid}`]: dataToSave
                        };
                        if (sessionData.exceptions?.[auth.currentUser.uid] !== undefined) {
                            attendUpdate[`exceptions.${auth.currentUser.uid}`] = deleteField();
                        }
                        await updateDoc(doc(db, 'groups', gid, 'sessions', sid), attendUpdate);
                        if (stat === 'on_time') showToast('כל הכבוד! הגעת בזמן!', 'success');
                        else showToast(`הפעם הגעת באיחור של ${lateMinutes} דקות ⏰, השתדל לדייק!`, 'error');
                        writeLog('attend', `רישום נוכחות: ${state.userData?.fullName} | סטטוס: ${stat} | מרחק: ${distanceStr} | מפגש ${sid} | קבוצה ${gid}`);
                    }

                    resetBtn();
                    loadStudentMain();
                    if (state._curStudentGroupId && !document.getElementById('student-group-details').classList.contains('hidden')) {
                        openStudentGroup(state._curStudentGroupId, state._curStudentGroupName);
                    }
                };

                // 5. No-GPS mode
                const noGpsMode = sessionData.noGpsMode === true || iLat == null || iLng == null || isNaN(Number(iLat)) || isNaN(Number(iLng));
                if (noGpsMode) {
                    await saveAttendance('ללא GPS');
                    return;
                }

                // 6. Get GPS location
                const getLocation = (timeoutMs) => new Promise((resolve, reject) => {
                    const timer = setTimeout(() => reject(new Error('GPS timeout')), timeoutMs);
                    navigator.geolocation.getCurrentPosition(
                        (pos) => { clearTimeout(timer); resolve(pos); },
                        (err) => { clearTimeout(timer); reject(err); },
                        { enableHighAccuracy: true, timeout: timeoutMs }
                    );
                });

                let pos;
                try {
                    pos = await getLocation(bypassActive ? 3000 : 8000);
                } catch (geoErr) {
                    if (geoErr.code === 1) { // permission denied
                        showToast('גישה למיקום נדחתה', 'error');
                        resetBtn();
                        return;
                    }
                    if (bypassActive) { await saveAttendance('GPS לא זמין'); return; }
                    // GPS failed — show retry modal
                    resetBtn();
                    document.getElementById('btn-send-exception')?.classList.toggle('hidden', retryCount === 0);
                    if (retryCount > 0) {
                        const btnExc = document.getElementById('btn-send-exception');
                        if (btnExc) btnExc.onclick = () => sendExceptionRequest(gid, sid, 'GPS לא זמין');
                    }
                    document.getElementById('btn-retry-location').onclick = (e) => {
                        closeModals();
                        startAttendProcess(gid, sid, iLat, iLng, start, 1, e, btnEl, roundStartedAt);
                    };
                    document.getElementById('location-retry-modal')?.classList.remove('hidden');
                    return;
                }

                // 7. Check distance
                const dist = haversineDistance(iLat, iLng, pos.coords.latitude, pos.coords.longitude);
                if (dist === null) { showToast('שגיאת חישוב מרחק', 'error'); resetBtn(); return; }

                const allowedRadius = (sessionData.attendanceRadius > 0) ? sessionData.attendanceRadius : 50;

                if (dist <= allowedRadius || bypassActive) {
                    await saveAttendance(String(Math.round(dist)) + 'מ\'');
                } else {
                    // Too far — show retry modal
                    resetBtn();
                    document.getElementById('btn-send-exception')?.classList.toggle('hidden', retryCount === 0);
                    if (retryCount > 0) {
                        const btnExc = document.getElementById('btn-send-exception');
                        if (btnExc) btnExc.onclick = () => sendExceptionRequest(gid, sid, Math.round(dist));
                    }
                    document.getElementById('btn-retry-location').onclick = (e) => {
                        closeModals();
                        startAttendProcess(gid, sid, iLat, iLng, start, 1, e, btnEl, roundStartedAt);
                    };
                    document.getElementById('location-retry-modal')?.classList.remove('hidden');
                }

            } catch (err) {
                console.error('startAttendProcess error:', err);
                showToast('שגיאה בתהליך הדיווח', 'error');
                resetBtn();
            }
        }

        // =====================================================
        // EXCEPTION REQUEST (Student too far from location)
        // =====================================================
        async function sendExceptionRequest(gid, sid, distCalculated) {
            const btn = document.getElementById('btn-send-exception');
            if (btn) { btn.disabled = true; btn.textContent = 'שולח...'; }
            try {
                await updateDoc(doc(db, "groups", gid, "sessions", sid), {
                    [`exceptions.${auth.currentUser.uid}`]: {
                        status: 'pending',
                        type: 'manual_request',
                        distance: distCalculated,
                        timestamp: serverTimestamp(),
                        viewed: false
                    }
                });
                closeModals();
                showToast('בקשה חריגה נשלחה למדריך', 'success');
                await loadStudentMain();
            } catch (error) {
                console.error("Error sending exception:", error);
                showToast("אירעה שגיאה בשליחת הבקשה", "error");
            } finally {
                if (btn) { btn.disabled = false; btn.textContent = 'שלח בקשה חריגה למדריך'; }
            }
        }

        // =====================================================
        // FEATURE 1: SYSTEM BROADCAST — Admin sends mandatory messages
        // Collection: systemBroadcasts/{id}
        // Fields: text, target(all/students/instructors/groupId), createdAt, 
        //         createdBy, confirmedBy: {uid: timestamp}
        // =====================================================
        async function openBroadcastCompose() {
            // Populate group selector
            const sel = document.getElementById('bc-group-id');
            sel.innerHTML = '<option value="">טוען...</option>';
            const gSnaps = await getDocs(collection(db, "groups"));
            sel.innerHTML = '';
            gSnaps.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d.id;
                opt.textContent = d.data().name;
                sel.appendChild(opt);
            });
            document.getElementById('bc-text').value = '';
            document.getElementById('bc-target').value = 'all';
            document.getElementById('bc-group-select-wrap').classList.add('hidden');
            document.getElementById('bc-students-select-wrap').classList.add('hidden');
            document.getElementById('admin-broadcast-modal').classList.remove('hidden');
        }

        async function sendBroadcast() {
            const text = document.getElementById('bc-text').value.trim();
            const target = document.getElementById('bc-target').value;
            const groupId = target === 'group' ? document.getElementById('bc-group-id').value : null;
            let targetUids = null;
            if (target === 'specific_students') {
                const checked = document.querySelectorAll('#bc-students-list input[type=checkbox]:checked');
                targetUids = Array.from(checked).map(cb => cb.value);
                if (targetUids.length === 0) {
                    await appDialog({ title: 'שגיאה', message: 'נא לבחור לפחות חניך אחד', confirmText: 'סגור' });
                    return;
                }
            }
            if (!text) { await appDialog({ title: 'שגיאה', message: 'נא להזין תוכן הודעה', confirmText: 'סגור' }); return; }
            const btn = document.getElementById('btn-send-broadcast');
            btn.disabled = true; btn.textContent = 'שולח...';
            try {
                await addDoc(collection(db, "systemBroadcasts"), {
                    text, target, groupId: groupId || null,
                    targetUids: targetUids || null,
                    createdAt: serverTimestamp(),
                    createdBy: auth.currentUser.uid,
                    createdByName: state.userData.fullName,
                    confirmedBy: {}
                });
                // Reset student list cache
                document.getElementById('bc-students-list').innerHTML = '';
                closeModals();
                showToast('ההודעה נשלחה בהצלחה!', 'success');
                loadAdminBroadcasts();
            } catch (err) {
                console.error('sendBroadcast error:', err);
                showToast('שגיאה בשליחת ההודעה — נסה שוב', 'error');
            } finally {
                btn.disabled = false; btn.textContent = 'שלח הודעה לכולם';
            }
        }

        async function loadAdminBroadcasts() {
            const list = document.getElementById('admin-broadcasts-list');
            list.innerHTML = '<div class="loading-text">טוען...</div>';
            const snaps = await getDocs(query(collection(db, "systemBroadcasts"), orderBy("createdAt", "desc")));
            if (snaps.empty) { list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>לא נשלחו הודעות מערכת עדיין</p></div>'; return; }
            list.innerHTML = '';
            // Fetch all relevant users
            const usersSnap = await getDocs(collection(db, "users"));
            const usersMap = {}, allUserIds = [];
            usersSnap.forEach(d => { usersMap[d.id] = d.data(); allUserIds.push(d.id); });

            snaps.forEach(d => {
                const b = d.data();
                const dateStr = b.createdAt ? b.createdAt.toDate().toLocaleString('he-IL') : '';
                const targetLabel = b.target === 'all' ? 'כולם' : b.target === 'students' ? 'תלמידים' : b.target === 'instructors' ? 'מדריכים' : b.target === 'group' ? 'קבוצה' : b.target === 'specific_students' ? 'חניכים נבחרים' : 'קבוצה';
                const confirmed = Object.keys(b.confirmedBy || {});
                const confirmedSet = new Set(confirmed);

                // Determine expected recipients
                let expectedUids = [];
                if (b.target === 'all') expectedUids = allUserIds;
                else if (b.target === 'students') expectedUids = allUserIds.filter(uid => usersMap[uid]?.role === 'student');
                else if (b.target === 'instructors') expectedUids = allUserIds.filter(uid => usersMap[uid]?.role === 'instructor');
                else if (b.target === 'specific_students') expectedUids = b.targetUids || [];
                // For group target we can't easily determine without querying — just show confirmed/not

                const confirmedNames = confirmed.map(uid => usersMap[uid]?.fullName || uid);
                const notConfirmedNames = expectedUids.filter(uid => !confirmedSet.has(uid) && usersMap[uid]).map(uid => usersMap[uid]?.fullName);

                // Fix 4: fetch instructor replies from userMessages
                const card = document.createElement('div');
                card.className = 'card';
                card.style.cssText = 'padding:16px;margin-bottom:12px;border-right:4px solid var(--red);';
                card.innerHTML = `
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                        <span style="font-weight:700;color:var(--ink);line-height:1.5;">${safeHTML(b.text)}</span>
                        <span class="status-tag bg-blue" style="font-size:0.72rem;flex-shrink:0;margin-right:8px;">${safeHTML(targetLabel)}</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--muted);margin-bottom:10px;">נשלח ע"י: ${safeHTML(b.createdByName||'')} | ${safeHTML(dateStr)}</p>
                    <details style="font-size:0.82rem;margin-bottom:6px;">
                        <summary style="cursor:pointer;color:var(--green);font-weight:700;">אישרו (${confirmedNames.length})</summary>
                        <p style="margin-top:6px;color:var(--ink-3);line-height:1.8;padding:8px;background:var(--green-soft);border-radius:6px;">${confirmedNames.length ? safeHTML(confirmedNames.join(' | ')) : 'אף אחד עדיין'}</p>
                    </details>
                    ${expectedUids.length ? `<details style="font-size:0.82rem;">
                        <summary style="cursor:pointer;color:var(--danger);font-weight:700;">טרם אישרו (${notConfirmedNames.length})</summary>
                        <p style="margin-top:6px;color:var(--ink-3);line-height:1.8;padding:8px;background:var(--red-soft);border-radius:6px;">${notConfirmedNames.length ? safeHTML(notConfirmedNames.join(' | ')) : 'כולם אישרו '}</p>
                    </details>` : ''}
                `;
                list.appendChild(card);
            });

            // Fix 4: also show instructor replies from userMessages in a separate section
            const replyMsgs = await getDocs(query(collection(db, "userMessages"), where("toUid", "==", "support"), orderBy("createdAt", "desc"), limit(20)));
            if (!replyMsgs.empty) {
                const replySection = document.createElement('div');
                replySection.style.cssText = 'margin-top:20px;';
                replySection.innerHTML = '<h3 style="margin-bottom:12px;font-size:1rem;">תגובות שהתקבלו מפניות</h3>';
                replyMsgs.forEach(rd => {
                    const rm = rd.data();
                    if (!rm.reply) return;
                    const rCard = document.createElement('div');
                    rCard.className = 'msg-card';
                    rCard.innerHTML = `
                        <div class="msg-meta"><strong>${safeHTML(rm.fromName)}</strong><span>${rm.repliedAt ? rm.repliedAt.toDate().toLocaleString('he-IL') : ''}</span></div>
                        <div class="msg-body">${safeHTML(rm.text)}</div>
                        <div class="msg-reply-box">תגובה: ${safeHTML(rm.reply)}</div>
                    `;
                    replySection.appendChild(rCard);
                });
                list.appendChild(replySection);
            }
        }

        // Check + show pending broadcast for current user on login
        async function checkPendingBroadcasts() {
            if (!auth.currentUser || !state.userData) return;
            const uid = auth.currentUser.uid;
            const role = state.userData.role;
            // Query broadcasts that target this user and haven't been confirmed
            const allSnaps = await getDocs(query(collection(db, "systemBroadcasts"), orderBy("createdAt", "asc")));
            let pending = null;
            for (const d of allSnaps.docs) {
                const b = d.data();
                const confirmed = b.confirmedBy || {};
                if (confirmed[uid]) continue; // already confirmed
                // Fix 2: Don't show broadcast to users who registered AFTER it was sent
                const userCreatedAt = state.userData?.createdAt;
                const broadcastCreatedAt = b.createdAt;
                if (userCreatedAt && broadcastCreatedAt) {
                    const userTs = userCreatedAt.toMillis ? userCreatedAt.toMillis() : (userCreatedAt.seconds * 1000);
                    const bcTs = broadcastCreatedAt.toMillis ? broadcastCreatedAt.toMillis() : (broadcastCreatedAt.seconds * 1000);
                    if (userTs > bcTs) continue; // user registered after broadcast was sent
                }
                // Check targeting
                const matches = b.target === 'all'
                    || (b.target === 'students' && role === 'student')
                    || (b.target === 'instructors' && role === 'instructor')
                    || (b.target === 'group' && state.userGroupIds?.includes(b.groupId))
                    || (b.target === 'specific_students' && b.targetUids?.includes(uid));
                if (matches) { pending = { id: d.id, ...b }; break; } // show oldest unconfirmed first
            }
            if (!pending) return;
            state.pendingBroadcastId = pending.id;
            document.getElementById('broadcast-modal-title').textContent = 'הודעת מערכת חשובה';
            document.getElementById('broadcast-modal-body').textContent = pending.text;
            document.getElementById('broadcast-modal-overlay').classList.remove('hidden');
        }

        async function confirmBroadcast() {
            if (!state.pendingBroadcastId) return;
            const btn = document.getElementById('broadcast-confirm-btn');
            btn.disabled = true; btn.textContent = 'מאשר...';
            await updateDoc(doc(db, "systemBroadcasts", state.pendingBroadcastId), {
                [`confirmedBy.${auth.currentUser.uid}`]: serverTimestamp()
            });
            document.getElementById('broadcast-modal-overlay').classList.add('hidden');
            state.pendingBroadcastId = null;
            btn.disabled = false; btn.textContent = 'קראתי ומאשר';
            // Check if there are more pending broadcasts
            await checkPendingBroadcasts();
        }

        // =====================================================
        // FEATURE 3: ADMIN EDIT LOG
        // Collection: systemLog/{id} — written on every attendance action
        // =====================================================
        async function writeLog(action, details) {
            try {
                await addDoc(collection(db, "systemLog"), {
                    action, details,
                    actorUid: auth.currentUser?.uid || 'system',
                    actorName: state.userData?.fullName || 'system',
                    createdAt: serverTimestamp()
                });
            } catch(e) { console.warn('Log write failed:', e); }
        }

        async function loadAdminLog() {
            const list = document.getElementById('admin-log-list');
            const filterType = document.getElementById('log-filter-type').value;
            list.innerHTML = '<div class="loading-text">טוען לוג...</div>';
            let q = query(collection(db, "systemLog"), orderBy("createdAt", "desc"), limit(200));
            if (filterType !== 'all') {
                q = query(collection(db, "systemLog"), where("action", "==", filterType), orderBy("createdAt", "desc"), limit(200));
            }
            const snaps = await getDocs(q);
            if (snaps.empty) {
                list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין רשומות לוג</p></div>';
                return;
            }

            // ── סטטיסטיקות מהירות ──────────────────────────────────
            const counts = { attend: 0, edit: 0, delete: 0, admin: 0, session: 0, user: 0 };
            snaps.forEach(d => {
                const a = d.data().action;
                if (counts[a] !== undefined) counts[a]++;
            });

            const LOG_META = {
                attend:  { icon: '✓', label: 'רישום נוכחות',   badgeClass: 'log-badge-attend',  avatarBg: '#d1fae5', avatarColor: '#059669' },
                edit:    { icon: '✎', label: 'עריכה',           badgeClass: 'log-badge-edit',    avatarBg: '#dbeafe', avatarColor: '#2563eb' },
                delete:  { icon: '✕', label: 'מחיקה',          badgeClass: 'log-badge-delete',  avatarBg: '#fee2e2', avatarColor: '#dc2626' },
                admin:   { icon: '⚙', label: 'הגדרות מערכת',   badgeClass: 'log-badge-admin',   avatarBg: '#fef3c7', avatarColor: '#d97706' },
                session: { icon: '▣', label: 'ניהול מפגש',      badgeClass: 'log-badge-session', avatarBg: '#ede9fe', avatarColor: '#7c3aed' },
                user:    { icon: '◉', label: 'ניהול משתמש',     badgeClass: 'log-badge-user',    avatarBg: '#cffafe', avatarColor: '#0891b2' },
            };

            list.innerHTML = '';

            // ── סרגל סטטיסטיקות ──────────────────────────────────
            const statsBar = document.createElement('div');
            statsBar.className = 'log-stats-bar';
            statsBar.innerHTML = `
                <span style="font-size:0.8rem;font-weight:700;color:var(--muted);align-self:center;">סה"כ ${snaps.size} פעולות:</span>
                ${counts.attend  > 0 ? `<span class="log-stat-chip">${counts.attend} נוכחות</span>` : ''}
                ${counts.edit    > 0 ? `<span class="log-stat-chip">${counts.edit} עריכות</span>` : ''}
                ${counts.delete  > 0 ? `<span class="log-stat-chip">${counts.delete} מחיקות</span>` : ''}
                ${counts.session > 0 ? `<span class="log-stat-chip">${counts.session} מפגשים</span>` : ''}
                ${counts.user    > 0 ? `<span class="log-stat-chip">${counts.user} משתמשים</span>` : ''}
                ${counts.admin   > 0 ? `<span class="log-stat-chip">${counts.admin} הגדרות</span>` : ''}
            `;
            list.appendChild(statsBar);

            // ── רשומות לוג ──────────────────────────────────────
            let lastDateLabel = '';
            snaps.forEach(d => {
                const entry = d.data();
                const meta = LOG_META[entry.action] || { icon: '◈', label: entry.action, badgeClass: 'log-badge-edit', avatarBg: '#f3f4f6', avatarColor: '#6b7280' };
                const date = entry.createdAt ? entry.createdAt.toDate() : null;
                const dateStr = date ? date.toLocaleString('he-IL', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
                const dayLabel = date ? date.toLocaleDateString('he-IL', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) : '';

                // ── מפריד יום ───────────────────────────────────
                if (dayLabel && dayLabel !== lastDateLabel) {
                    lastDateLabel = dayLabel;
                    const sep = document.createElement('div');
                    sep.style.cssText = 'display:flex;align-items:center;gap:10px;padding:10px 16px 4px;';
                    sep.innerHTML = `
                        <span style="flex:1;height:1px;background:var(--border);"></span>
                        <span style="font-size:0.75rem;font-weight:700;color:var(--muted);white-space:nowrap;">${safeHTML(dayLabel)}</span>
                        <span style="flex:1;height:1px;background:var(--border);"></span>
                    `;
                    list.appendChild(sep);
                }

                // ── אות אווטאר ───────────────────────────────────
                const initials = (entry.actorName || '?').trim().charAt(0).toUpperCase();

                const div = document.createElement('div');
                div.className = `log-entry log-${entry.action}`;
                div.innerHTML = `
                    <div class="log-header">
                        <div class="log-actor">
                            <span style="width:32px;height:32px;border-radius:50%;background:${meta.avatarBg};color:${meta.avatarColor};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;border:1.5px solid ${meta.avatarColor}22;">${safeHTML(initials)}</span>
                            <span>${safeHTML(entry.actorName || 'מערכת')}</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                            <span class="log-badge ${meta.badgeClass}">${meta.icon} ${meta.label}</span>
                            <span class="log-time">${safeHTML(dateStr)}</span>
                        </div>
                    </div>
                    <div class="log-details">${safeHTML(entry.details || '—')}</div>
                `;
                list.appendChild(div);
            });
        }


        // =====================================================
        // CONTACT / MESSAGING SYSTEM
        // Collection: userMessages/{id}
        // =====================================================

        async function openContactCompose() {
            const role = state.userData?.role;
            const recip = document.getElementById('contact-recipient');
            document.getElementById('contact-text').value = '';
            document.getElementById('contact-compose-modal').classList.remove('hidden');
            try {
                if (role === 'instructor' || role === 'admin') {
                    recip.innerHTML = '<option value="support">תמיכה</option>';
                    document.getElementById('contact-instructor-select-wrap').classList.add('hidden');
                } else {
                    // Students: populate instructors from their groups
                    recip.innerHTML = '<option value="instructor">המדריך שלי</option><option value="support">תמיכה</option>';
                    const instrSel = document.getElementById('contact-instructor-id');
                    instrSel.innerHTML = '<option value="">טוען מדריכים...</option>';

                    const gSnaps = await getDocs(query(collection(db, "groups"), where("members", "array-contains", auth.currentUser.uid)));
                    instrSel.innerHTML = '';

                    const seen = new Set();
                    const instructorFetches = [];

                    for (const gd of gSnaps.docs) {
                        const g = gd.data();
                        const groupName = g.name;
                        const iids = [g.instructorId, ...(g.coInstructors || [])].filter(Boolean);
                        for (const iid of iids) {
                            if (seen.has(iid)) continue;
                            seen.add(iid);
                            instructorFetches.push({ iid, groupName });
                        }
                    }

                    // Fetch all instructor names in parallel — /users is readable by all
                    const userDocs = await Promise.all(
                        instructorFetches.map(({ iid }) => getDoc(doc(db, "users", iid)).catch(() => null))
                    );

                    instructorFetches.forEach(({ iid, groupName }, i) => {
                        const udata = userDocs[i]?.data();
                        const instructorName = udata?.fullName || 'מדריך';
                        const opt = document.createElement('option');
                        opt.value = iid;
                        opt.dataset.name = instructorName;
                        opt.textContent = `${instructorName} — ${groupName}`;
                        instrSel.appendChild(opt);
                    });

                    if (instrSel.options.length === 0) {
                        instrSel.innerHTML = '<option value="">לא נמצאו מדריכים</option>';
                    }
                    document.getElementById('contact-instructor-select-wrap').classList.remove('hidden');
                }
            } catch (err) {
                console.warn('openContactCompose error:', err);
                showToast('שגיאה בטעינת הטופס', 'error');
                recip.innerHTML = '<option value="support">תמיכה</option>';
                document.getElementById('contact-instructor-select-wrap').classList.add('hidden');
            }
        }

        async function sendContactMessage() {
            const text = document.getElementById('contact-text').value.trim();
            const recipType = document.getElementById('contact-recipient').value;
            if (!text) { await appDialog({ title: 'שגיאה', message: 'נא לכתוב תוכן הודעה', confirmText: 'סגור' }); return; }

            const btn = document.getElementById('btn-send-contact');
            btn.disabled = true; btn.textContent = 'שולח...';

            let toUid = null, toName = '';

            if (recipType === 'instructor') {
                toUid = document.getElementById('contact-instructor-id').value;
                if (!toUid) { btn.disabled=false; btn.textContent='שלח הודעה'; await appDialog({title:'שגיאה',message:'בחר מדריך',confirmText:'סגור'}); return; }
                const instrSel = document.getElementById('contact-instructor-id');
                const selectedOpt = instrSel.options[instrSel.selectedIndex];
                toName = selectedOpt?.dataset?.name || selectedOpt?.text || 'מדריך';
            } else {
                // 'support' — goes to admin
                toUid = 'support';
                toName = 'תמיכה';
            }

            try {
                await addDoc(collection(db, "userMessages"), {
                    fromUid: auth.currentUser.uid,
                    fromName: state.userData.fullName || 'משתמש',
                    fromRole: state.userData?.role || 'student',
                    toUid: toUid,
                    toName: toName,
                    text: text,
                    createdAt: serverTimestamp(),
                    readByRecipient: false,
                    confirmedByUser: false
                });
                closeModals();
                showToast('ההודעה נשלחה בהצלחה!', 'success');
            } catch (error) {
                console.error("Error sending message:", error);
                showToast("שגיאה בשליחת ההודעה", "error");
            } finally {
                btn.disabled = false;
                btn.textContent = 'שלח הודעה';
            }
        } 


        // ── INSTRUCTOR INBOX ──────────────────────────────────────────
        async function loadInstructorInbox() {
            const list = document.getElementById('instructor-inbox-list');
            if (!list) return;
            list.innerHTML = '<div class="loading-text">טוען...</div>';

            // Also prepare home widget
            const homeList = document.getElementById('instructor-inbox-home-list');
            const homePill = document.getElementById('inbox-home-unread-pill');

            // Fetch instructor's groups so we can map sender UIDs → group names
            const [msgs, q1, q2] = await Promise.all([
                getDocs(query(
                    collection(db, "userMessages"),
                    where("toUid", "==", auth.currentUser.uid),
                    orderBy("createdAt", "desc")
                )),
                getDocs(query(collection(db, "groups"), where("instructorId", "==", auth.currentUser.uid))),
                getDocs(query(collection(db, "groups"), where("coInstructors", "array-contains", auth.currentUser.uid)))
            ]);

            // Build uid → group names map
            const groupsMap = new Map();
            [...q1.docs, ...q2.docs].forEach(d => {
                const g = d.data();
                const memberUids = g.members || [];
                memberUids.forEach(uid => {
                    if (!groupsMap.has(uid)) groupsMap.set(uid, []);
                    groupsMap.get(uid).push(g.name);
                });
            });
            function getGroupTag(fromUid) {
                const groups = groupsMap.get(fromUid);
                if (!groups || groups.length === 0) return '';
                return groups.slice(0, 2).join(' · ');
            }

            const unread = msgs.docs.filter(d => !d.data().readByRecipient).length;

            // Update badges
            const badge = document.getElementById('inbox-badge');
            if (badge) {
                if (unread > 0) { badge.textContent = unread; badge.classList.remove('hidden'); }
                else { badge.classList.add('hidden'); }
            }
            updateContactBadge(unread);
            // Update bottom nav badge
            const bnBadge = document.getElementById('bn-contact-badge');
            if (bnBadge) {
                if (unread > 0) { bnBadge.textContent = unread; bnBadge.classList.remove('hidden'); }
                else { bnBadge.classList.add('hidden'); }
            }
            // Update home pill
            if (homePill) {
                if (unread > 0) { homePill.textContent = `${unread} חדשות`; homePill.classList.remove('hidden'); }
                else { homePill.classList.add('hidden'); }
            }
            // Update modal pill
            const modalPill = document.getElementById('inbox-modal-unread-pill');
            if (modalPill) {
                if (unread > 0) { modalPill.textContent = `${unread} חדשות`; modalPill.classList.remove('hidden'); }
                else { modalPill.classList.add('hidden'); }
            }

            // ── HOME WIDGET (max 4 messages preview) ──────────────────
            if (homeList) {
                homeList.innerHTML = '';
                if (msgs.empty) {
                    homeList.innerHTML = '<div class="inbox-empty-state"><span class="empty-icon"></span>אין הודעות עדיין</div>';
                } else {
                    const preview = msgs.docs.slice(0, 4);
                    preview.forEach(d => {
                        const m = d.data();
                        const isUnread = !m.readByRecipient;
                        const hasReply = !!m.reply;
                        const initial = (m.fromName || '?').trim().charAt(0).toUpperCase();
                        const groupTag = getGroupTag(m.fromUid);
                        const dateStr = m.createdAt ? m.createdAt.toDate().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit' }) + ' ' + m.createdAt.toDate().toLocaleDateString('he-IL', { day: '2-digit', month: '2-digit' }) : '';
                        const item = document.createElement('div');
                        item.className = `inbox-msg-item${isUnread ? ' is-unread' : ''}`;
                        item.innerHTML = `
                            <div class="inbox-msg-avatar${isUnread ? ' unread-avatar' : ''}">${safeHTML(initial)}</div>
                            <div class="inbox-msg-content">
                                <div class="inbox-msg-top">
                                    <span class="inbox-msg-sender">${safeHTML(m.fromName || 'לא ידוע')}</span>
                                    <span class="inbox-msg-time">${safeHTML(dateStr)}</span>
                                </div>
                                ${groupTag ? `<div class="inbox-msg-group-tag">${safeHTML(groupTag)}</div>` : ''}
                                <div class="inbox-msg-text${hasReply ? ' has-reply' : ''}">${hasReply ? '✓ ענית על הודעה זו' : safeHTML(m.text)}</div>
                            </div>
                        `;
                        homeList.appendChild(item);
                    });
                    if (msgs.docs.length > 4) {
                        const more = document.createElement('div');
                        more.style.cssText = 'text-align:center;padding:10px;font-size:0.8rem;color:var(--muted);font-weight:600;border-top:1px solid var(--border-light);';
                        more.textContent = `ועוד ${msgs.docs.length - 4} הודעות נוספות`;
                        homeList.appendChild(more);
                    }
                }
            }

            // ── FULL INBOX MODAL ──────────────────────────────────────
            if (msgs.empty) { list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין הודעות עדיין</p></div>'; return; }
            list.innerHTML = '';
            msgs.forEach(d => {
                const m = d.data();
                const dateStr = m.createdAt ? m.createdAt.toDate().toLocaleString('he-IL') : '';
                const groupTag = getGroupTag(m.fromUid);
                const div = document.createElement('div');
                div.className = `msg-card${!m.readByRecipient ? ' msg-unread' : ''}${m.reply ? ' msg-has-reply' : ''}`;
                div.innerHTML = `
                    <div class="msg-meta">
                        <span><strong>${safeHTML(m.fromName)}</strong></span>
                        ${groupTag ? `<span class="inbox-msg-group-tag" style="font-size:0.7rem;">${safeHTML(groupTag)}</span>` : ''}
                        <span>${safeHTML(dateStr)}</span>
                        ${!m.readByRecipient ? '<span style="color:var(--red);font-weight:700;">● חדשה</span>' : ''}
                    </div>
                    <div class="msg-body">${safeHTML(m.text)}</div>
                    ${m.reply ? `<div class="msg-reply-box">תגובתך: ${safeHTML(m.reply)}</div>` : ''}
                `;
                // Action buttons
                const btnRow = document.createElement('div');
                btnRow.style.cssText = 'display:flex;gap:8px;margin-top:10px;';
                if (!m.readByRecipient) {
                    const markBtn = document.createElement('button');
                    markBtn.className = 'outline action-btn-small';
                    markBtn.textContent = 'סמן כנקרא';
                    markBtn.addEventListener('click', () => markMsgRead(d.id, div, markBtn));
                    btnRow.appendChild(markBtn);
                }
                const replyBtn = document.createElement('button');
                replyBtn.className = 'secondary action-btn-small';
                replyBtn.textContent = m.reply ? 'ערוך תגובה' : 'השב';
                replyBtn.addEventListener('click', () => openReplyModal(d.id, m));
                btnRow.appendChild(replyBtn);
                div.appendChild(btnRow);
                list.appendChild(div);
            });
        }

        async function markMsgRead(msgId, divEl, btn) {
            btn.disabled = true;
            await updateDoc(doc(db, "userMessages", msgId), { readByRecipient: true });
            divEl.classList.remove('msg-unread');
            btn.remove();
            showToast('סומן כנקרא', 'success');
            loadInstructorInbox(); // refresh badge
        }

        function openReplyModal(msgId, m) {
            document.getElementById('reply-msg-id').value = msgId;
            document.getElementById('reply-modal-title').textContent = `השב ל-${m.fromName}`;
            document.getElementById('reply-original-msg').textContent = m.text;
            document.getElementById('reply-text').value = m.reply || '';
            document.getElementById('contact-reply-modal').classList.remove('hidden');
        }

        async function sendContactReply() {
            const msgId = document.getElementById('reply-msg-id').value;
            const replyText = document.getElementById('reply-text').value.trim();
            if (!replyText) { await appDialog({ title: 'שגיאה', message: 'נא לכתוב תגובה', confirmText: 'סגור' }); return; }
            const btn = document.getElementById('btn-send-reply');
            btn.disabled = true; btn.textContent = 'שולח...';
            await updateDoc(doc(db, "userMessages", msgId), {
                reply: replyText,
                repliedAt: serverTimestamp(),
                readByRecipient: true,
                confirmedByUser: false
            });
            btn.disabled = false; btn.textContent = 'שלח תגובה';
            // keep inbox modal open, just refresh the list
            document.getElementById('contact-reply-modal').classList.add('hidden');
            showToast('התגובה נשלחה!', 'success');
            loadInstructorInbox();
        }

        // ── ADMIN MESSAGES VIEW ────────────────────────────────────────
        async function loadAdminMessages() {
            const list = document.getElementById('admin-messages-list');
            list.innerHTML = '<div class="loading-text">טוען הודעות...</div>';
            const msgs = await getDocs(query(
                collection(db, "userMessages"),
                where("toUid", "in", ['support', auth.currentUser.uid]),
                orderBy("createdAt", "desc")
            ));
            if (msgs.empty) { list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין הודעות עדיין</p></div>'; return; }
            list.innerHTML = '';
            msgs.forEach(d => {
                const m = d.data();
                const dateStr = m.createdAt ? m.createdAt.toDate().toLocaleString('he-IL') : '';
                const div = document.createElement('div');
                div.className = `msg-card${!m.readByRecipient ? ' msg-unread' : ''}${m.reply ? ' msg-has-reply' : ''}`;
                const adminNote = m.adminNote ? `<span style="font-size:0.75rem;color:var(--blue);display:block;margin-bottom:4px;">${safeHTML(m.adminNote)}</span>` : '';
                div.innerHTML = `
                    <div class="msg-meta">
                        <span><strong>${safeHTML(m.fromName)}</strong> (${safeHTML(m.fromRole==='student'?'תלמיד':m.fromRole==='instructor'?'מדריך':m.fromRole==='frozen'?'קפוא':'מנהל')})</span>
                        <span>${safeHTML(dateStr)}</span>
                        ${!m.readByRecipient ? '<span style="color:var(--red);font-weight:700;">● חדשה</span>' : ''}
                    </div>
                    ${adminNote}
                    <div class="msg-body">${safeHTML(m.text)}</div>
                    ${m.reply ? `<div class="msg-reply-box">תגובה שנשלחה: ${safeHTML(m.reply)}</div>` : ''}
                `;
                const btnRow = document.createElement('div');
                btnRow.style.cssText = 'display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;';
                if (!m.readByRecipient) {
                    const markBtn = document.createElement('button');
                    markBtn.className = 'outline action-btn-small';
                    markBtn.textContent = 'סמן כנקרא';
                    markBtn.addEventListener('click', async () => {
                        markBtn.disabled = true;
                        await updateDoc(doc(db, "userMessages", d.id), { readByRecipient: true });
                        div.classList.remove('msg-unread');
                        markBtn.remove();
                        showToast('סומן כנקרא', 'success');
                    });
                    btnRow.appendChild(markBtn);
                }
                if (!m.adminNote) { // Don't allow replying to copies
                    const replyBtn = document.createElement('button');
                    replyBtn.className = 'secondary action-btn-small';
                    replyBtn.textContent = m.reply ? 'ערוך תגובה' : 'השב';
                    replyBtn.addEventListener('click', () => openReplyModal(d.id, m));
                    btnRow.appendChild(replyBtn);
                }
                div.appendChild(btnRow);
                list.appendChild(div);
            });
        }

        // ── CHECK PENDING REPLIES (student/instructor sees reply popup) ─
        async function checkPendingReplies() {
            if (!auth.currentUser) return;
            const msgs = await getDocs(query(
                collection(db, "userMessages"),
                where("fromUid", "==", auth.currentUser.uid),
                where("confirmedByUser", "==", false)
            ));
            for (const d of msgs.docs) {
                const m = d.data();
                if (m.reply && !m.confirmedByUser) {
                    state.pendingReplyMsgId = d.id;
                    const fromLabel = m.toUid === 'admin' ? 'מנהל המערכת' : (m.toName || 'המדריך');
                    document.getElementById('reply-popup-from').textContent = `תגובה מ-${fromLabel}:`;
                    document.getElementById('reply-popup-text').textContent = m.reply;
                    document.getElementById('contact-reply-popup-overlay').classList.remove('hidden');
                    break; // show one at a time
                }
            }
        }

        async function confirmReplyPopup() {
            if (!state.pendingReplyMsgId) return;
            const btn = document.getElementById('btn-confirm-reply-popup');
            btn.disabled = true;
            await updateDoc(doc(db, "userMessages", state.pendingReplyMsgId), { confirmedByUser: true });
            document.getElementById('contact-reply-popup-overlay').classList.add('hidden');
            state.pendingReplyMsgId = null;
            btn.disabled = false;
            // Check if there are more unread replies
            await checkPendingReplies();
        }

        function updateContactBadge(count) {
            const btn = document.getElementById('nav-contact-btn');
            if (!btn) return;
            const existing = btn.querySelector('.menu-badge');
            if (existing) existing.remove();
            if (count > 0) {
                const badge = document.createElement('span');
                badge.className = 'menu-badge';
                badge.textContent = count;
                btn.prepend(badge);
            }
        }


        // =====================================================
        // EDIT SESSION (post-open)
        // =====================================================
        function openEditSessionModal() {
            if (!state.liveSessionData) return;
            const s = state.liveSessionData;
            document.getElementById('es-session-start').value = s.expectedStartTime || '';
            document.getElementById('es-session-end').value = s.expectedEndTime || '';
            const rad = s.attendanceRadius || 50;
            document.getElementById('es-session-radius').value = rad;
            document.querySelectorAll('.es-radius-preset').forEach(b => {
                b.classList.toggle('active-preset', Number(b.dataset.val) === rad);
            });
            const loc = s.instructorLocation;
            document.getElementById('es-location-status').textContent = loc
                ? `מיקום נוכחי: ${loc.lat.toFixed(5)}, ${loc.lng.toFixed(5)}`
                : 'אין מיקום מוגדר למפגש זה';
            // Show current access code
            const codeDisplay = document.getElementById('es-current-code-display');
            if (codeDisplay) {
                codeDisplay.textContent = s.accessCode ? s.accessCode : 'ללא קוד';
                codeDisplay.style.color = s.accessCode ? 'var(--red)' : 'var(--muted)';
            }
            const esNewCode = document.getElementById('es-new-code');
            if (esNewCode) esNewCode.value = '';
            // Pre-fill grace minutes from session (or instructor's current setting)
            const graceMinsInput = document.getElementById('es-grace-mins');
            if (graceMinsInput) graceMinsInput.value = (s.graceMins != null) ? s.graceMins : (state.graceMins ?? 15);
            document.getElementById('edit-session-modal').classList.remove('hidden');
        }

        async function saveSessionEdit() {
            const btn = document.getElementById('btn-save-session-edit');
            btn.disabled = true; btn.textContent = 'שומר...';
            const newStart = document.getElementById('es-session-start').value;
            const newEnd = document.getElementById('es-session-end').value;
            const newRadius = Math.max(10, Math.min(2000, Number(document.getElementById('es-session-radius').value) || 50));
            const newGraceMins = parseInt(document.getElementById('es-grace-mins').value);
            if (!newStart) {
                await appDialog({ title: 'שגיאה', message: 'שעת התחלה היא שדה חובה', confirmText: 'סגור' });
                btn.disabled = false; btn.textContent = 'שמור שינויים';
                return;
            }
            const sessionEditData = {
                expectedStartTime: newStart,
                expectedEndTime: newEnd || '',
                attendanceRadius: newRadius
            };
            if (!isNaN(newGraceMins) && newGraceMins >= 0 && newGraceMins <= 60) {
                sessionEditData.graceMins = newGraceMins;
            }
            try {
                await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), sessionEditData);
                closeModals();
                showToast('פרטי המפגש עודכנו', 'success');
                writeLog('edit', `עריכת פרטי מפגש ${state.liveSessionNumber}: שעה ${newStart}, רדיוס ${newRadius}מ', חסד ${!isNaN(newGraceMins) ? newGraceMins : '—'} דק'`);
            } catch (err) {
                console.error('saveSessionEdit error:', err);
                showToast('שגיאה בשמירת השינויים — נסה שוב', 'error');
            } finally {
                btn.disabled = false; btn.textContent = 'שמור שינויים';
            }
        }

        async function resampleSessionLocation() {
            const btn = document.getElementById('btn-resample-location');
            const status = document.getElementById('es-location-status');
            btn.disabled = true; btn.textContent = 'דוגם...';
            status.textContent = 'מחפש מיקום GPS...';
            navigator.geolocation.getCurrentPosition(
                async (pos) => {
                    await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), {
                        instructorLocation: { lat: pos.coords.latitude, lng: pos.coords.longitude },
                        noGpsMode: false
                    });
                    status.textContent = `מיקום חדש נשמר: ${pos.coords.latitude.toFixed(5)}, ${pos.coords.longitude.toFixed(5)}`;
                    btn.disabled = false; btn.textContent = 'דגום מיקום מחדש';
                    showToast('מיקום חדש נדגם ונשמר', 'success');
                },
                (err) => {
                    btn.disabled = false; btn.textContent = 'דגום מיקום מחדש';
                    const msg = err.code === 1 ? 'הרשאת מיקום נדחתה' : 'שגיאת GPS — נסה שוב';
                    status.textContent = msg;
                    showToast(msg, 'error');
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }

        // =====================================================
        // PWA INSTALL
        // =====================================================
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            document.getElementById('fab-install').classList.remove('hidden');
        });

        // OFFLINE/ONLINE events — notify user and sync queue on reconnect
        window.addEventListener('offline', () => {
            showToast('אין חיבור לאינטרנט — רישום נוכחות יישמר ויסונכרן אוטומטית כשהחיבור יחזור', 'error');
        });
        window.addEventListener('online', () => {
            showToast('החיבור לאינטרנט חזר — מסנכרן רישומים ממתינים...', 'success');
            syncOfflineQueue();
        });
        // On load, if there are queued items from a previous session, try to sync now
        if (state.offlineQueue.length > 0) {
            showToast(`נמצאו ${state.offlineQueue.length} רישומי נוכחות ממתינים לסנכרון...`, 'warning');
            setTimeout(syncOfflineQueue, 3000); // wait for Firebase to initialize
        }

        document.getElementById('fab-install').addEventListener('click', async () => {
            if (deferredPrompt) {
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                if (outcome === 'accepted') document.getElementById('fab-install').classList.add('hidden');
                deferredPrompt = null;
            } else {
                const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
                if (isIOS) document.getElementById('ios-install-modal').classList.remove('hidden');
            }
        });
        
            // ── ACCESS CODE: generate random code (new session modal) ─────────
        document.getElementById('btn-gen-code').addEventListener('click', () => {
            document.getElementById('ns-access-code').value = Math.floor(1000 + Math.random() * 9000);
        });

        // ── ACCESS CODE: generate random code (edit session modal) ───────────
        document.getElementById('btn-es-gen-code').addEventListener('click', () => {
            document.getElementById('es-new-code').value = Math.floor(1000 + Math.random() * 9000);
        });

        // ── ACCESS CODE: update code live from edit modal ────────────────────
        document.getElementById('btn-update-code').addEventListener('click', async () => {
            const btn = document.getElementById('btn-update-code');
            const newCode = document.getElementById('es-new-code').value.trim();
            await withTimeout(async () => {
                await updateDoc(doc(db, "groups", state.curGroupId, "sessions", state.curSessionId), {
                    accessCode: newCode || null
                });
                const codeDisplay = document.getElementById('es-current-code-display');
                if (codeDisplay) {
                    codeDisplay.textContent = newCode || 'ללא קוד';
                    codeDisplay.style.color = newCode ? 'var(--red)' : 'var(--muted)';
                }
                document.getElementById('es-new-code').value = '';
                showToast(newCode ? `קוד עודכן ל-${newCode}` : 'קוד הוסר', 'success');
            }, btn, 'עדכן קוד');
        });

        // ── APP INFO MODAL ──────────────────────────────────────────────────
        
function openInfoModal(isMandatory = false) {
    const modal = document.getElementById('app-info-modal');
    if (!modal) return;

    modal.classList.remove('hidden');

    // שמירת מצב mandatory כ-data attribute כדי שכפתור הסגירה ידע
    modal.dataset.mandatory = isMandatory ? '1' : '0';

    // מניעת סגירה בלחיצה על הרקע — בכל מקרה (center dialog)
    // modal-center לא נסגר ע"י swipe, אבל נחסום גם click על overlay
    modal._infoClickHandler && modal.removeEventListener('click', modal._infoClickHandler);
    modal._infoClickHandler = (e) => {
        if (e.target === modal) {
            if (isMandatory) {
                showToast('יש לאשר את המידע כדי להמשיך', 'warning');
            } else {
                closeAppInfo();
            }
        }
    };
    modal.addEventListener('click', modal._infoClickHandler);
}

function closeAppInfo() {
    const modal = document.getElementById('app-info-modal');
    if (!modal) return;
    modal.classList.add('hidden');
    modal.dataset.mandatory = '0';
    localStorage.setItem('imhere_info_seen', '1');
}

// הגדרת מאזיני אירועים — btn-close-info-modal
document.addEventListener('DOMContentLoaded', () => {
    const closeBtn = document.getElementById('btn-close-info-modal');
    if (closeBtn) {
        closeBtn.addEventListener('click', closeAppInfo);
    }
    const navInfoBtn = document.getElementById('nav-info-btn');
    if (navInfoBtn) {
        navInfoBtn.addEventListener('click', () => openInfoModal(false));
    }
});

// btn-close-info-modal — fallback (in case DOMContentLoaded already fired inside module)
(function() {
    const closeBtn = document.getElementById('btn-close-info-modal');
    if (closeBtn && !closeBtn._infoHandlerSet) {
        closeBtn._infoHandlerSet = true;
        closeBtn.addEventListener('click', closeAppInfo);
    }
    const navInfoBtn = document.getElementById('nav-info-btn');
    if (navInfoBtn && !navInfoBtn._infoHandlerSet) {
        navInfoBtn._infoHandlerSet = true;
        navInfoBtn.addEventListener('click', () => openInfoModal(false));
    }
})();

// הצגה אוטומטית בפעם הראשונה בלבד
setTimeout(() => {
    if (typeof auth !== 'undefined' && auth.currentUser) {
        if (!localStorage.getItem('imhere_info_seen')) {
            openInfoModal(true); // פותח במצב "חובה"
        }
    }
}, 2500);


        // ── SETTINGS MODAL ──────────────────────────────────────────────────
        function setGrace(mins) {
            document.getElementById('settings-grace-mins').value = mins;
        }
        // Wire grace preset buttons (inline onclick won't work in type="module")
        document.querySelectorAll('[data-grace]').forEach(btn => {
            btn.addEventListener('click', () => setGrace(Number(btn.dataset.grace)));
        });
        function openSettingsModal() {
            document.getElementById('settings-grace-mins').value = state.graceMins;
            // Show instructor section only for instructors/admins
            const instrSection = document.getElementById('settings-instructor-section');
            if (instrSection) instrSection.style.display = (state.userData?.role === 'instructor' || isAdmin()) ? '' : 'none';
            // Re-apply theme highlights so active button is marked correctly
            const savedTheme = localStorage.getItem('imhere_theme') || 'system';
            ['light','dark','system'].forEach(t => {
                const b = document.getElementById(`btn-theme-${t}`);
                if (b) {
                    b.style.fontWeight = (t === savedTheme) ? '800' : '';
                    b.style.borderColor = (t === savedTheme) ? 'var(--red)' : '';
                    b.style.color = (t === savedTheme) ? 'var(--red)' : '';
                }
            });
            // Re-apply lang highlights
            const savedLang = localStorage.getItem('imhere_lang') || 'he';
            ['he','en','ar'].forEach(l => {
                const b = document.getElementById(`btn-lang-${l}`);
                if (b) {
                    b.style.fontWeight = l === savedLang ? '800' : '';
                    b.style.borderColor = l === savedLang ? 'var(--red)' : '';
                    b.style.color = l === savedLang ? 'var(--red)' : '';
                }
            });
            document.getElementById('settings-modal').classList.remove('hidden');
        }
        document.getElementById('nav-settings-btn').addEventListener('click', openSettingsModal);
        document.getElementById('btn-close-settings').addEventListener('click', () => {
            document.getElementById('settings-modal').classList.add('hidden');
        });
        document.getElementById('btn-save-settings').addEventListener('click', () => {
            const newGrace = parseInt(document.getElementById('settings-grace-mins').value);
            if (!isNaN(newGrace) && newGrace >= 0 && newGrace <= 60) {
                state.graceMins = newGrace;
                localStorage.setItem('imhere_grace_mins', String(newGrace));
                showToast(`הגדרות נשמרו — חסד: ${newGrace} דקות`, 'success');
            }
            document.getElementById('settings-modal').classList.add('hidden');
        });
        // Show settings button for ALL users
        function updateSettingsVisibility() {
            const btn = document.getElementById('nav-settings-btn');
            if (btn) btn.classList.remove('hidden');
        }

        // ── DARK MODE ────────────────────────────────────────────────────────

        // =====================================================
        // LOGIN MESSAGE (Admin sets a banner on the login screen)
        // Stored in Firestore: systemSettings/loginMessage
        // =====================================================
        async function loadLoginMessageBanner() {
            try {
                const snap = await getDoc(doc(db, "systemSettings", "loginMessage"));
                if (snap.exists()) {
                    const data = snap.data();
                    const text = (data.text || '').trim();
                    const banner = document.getElementById('login-admin-message');
                    const bannerText = document.getElementById('login-admin-message-text');
                    if (text) {
                        bannerText.textContent = text;
                        banner.classList.remove('hidden');
                    } else {
                        banner.classList.add('hidden');
                    }
                }
            } catch(e) { console.warn('Could not load login message:', e); }
        }

        async function loadLoginSettings() {
            try {
                const snap = await getDoc(doc(db, "systemSettings", "loginMessage"));
                const text = snap.exists() ? (snap.data().text || '') : '';
                document.getElementById('admin-login-msg-text').value = text;
            } catch(e) { console.warn('Could not load login settings:', e); }
            loadPasswordRequests();
        }

        async function saveLoginMessage() {
            const text = document.getElementById('admin-login-msg-text').value.trim();
            const btn = document.getElementById('btn-save-login-message');
            btn.disabled = true; btn.textContent = 'שומר...';
            try {
                await setDoc(doc(db, "systemSettings", "loginMessage"), { text, updatedAt: serverTimestamp(), updatedBy: auth.currentUser.uid });
                writeLog('admin', text ? `עדכון הודעת כניסה: "${text.substring(0,60)}${text.length>60?'…':''}"` : 'הסרת הודעת כניסה ממסך הכניסה');
                showToast(text ? 'ההודעה נשמרה' : 'הבאנר הוסר', 'success');
            } catch(e) {
                showToast('שגיאה בשמירה', 'error');
            } finally {
                btn.disabled = false; btn.textContent = 'שמור הודעה';
            }
        }

        async function clearLoginMessage() {
            const confirmed = await appDialog({ title: 'הסרת הודעה', message: 'להסיר את ההודעה ממסך הכניסה?', confirmText: 'הסר', cancelText: 'ביטול', danger: true });
            if (!confirmed) return;
            document.getElementById('admin-login-msg-text').value = '';
            await saveLoginMessage();
        }

        // Load banner on auth screen load
        loadLoginMessageBanner();

        // =====================================================
        // FORGOT PASSWORD REQUEST
        // Stored in: passwordResetRequests/{id}
        // =====================================================
        async function sendForgotPasswordRequest() {
            const fullName = document.getElementById('fp-fullname').value.trim();
            const idNum    = document.getElementById('fp-id').value.trim();
            const phone    = document.getElementById('fp-phone').value.trim();
            const reason   = document.getElementById('fp-reason').value.trim();
            if (!fullName || !idNum || !phone || !reason) {
                await appDialog({ title: 'שדות חסרים', message: 'נא למלא את כל השדות: שם מלא, תעודת זהות, טלפון וסיבת הבקשה.', confirmText: 'סגור' });
                return;
            }
            if (!/^[0-9]{8,9}$/.test(idNum)) {
                await appDialog({ title: 'שגיאה', message: 'תעודת הזהות אינה תקינה — יש להזין 8-9 ספרות.', confirmText: 'סגור' });
                return;
            }
            const btn = document.getElementById('btn-send-forgot-password');
            btn.disabled = true; btn.textContent = 'שולח...';
            try {
                await addDoc(collection(db, "passwordResetRequests"), {
                    fullName, idNumber: idNum, phone, reason,
                    status: 'pending',
                    createdAt: serverTimestamp()
                });
                closeModals();
                showToast('הבקשה נשלחה! צוות התמיכה יטפל בה בהקדם', 'success');
            } catch(e) {
                console.error(e);
                showToast('שגיאה בשליחה — בדוק חיבור לאינטרנט', 'error');
            } finally {
                btn.disabled = false; btn.textContent = 'שלח בקשה לתמיכה';
            }
        }

        async function loadPasswordRequests() {
            const list = document.getElementById('admin-password-requests-list');
            if (!list) return;
            list.innerHTML = '<div class="loading-text">טוען...</div>';
            try {
                const snaps = await getDocs(query(collection(db, "passwordResetRequests"), orderBy("createdAt", "desc")));
                if (snaps.empty) {
                    list.innerHTML = '<div class="empty-state"><span class="empty-icon"></span><p>אין בקשות איפוס סיסמה</p></div>';
                    return;
                }
                list.innerHTML = '';
                snaps.forEach(d => {
                    const r = d.data();
                    const dateStr = r.createdAt ? r.createdAt.toDate().toLocaleString('he-IL') : '';
                    const statusColor = r.status === 'resolved' ? 'var(--green)' : 'var(--amber)';
                    const statusLabel = r.status === 'resolved' ? 'טופל' : 'ממתין';
                    const card = document.createElement('div');
                    card.style.cssText = 'background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);padding:16px;margin-bottom:10px;border-right:4px solid ' + statusColor + ';';
                    card.innerHTML = `
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;flex-wrap:wrap;gap:6px;">
                            <strong style="font-size:0.97rem;color:var(--ink);">${safeHTML(r.fullName)}</strong>
                            <span style="font-size:0.78rem;font-weight:700;color:${statusColor};background:rgba(0,0,0,0.05);padding:2px 10px;border-radius:99px;">${statusLabel}</span>
                        </div>
                        <div style="font-size:0.83rem;color:var(--muted);margin-bottom:6px;">
                            ת.ז: <strong style="color:var(--ink-3);">${safeHTML(r.idNumber)}</strong> &nbsp;|&nbsp; טלפון: <strong style="color:var(--ink-3);">${safeHTML(r.phone)}</strong>
                        </div>
                        <div style="font-size:0.85rem;color:var(--ink-3);background:var(--surface-2);border-radius:var(--r-sm);padding:10px;margin-bottom:8px;line-height:1.55;">
                            <span style="font-weight:700;font-size:0.78rem;color:var(--muted);display:block;margin-bottom:3px;">סיבת הבקשה:</span>
                            ${safeHTML(r.reason)}
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
                            <span style="font-size:0.78rem;color:var(--subtle);">${safeHTML(dateStr)}</span>
                            ${r.status !== 'resolved' ? `<button data-req-id="${d.id}" class="btn-mark-req-resolved outline action-btn-small" style="color:var(--green);border-color:var(--green);width:auto;">סמן כטופל</button>` : ''}
                        </div>
                    `;
                    list.appendChild(card);
                });
                // Mark as resolved buttons
                list.querySelectorAll('.btn-mark-req-resolved').forEach(btn => {
                    btn.addEventListener('click', async () => {
                        const reqId = btn.dataset.reqId;
                        btn.disabled = true; btn.textContent = 'מעדכן...';
                        await updateDoc(doc(db, "passwordResetRequests", reqId), { status: 'resolved', resolvedAt: serverTimestamp(), resolvedBy: auth.currentUser.uid });
                        showToast('הבקשה סומנה כטופלה', 'success');
                        loadPasswordRequests();
                    });
                });
            } catch(e) {
                list.innerHTML = '<div class="empty-state"><span>!</span><p>שגיאה בטעינה</p></div>';
                console.error(e);
            }
        }

        const THEME_KEY = 'imhere_theme';
        function applyTheme(theme) {
            const html = document.documentElement;
            if (theme === 'dark') {
                html.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                html.removeAttribute('data-theme');
            } else {
                // system
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                if (prefersDark) html.setAttribute('data-theme', 'dark');
                else html.removeAttribute('data-theme');
            }
            localStorage.setItem(THEME_KEY, theme);
            // Update active buttons
            ['light','dark','system'].forEach(t => {
                const btn = document.getElementById(`btn-theme-${t}`);
                if (btn) btn.style.fontWeight = (t === theme) ? '800' : '';
                if (btn) btn.style.borderColor = (t === theme) ? 'var(--red)' : '';
                if (btn) btn.style.color = (t === theme) ? 'var(--red)' : '';
            });
        }
        // Apply saved theme on load
        applyTheme(localStorage.getItem(THEME_KEY) || 'system');
        document.getElementById('btn-theme-light').addEventListener('click', () => applyTheme('light'));
        document.getElementById('btn-theme-dark').addEventListener('click', () => applyTheme('dark'));
        document.getElementById('btn-theme-system').addEventListener('click', () => applyTheme('system'));
        // Also react to OS theme change
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if ((localStorage.getItem(THEME_KEY) || 'system') === 'system') applyTheme('system');
        });

        // ── LANGUAGE ────────────────────────────────────────────────────────
        const LANG_KEY = 'imhere_lang';
        const TRANSLATIONS = {
            he: {
                appName: "I'm Here",
                loginTitle: 'כניסה למערכת',
                loginBtn: 'היכנס למערכת',
                registerBtn: 'הרשמה',
                homeBtn: 'ראשי',
                backBtn: 'חזור',
                refreshBtn: 'רענן',
                reportPresent: 'נוכח',
                reportLate: 'איחור',
                reportExcused: 'באישור',
                reportAbsent: 'חיסור',
                lockSession: 'סגור',
                openSession: 'פתח מחדש',
            },
            en: {
                appName: "I'm Here",
                loginTitle: 'Sign In',
                loginBtn: 'Sign In',
                registerBtn: 'Register',
                homeBtn: 'Home',
                backBtn: 'Back',
                refreshBtn: 'Refresh',
                reportPresent: 'Present',
                reportLate: 'Late',
                reportExcused: 'Excused',
                reportAbsent: 'Absent',
                lockSession: 'Lock',
                openSession: 'Reopen',
            },
            ar: {
                appName: "I'm Here",
                loginTitle: 'تسجيل الدخول',
                loginBtn: 'دخول',
                registerBtn: 'تسجيل',
                homeBtn: 'الرئيسية',
                backBtn: 'رجوع',
                refreshBtn: 'تحديث',
                reportPresent: 'حاضر',
                reportLate: 'متأخر',
                reportExcused: 'بإذن',
                reportAbsent: 'غائب',
                lockSession: 'إغلاق',
                openSession: 'إعادة فتح',
            }
        };
        let currentLang = localStorage.getItem(LANG_KEY) || 'he';

        function applyLang(lang, showFeedback = false) {
            currentLang = lang;
            localStorage.setItem(LANG_KEY, lang);
            const t = TRANSLATIONS[lang] || TRANSLATIONS['he'];
            // App is Hebrew/Arabic/English but always RTL — English is also displayed RTL for layout consistency
            document.documentElement.dir = 'rtl';
            document.documentElement.lang = lang === 'en' ? 'en' : lang === 'ar' ? 'ar' : 'he';
            // Update key UI strings
            const loginTitleEl = document.getElementById('login-title');
            if (loginTitleEl) safeText(loginTitleEl, t.loginTitle);
            const loginBtnEl = document.getElementById('btn-login-submit');
            if (loginBtnEl && loginBtnEl.textContent !== t.loginBtn) loginBtnEl.textContent = t.loginBtn;
            // Update language button highlights
            ['he','en','ar'].forEach(l => {
                const btn = document.getElementById(`btn-lang-${l}`);
                if (btn) {
                    btn.style.fontWeight = l === lang ? '800' : '';
                    btn.style.borderColor = l === lang ? 'var(--red)' : '';
                    btn.style.color = l === lang ? 'var(--red)' : '';
                }
            });
            // Only show toast on explicit user action, not on page load
            if (showFeedback) {
                showToast(lang === 'en' ? 'Language changed to English' : lang === 'ar' ? 'تم تغيير اللغة' : 'השפה שונה לעברית', 'success');
            }
        }
        applyLang(currentLang); // silent on load — no toast
        document.getElementById('btn-lang-he').addEventListener('click', () => applyLang('he', true));
        document.getElementById('btn-lang-en').addEventListener('click', () => applyLang('en', true));
        document.getElementById('btn-lang-ar').addEventListener('click', () => applyLang('ar', true));

        document.addEventListener('contextmenu', event => {
            if (event.target.tagName !== 'INPUT' && event.target.tagName !== 'TEXTAREA') {
                event.preventDefault();
            }
        }, false);

        // ── FROZEN VIEW ──────────────────────────────────────────────────────
        document.getElementById('btn-frozen-logout').addEventListener('click', () => signOut(auth));

        document.getElementById('btn-frozen-send').addEventListener('click', async () => {
            const courseName = document.getElementById('frozen-course-name').value.trim();
            const courseNum  = document.getElementById('frozen-course-number').value.trim();
            const instrName  = document.getElementById('frozen-instructor-name').value.trim();
            if (!courseName || !courseNum || !instrName) {
                await appDialog({ title: 'שדות חסרים', message: 'נא למלא את כל השדות לפני שליחה.', confirmText: 'סגור' });
                return;
            }
            const btn = document.getElementById('btn-frozen-send');
            btn.disabled = true; btn.textContent = 'שולח...';
            try {
                await addDoc(collection(db, "userMessages"), {
                    fromUid: auth.currentUser.uid,
                    fromName: state.userData?.fullName || 'חניך חדש',
                    fromRole: 'frozen',
                    toUid: 'support',
                    toName: 'תמיכה',
                    text: `פנייה לאישור חשבון חדש:\nשם קורס: ${courseName}\nמספר קורס: ${courseNum}\nמדריך: ${instrName}`,
                    createdAt: serverTimestamp(),
                    readByRecipient: false,
                    confirmedByUser: false
                });
                showToast('הפנייה נשלחה! נחזור אליך בהקדם', 'success');
                btn.textContent = 'פנייה נשלחה';
                btn.disabled = false;
            } catch (err) {
                console.error(err);
                showToast('שגיאה בשליחה — נסה שוב', 'error');
                btn.disabled = false;
                btn.textContent = 'שלח פנייה לתמיכה';
            }
        });


    </script>
    <div id="toast-container"></div>
</body>
</html>
