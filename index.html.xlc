        document.getElementById('bc-target').addEventListener('change', async () => {
            const val = document.getElementById('bc-target').value;
            document.getElementById('bc-group-select-wrap').classList.toggle('hidden', val !== 'group');
            document.getElementById('bc-students-select-wrap').classList.toggle('hidden', val !== 'specific_students');
            if (val === 'specific_students') {
                const studentsList = document.getElementById('bc-students-list');
                if (studentsList.children.length === 0) {
                    studentsList.innerHTML = '<div class="loading-text" style="padding:8px;">טוען חניכים...</div>';
                    const snaps = await getDocs(query(collection(db, "users"), where("role", "==", "student")));
                    studentsList.innerHTML = '';
                    // Sort client-side to avoid requiring a composite Firestore index
                    const sortedDocs = [...snaps.docs].sort((a, b) => (a.data().fullName || '').localeCompare(b.data().fullName || '', 'he'));
                    sortedDocs.forEach(d => {
                        const u = d.data();
                        const label = document.createElement('label');
                        label.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 4px;cursor:pointer;font-size:0.9rem;border-bottom:1px solid var(--border-light);';
                        const cb = document.createElement('input');
                        cb.type = 'checkbox';
                        cb.value = d.id;
                        cb.style.cssText = 'width:auto;margin:0;';
                        label.appendChild(cb);
                        label.appendChild(document.createTextNode(u.fullName));
                        studentsList.appendChild(label);
                    });
                }
            }
        });
        document.getElementById('btn-refresh-log').addEventListener('click', loadAdminLog);
        document.getElementById('log-filter-type').addEventListener('change', loadAdminLog);
        document.getElementById('log-search').addEventListener('input', () => {
            const q = document.getElementById('log-search').value.toLowerCase();
            document.querySelectorAll('#admin-log-list .log-entry').forEach(entry => {
                const text = entry.textContent.toLowerCase();
                entry.style.display = q === '' || text.includes(q) ? '' : 'none';
            });
        });
        document.getElementById('btn-export-log').addEventListener('click', () => {
            const entries = document.querySelectorAll('#admin-log-list .log-entry');
            if (!entries.length) { showToast('אין נתונים לייצוא', 'warning'); return; }
            const rows = [['תאריך ושעה', 'שם משתמש', 'סוג פעולה', 'פרטים']];
            entries.forEach(entry => {
                const actor = entry.querySelector('.log-actor span:last-child')?.textContent?.trim() || '';
                const badge = entry.querySelector('.log-badge')?.textContent?.trim() || '';
                const details = entry.querySelector('.log-details')?.textContent?.trim() || '';
                const time = entry.querySelector('.log-time')?.textContent?.trim() || '';
                rows.push([time, actor, badge, details]);
            });
            const csv = rows.map(r => r.map(c => `"${c.replace(/"/g,'""')}"`).join(',')).join('\n');
            const bom = '\uFEFF';
            const blob = new Blob([bom + csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a'); a.href = url; a.download = `systemLog_${new Date().toLocaleDateString('he-IL').replace(/\//g,'-')}.csv`;
            a.click(); URL.revokeObjectURL(url);
            showToast('הלוג יוצא בהצלחה', 'success');
        });
