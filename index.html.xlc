<!DOCTYPE html>
<html lang="he" dir="rtl" translate="no">
        
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>מערכת נוכחות חכמה</title>
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#dc2626">

   <meta property="og:title" content="Im Here">
   <meta property="og:description" content="מערכת נוכחות מתקדמת">
   <meta property="og:url" content="https://imhere.study/">
   <meta property="og:image" content="https://imhere.study/Micon.png">
   <meta property="og:type" content="website">

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('sw.js').catch((err) => {
                    console.warn('Service Worker registration failed:', err);
                });
            });
        }
    </script>
    
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <style>
        /* ══════════════════════════════════════════════════════
           DESIGN TOKENS
        ══════════════════════════════════════════════════════ */
        :root {
            --red:          #dc2626;
            --red-dark:     #b91c1c;
            --red-soft:     rgba(220, 38, 38, 0.10);
            --red-glow:     rgba(220, 38, 38, 0.18);
            --ink:          #0d1117;
            --ink-2:        #1c2531;
            --ink-3:        #374151;
            --muted:        #6b7280;
            --subtle:       #9ca3af;
            --bg:           #f2f4f8;
            --surface:      #ffffff;
            --surface-2:    #f8f9fb;
            --surface-3:    #f0f2f6;
            --border:       #e2e6ed;
            --border-light: #edf0f5;
            --green:        #059669;
            --green-soft:   rgba(5, 150, 105, 0.10);
            --amber:        #d97706;
            --amber-soft:   rgba(217, 119, 6, 0.10);
            --blue:         #2563eb;
            --blue-soft:    rgba(37, 99, 235, 0.10);
            --danger:       #dc2626;
            --shadow-xs:    0 1px 3px rgba(13,17,23,0.06), 0 1px 2px rgba(13,17,23,0.04);
            --shadow-sm:    0 2px 8px rgba(13,17,23,0.07), 0 1px 3px rgba(13,17,23,0.05);
            --shadow-md:    0 6px 24px rgba(13,17,23,0.09), 0 2px 8px rgba(13,17,23,0.05);
            --shadow-lg:    0 16px 48px rgba(13,17,23,0.12), 0 4px 12px rgba(13,17,23,0.06);
            --shadow-xl:    0 32px 80px rgba(13,17,23,0.16), 0 8px 24px rgba(13,17,23,0.08);
            --r-sm:  8px; --r-md: 14px; --r-lg: 18px; --r-xl: 24px;
            --ease-bounce: cubic-bezier(0.34,1.56,0.64,1);
            --ease-out:    cubic-bezier(0.22,1,0.36,1);
        }
        /* ── DARK MODE ─────────────────────────────────────── */
        html[data-theme="dark"] {
            --ink:          #f0f4f8;
            --ink-2:        #e2e8f0;
            --ink-3:        #cbd5e1;
            --muted:        #94a3b8;
            --subtle:       #64748b;
            --bg:           #0d1117;
            --surface:      #161b22;
            --surface-2:    #1c2333;
            --surface-3:    #21262d;
            --border:       #30363d;
            --border-light: #21262d;
            --shadow-xs:    0 1px 3px rgba(0,0,0,0.3);
            --shadow-sm:    0 2px 8px rgba(0,0,0,0.4);
            --shadow-md:    0 6px 24px rgba(0,0,0,0.5);
            --shadow-lg:    0 16px 48px rgba(0,0,0,0.6);
            --shadow-xl:    0 32px 80px rgba(0,0,0,0.7);
        }
        html[data-theme="dark"] header {
            background: rgba(22,27,34,0.92);
            border-bottom-color: #30363d;
        }
        html[data-theme="dark"] input,
        html[data-theme="dark"] select,
        html[data-theme="dark"] textarea {
            background: var(--surface-3);
            color: var(--ink);
            border-color: var(--border);
        }
        html[data-theme="dark"] input::placeholder,
        html[data-theme="dark"] textarea::placeholder { color: var(--subtle); }
        html[data-theme="dark"] button.outline {
            background: var(--surface-2);
            color: var(--ink-3);
            border-color: var(--border);
        }
        html[data-theme="dark"] button.outline:hover {
            background: var(--surface-3);
            border-color: #4b5563;
            color: var(--ink);
        }
        html[data-theme="dark"] button.secondary {
            background: #334155;
            color: #f1f5f9;
        }
        html[data-theme="dark"] button.secondary:hover {
            background: #475569;
        }
        html[data-theme="dark"] button:disabled {
            background: #374151 !important;
            color: #6b7280 !important;
        }
        html[data-theme="dark"] #app-dialog-box,
        html[data-theme="dark"] #broadcast-modal-box {
            border-top-color: var(--border);
            box-shadow: 0 -8px 40px rgba(0,0,0,0.5);
        }
        html[data-theme="dark"] #broadcast-modal-box {
            border-top-color: var(--red);
        }
        html[data-theme="dark"] #profile-modal-box {
            background: var(--surface);
            box-shadow: 0 -8px 40px rgba(0,0,0,0.5);
        }
        html[data-theme="dark"] .modal-center > .card {
            box-shadow: 0 32px 80px rgba(0,0,0,0.7);
        }
        html[data-theme="dark"] #bottom-nav .bn-item {
            color: var(--muted);
        }
        html[data-theme="dark"] #bottom-nav .bn-item.active {
            color: #f87171;
        }
        html[data-theme="dark"] #bottom-nav .bn-item:hover {
            color: var(--ink);
        }
        html[data-theme="dark"] .dropdown-menu {
            background: var(--surface);
            border-color: var(--border);
        }
        *, *::before, *::after {
            box-sizing: border-box; margin: 0; padding: 0;
            font-family: 'Heebo', sans-serif;
            -webkit-font-smoothing: antialiased;
            -webkit-user-select: none; user-select: none;
            -webkit-touch-callout: none;
            -webkit-tap-highlight-color: transparent;
        }
        input, textarea { -webkit-user-select: text; user-select: text; }
        /* Block pull-to-refresh everywhere except the very top of the page */
        html { overscroll-behavior-y: auto; }
        body {
            background: var(--bg);
            background-image: radial-gradient(ellipse 70% 50% at 90% 0%, rgba(220,38,38,0.05) 0%, transparent 70%),
                              radial-gradient(ellipse 50% 40% at 10% 100%, rgba(13,17,23,0.04) 0%, transparent 70%);
            color: var(--ink); min-height: 100vh;
            display: flex; flex-direction: column; padding-top: 64px; padding-bottom: 72px;
        }

        /* ── BOTTOM NAV ────────────────────────────────────── */
        #bottom-nav {
            position: fixed; bottom: 0; left: 0; right: 0; z-index: 10001;
            height: 64px;
            background: rgba(255,255,255,0.94);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-top: 1px solid var(--border-light);
            box-shadow: 0 -4px 24px rgba(13,17,23,0.07);
            display: none;
            align-items: stretch;
            justify-content: space-around;
            padding-bottom: env(safe-area-inset-bottom, 0px);
        }
        html[data-theme="dark"] #bottom-nav {
            background: rgba(22,27,34,0.95);
            border-top-color: #30363d;
        }
        #bottom-nav.visible { display: flex; }
        #bottom-nav .bn-item {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 3px; cursor: pointer;
            color: var(--muted); font-size: 0.68rem; font-weight: 700;
            letter-spacing: 0.1px;
            transition: color 0.18s var(--ease-out);
            -webkit-tap-highlight-color: transparent;
            padding: 8px 4px 4px;
            border: none; background: none !important; width: auto;
            box-shadow: none !important; border-radius: 0;
            position: relative;
        }
        #bottom-nav .bn-item:hover { color: var(--ink); background: none !important; transform: none !important; box-shadow: none !important; }
        #bottom-nav .bn-item:active { color: var(--red); transform: none !important; box-shadow: none !important; background: none !important; }
        #bottom-nav .bn-item.active { color: var(--red); }
        #bottom-nav .bn-item .bn-icon {
            font-size: 1.35rem; line-height: 1;
            transition: transform 0.2s var(--ease-bounce);
        }
        #bottom-nav .bn-item.active .bn-icon { transform: scale(1.12); }
        #bottom-nav .bn-item .bn-label { font-family: 'Heebo', sans-serif; }
        .bn-badge {
            position: absolute; top: 5px; right: calc(50% - 18px);
            background: var(--red); color: white; border-radius: 99px;
            font-size: 0.58rem; font-weight: 800; padding: 1px 5px;
            min-width: 16px; text-align: center; line-height: 1.4;
            box-shadow: 0 1px 4px rgba(220,38,38,0.4);
        }
        /* HEADER */
        header {
            position: fixed; top: 0; left: 0; right: 0; height: 64px;
            background: rgba(255,255,255,0.88);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid var(--border-light);
            box-shadow: 0 1px 0 var(--border-light), 0 4px 24px rgba(13,17,23,0.05);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 20px; z-index: 10001;
        }
        header > div:last-child {
            font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.15rem;
            letter-spacing: -0.5px; color: var(--ink);
            display: flex; align-items: center; gap: 6px;
        }
        header > div:last-child::before {
            content: ''; width: 8px; height: 8px; border-radius: 50%;
            background: var(--red); box-shadow: 0 0 8px var(--red-glow); flex-shrink: 0;
        }
        main { flex: 1; padding: 20px 14px 32px; max-width: 820px; margin: 0 auto; width: 100%; }
        /* CARDS */
        .card {
            background: var(--surface); border-radius: var(--r-xl);
            padding: 26px 24px; box-shadow: var(--shadow-sm);
            border: 1px solid var(--border); margin-bottom: 16px;
            transition: transform 0.25s var(--ease-bounce), box-shadow 0.25s var(--ease-out);
        }
        .clickable { cursor: pointer; -webkit-tap-highlight-color: transparent; touch-action: manipulation; }
        .clickable:hover  { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: #d4d9e3; }
        .clickable:active { transform: scale(0.975) !important; box-shadow: var(--shadow-xs) !important; transition-duration: 0.08s !important; }
        /* TYPOGRAPHY */
        h2 {
            font-family: 'Syne', sans-serif; font-weight: 800; color: var(--ink);
            font-size: 1.3rem; letter-spacing: -0.4px; margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
        }
        h2::before {
            content: ''; width: 4px; height: 20px;
            background: linear-gradient(180deg, var(--red), #f87171);
            border-radius: 3px; flex-shrink: 0;
        }
        h2[style*="text-align:center"]::before, h2[style*="text-align: center"]::before { display: none; }
        h2[style*="text-align:center"], h2[style*="text-align: center"] { justify-content: center; }
        h3 { color: var(--ink); font-weight: 700; font-size: 1.02rem; margin-bottom: 14px; letter-spacing: -0.2px; }
        label { display: block; font-size: 0.83rem; font-weight: 700; color: var(--ink-3); margin-bottom: 5px; }
        /* INPUTS */
        input, select, textarea {
            width: 100%; padding: 12px 15px; border: 1.5px solid var(--border);
            border-radius: var(--r-md); background: var(--surface-2);
            font-size: 0.97rem; font-family: 'Heebo', sans-serif; color: var(--ink);
            margin-bottom: 13px;
            transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
            appearance: none;
        }
        input:focus, select:focus, textarea:focus {
            outline: none; border-color: var(--red); background: var(--surface);
            box-shadow: 0 0 0 3.5px var(--red-soft);
        }
        input::placeholder, textarea::placeholder { color: var(--subtle); }
        input:disabled { background: var(--surface-3); color: var(--muted); cursor: default; border-color: var(--border-light); opacity: 1; }
        /* BUTTONS — Modern Flat Design */
        button {
            background: var(--red);
            color: #fff; border: none; padding: 13px 20px; border-radius: 12px;
            cursor: pointer; width: 100%; font-size: 0.95rem; font-weight: 700;
            font-family: 'Heebo', sans-serif; letter-spacing: 0.2px;
            position: relative; overflow: hidden;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
            transition:
                background   0.15s var(--ease-out),
                transform    0.12s var(--ease-bounce),
                box-shadow   0.15s var(--ease-out),
                opacity      0.12s ease;
            box-shadow: 0 2px 8px rgba(220,38,38,0.22), 0 1px 2px rgba(220,38,38,0.12);
        }
        button:hover  { background: var(--red-dark); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(220,38,38,0.30); }
        button:active { transform: scale(0.96) !important; box-shadow: 0 1px 3px rgba(220,38,38,0.15) !important; opacity: 0.88; transition-duration: 0.06s !important; }
        button:disabled { background: #d1d5db !important; color: #9ca3af !important; box-shadow: none !important; transform: none !important; cursor: not-allowed; opacity: 0.75; }

        button.secondary {
            background: #1e293b; color: #fff;
            box-shadow: 0 2px 8px rgba(13,17,23,0.25), 0 1px 2px rgba(13,17,23,0.15);
        }
        button.secondary:hover  { background: #0f172a; box-shadow: 0 6px 18px rgba(13,17,23,0.35); }
        button.secondary:active { box-shadow: 0 1px 3px rgba(13,17,23,0.2) !important; }

        button.outline {
            background: var(--surface); border: 1.5px solid var(--border);
            color: var(--ink-3); box-shadow: 0 1px 4px rgba(13,17,23,0.05);
        }
        button.outline:hover  { background: var(--surface-2); border-color: #c0c8d5; box-shadow: 0 3px 10px rgba(13,17,23,0.09); transform: translateY(-1px); }
        button.outline:active { transform: scale(0.96) !important; box-shadow: none !important; }

        .action-btn-small {
            width: auto; padding: 9px 15px; font-size: 0.84rem;
            border-radius: 10px; font-weight: 700;
        }
        .icon-btn {
            background: rgba(220,38,38,0.06); border: 1.5px solid rgba(220,38,38,0.25); border-radius: 10px;
            color: var(--danger); font-size: 0.88rem; cursor: pointer; padding: 7px 11px; width: auto;
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            transition: all 0.15s var(--ease-out); box-shadow: none;
        }
        .icon-btn:hover  { background: rgba(220,38,38,0.12); border-color: var(--danger); transform: scale(1.04); }
        .icon-btn:active { transform: scale(0.94) !important; opacity: 0.8; transition-duration: 0.06s !important; }

        /* Ripple wave injected by JS */
        .ripple {
            position: absolute; border-radius: 50%;
            background: rgba(255,255,255,0.30);
            transform: scale(0); pointer-events: none;
            animation: rippleOut 0.5s linear forwards;
        }
        button.outline .ripple, button.outline .ripple { background: rgba(13,17,23,0.10); }
        @keyframes rippleOut {
            to { transform: scale(4.5); opacity: 0; }
        }
        /* STATUS TAGS */
        .status-tag {
            display: inline-flex; align-items: center; padding: 3px 11px;
            border-radius: 99px; font-size: 0.76rem; font-weight: 800;
            color: white; letter-spacing: 0.2px; white-space: nowrap;
        }
        .bg-green  { background: #059669 !important; color: white !important; box-shadow: 0 2px 8px rgba(5,150,105,0.22) !important; }
        .bg-red    { background: #dc2626 !important; color: white !important; box-shadow: 0 2px 8px rgba(220,38,38,0.22) !important; }
        .bg-yellow { background: #d97706 !important; color: white !important; box-shadow: 0 2px 8px rgba(217,119,6,0.22) !important; }
        .bg-blue   { background: #2563eb !important; color: white !important; box-shadow: 0 2px 8px rgba(37,99,235,0.22) !important; }
        .bg-purple { background: #7c3aed !important; color: white !important; box-shadow: 0 2px 8px rgba(124,58,237,0.22) !important; }
        .text-green  { color: var(--green);  font-weight: 700; }
        .text-orange { color: var(--amber);  font-weight: 700; }
        .text-red    { color: var(--danger); font-weight: 700; }
        /* LIST ITEMS */
        .list-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 13px 16px; border-radius: var(--r-md); margin-bottom: 7px;
            background: var(--surface); border: 1px solid var(--border-light);
            transition: border-color 0.17s var(--ease-out), box-shadow 0.17s var(--ease-out), transform 0.1s ease, background 0.15s;
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            cursor: pointer;
        }
        .list-item:last-child { margin-bottom: 0; }
        .list-item:hover  { border-color: var(--border); box-shadow: var(--shadow-xs); }
        .list-item:active { transform: scale(0.985); background: var(--surface-2); transition-duration: 0.06s; }
        /* TABS */
        .tab-container {
            display: flex; gap: 3px; margin-bottom: 20px;
            background: var(--surface-3); border: 1px solid var(--border);
            border-radius: var(--r-md); padding: 4px; overflow-x: auto; scrollbar-width: none;
        }
        .tab-container::-webkit-scrollbar { display: none; }
        .tab {
            padding: 8px 14px; cursor: pointer; border-radius: var(--r-sm);
            font-weight: 500; font-size: 0.86rem; color: var(--muted);
            transition: all 0.18s var(--ease-out), transform 0.1s ease;
            white-space: nowrap; flex-shrink: 0;
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
        }
        .tab:hover  { color: var(--ink); background: rgba(255,255,255,0.65); }
        .tab:active { transform: scale(0.94); opacity: 0.75; transition-duration: 0.06s; }
        .tab.active { background: var(--surface); color: var(--red); font-weight: 700; box-shadow: 0 1px 5px rgba(13,17,23,0.09); }
        /* ACTION ROW */
        .action-row { display: flex; gap: 7px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
        /* PROFILE & DROPDOWN */
        .profile-area {
            position: relative; cursor: pointer; display: flex; align-items: center;
            gap: 9px; font-weight: 600; font-size: 0.92rem; padding: 7px 12px;
            border-radius: var(--r-md);
            transition: background 0.15s, transform 0.1s ease;
            color: var(--ink);
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
        }
        .profile-area:hover  { background: var(--surface-3); }
        .profile-area:active { transform: scale(0.96); background: var(--surface-3); transition-duration: 0.06s; }
        .profile-area > span:first-child {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, #dde3eb, #edf0f5);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 0.9rem; border: 1.5px solid var(--border); flex-shrink: 0;
        }
        .dropdown-menu {
            position: absolute; top: calc(100% + 10px); right: 0; left: auto;
            background: var(--surface); box-shadow: var(--shadow-lg);
            border-radius: var(--r-lg); border: 1px solid var(--border);
            display: none; width: 190px; z-index: 1000; overflow: hidden;
        }
        .dropdown-menu.show { display: block; animation: dropIn 0.22s var(--ease-bounce) forwards; }
        @keyframes dropIn { from { opacity: 0; transform: translateY(-8px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
        .dropdown-item {
            padding: 12px 18px; font-size: 0.9rem; font-weight: 500; color: var(--ink-3);
            cursor: pointer; transition: background 0.14s, padding 0.14s, color 0.14s, transform 0.08s;
            border-bottom: 1px solid var(--border-light);
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
        }
        .dropdown-item:last-child { border-bottom: none; }
        .dropdown-item:hover  { background: var(--surface-2); padding-right: 22px; color: var(--ink); }
        .dropdown-item:active { background: var(--surface-3); transform: scale(0.97); transition-duration: 0.06s; }
        /* TOASTS */
        #toast-container {
            position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
            z-index: 99999; display: flex; flex-direction: column; gap: 8px;
            width: 90%; max-width: 400px; pointer-events: none;
        }
        .toast {
            padding: 13px 20px; border-radius: var(--r-lg); color: white; font-weight: 700;
            font-size: 0.9rem; text-align: center; box-shadow: var(--shadow-lg);
            opacity: 0; transition: all 0.4s var(--ease-bounce);
            transform: translateY(20px) scale(0.94);
            border: 1px solid rgba(255,255,255,0.15); pointer-events: auto; line-height: 1.45;
        }
        .toast.show { opacity: 1; transform: translateY(0) scale(1); }
        /* MODALS — Bottom Sheet */
.modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(8,12,20,0.55);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    display: flex; align-items: flex-end; justify-content: center;
    z-index: 20000; padding: 0;
    animation: overlayFadeIn 0.22s ease forwards;
    overflow: hidden;
}

.modal-overlay > .card {
    width: 100%; max-width: 560px; margin: 0;
    border-radius: 22px 22px 0 0 !important;
    max-height: 92vh;
    display: flex;
    flex-direction: column;
    /* --- התיקונים --- */
    overflow-y: auto; /* מאפשר גלילה אנכית */
    -webkit-overflow-scrolling: touch; /* גלילה חלקה באייפון */
    overscroll-behavior: contain; /* מונע "בריחה" של הגלילה לרקע */
    /* ---------------- */
    padding: 0 24px 24px !important;
    box-shadow: 0 -8px 40px rgba(8,12,20,0.18) !important;
    will-change: transform;
}

/* Handle bar — פס לגרירה בראש כל bottom sheet */
.sheet-handle {
    width: 36px; height: 4px;
    background: var(--border); border-radius: 99px;
    margin: 12px auto 16px;
    flex-shrink: 0;
    cursor: grab;
    touch-action: none; /* JS שולט כאן בלבד */
}

/* ביטול ה-::before הישן */
.modal-overlay > .card::before { display: none; }

/* אזור תוכן - רק הוא יגלוש */
.modal-body-scroll {
    overflow-y: auto;
    flex: 1;
    margin-bottom: 16px;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
}

/* הכפתור בתחתית - לא יזוז ולא יתכווץ */
.modal-footer-fixed {
    flex-shrink: 0;
    padding-top: 8px;
    border-top: 1px solid var(--border-light);
}

/* MODALS — Center Dialog (חלון קופץ במרכז) */
.modal-center {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(8,12,20,0.60);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    z-index: 20000; padding: 20px;
    animation: overlayFadeIn 0.22s ease forwards;
    overflow: hidden;
}

.modal-center > .card {
    width: 100%; max-width: 480px; margin: 0;
    border-radius: var(--r-xl) !important;
    max-height: 90vh;
    overflow-y: auto;
    padding: 28px 26px !important;
    box-shadow: var(--shadow-xl) !important;
    animation: centerPopIn 0.28s cubic-bezier(0.34,1.56,0.64,1) forwards;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
}

@keyframes centerPopIn {
    from { opacity: 0; transform: scale(0.92) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* PROFILE MODAL — Bottom Sheet */
#profile-modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(8,12,20,0.55);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    display: flex; align-items: flex-end; justify-content: center;
    z-index: 20000; padding: 0;
    animation: overlayFadeIn 0.22s ease forwards;
    overflow: hidden;
}

#profile-modal-box {
    background: var(--surface);
    border-radius: 22px 22px 0 0;
    width: 100%; max-width: 560px;
    max-height: 92vh;
    display: flex; flex-direction: column;
    overflow: hidden;
    padding: 0 24px 32px;
    box-shadow: 0 -8px 40px rgba(8,12,20,0.18);
    will-change: transform;
    overscroll-behavior: contain;
}

#profile-modal-box::before { display: none; }

#profile-modal-scroll {
    overflow-y: auto; flex: 1; -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
}

        /* APP DIALOG */
        #app-dialog-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(8,12,20,0.55); backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            display: flex; align-items: flex-end; justify-content: center;
            z-index: 30000; padding: 0;
            animation: overlayFadeIn 0.22s ease forwards;
            overflow: hidden;
        }
        #app-dialog-box {
            background: var(--surface);
            border-radius: 22px 22px 0 0;
            border-top: 1px solid var(--border-light);
            padding: 8px 28px 36px; width: 100%; max-width: 560px;
            box-shadow: 0 -8px 40px rgba(8,12,20,0.18);
            will-change: transform;
            overscroll-behavior: contain;
            position: relative;
        }
        #app-dialog-box::before { display: none; }
        #app-dialog-title { font-family: 'Syne', sans-serif; font-size: 1.12rem; font-weight: 800; color: var(--ink); margin-bottom: 9px; letter-spacing: -0.3px; }
        #app-dialog-message { font-size: 0.93rem; color: var(--ink-3); margin-bottom: 20px; line-height: 1.65; white-space: pre-wrap; }
        #app-dialog-input {
            width: 100%; padding: 12px 15px; border: 1.5px solid var(--border);
            border-radius: var(--r-md); font-size: 0.97rem; margin-bottom: 16px;
            font-family: 'Heebo', sans-serif; display: none; background: var(--surface-2); color: var(--ink);
        }
        #app-dialog-input:focus { outline: none; border-color: var(--red); box-shadow: 0 0 0 3.5px var(--red-soft); background: var(--surface); }
        #app-dialog-actions { display: flex; gap: 8px; }
        /* BROADCAST MODAL */
        #broadcast-modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(8,12,20,0.75); backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            display: flex; align-items: flex-end; justify-content: center;
            z-index: 40000; padding: 0;
            animation: overlayFadeIn 0.22s ease forwards;
            overflow: hidden;
        }
        #broadcast-modal-box {
            background: var(--surface);
            border-radius: 22px 22px 0 0;
            border-top: 4px solid var(--red);
            padding: 8px 26px 36px; width: 100%; max-width: 560px;
            box-shadow: 0 -8px 40px rgba(8,12,20,0.22);
            animation: sheetSlideUp 0.34s cubic-bezier(0.32,0.72,0,1) forwards;
            position: relative;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
        }
        #broadcast-modal-box::before {
            content: ''; display: block; width: 36px; height: 4px;
            background: rgba(220,38,38,0.3); border-radius: 99px;
            margin: 10px auto 20px;
            flex-shrink: 0;
        }
        #broadcast-modal-title {
            font-family: 'Syne', sans-serif; font-size: 1.18rem; font-weight: 800;
            color: var(--ink); margin-bottom: 12px; flex-shrink: 0;
        }
        #broadcast-modal-body {
            font-size: 0.96rem; color: var(--ink-3); line-height: 1.7;
            margin-bottom: 16px; white-space: pre-wrap;
            overflow-y: auto;
            flex: 1;
            min-height: 0;
        }
        #broadcast-confirm-btn { flex-shrink: 0; }
        /* TABLES */
        table { width: 100%; border-collapse: separate; border-spacing: 0; margin-top: 10px; }
        th, td { padding: 11px 13px; text-align: right; }
        th { background: var(--surface-2); font-weight: 700; font-size: 0.82rem; color: var(--ink-3); letter-spacing: 0.2px; border-bottom: 2px solid var(--border); }
        td { border-bottom: 1px solid var(--border-light); font-size: 0.92rem; color: var(--ink-3); }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: var(--surface-3); }
        /* SEARCH WRAP */
        .search-wrap { position: relative; margin-bottom: 14px; }
        .search-wrap input { padding-right: 40px; margin-bottom: 0; }
        .search-wrap { position: relative; }
        /* PROGRESS BAR */
        .attendance-bar-wrap { height: 7px; background: var(--border-light); border-radius: 99px; overflow: hidden; margin-top: 6px; }
        .attendance-bar-fill { height: 100%; border-radius: 99px; transition: width 0.9s var(--ease-out); }
        /* EMPTY STATE */
        .empty-state { text-align: center; padding: 44px 20px; color: var(--subtle); }
        .empty-state .empty-icon { font-size: 2.6rem; margin-bottom: 10px; display: block; opacity: 0.35; }
        .empty-state p { font-size: 0.93rem; color: var(--subtle); }
        /* ADMIN STAT CARDS */
        .admin-stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 20px 14px; text-align: center; box-shadow: var(--shadow-xs); transition: transform 0.2s var(--ease-bounce), box-shadow 0.2s var(--ease-out); }
        .admin-stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
        .admin-stat-card .stat-label { font-size: 0.72rem; color: var(--muted); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 6px; display: block; }
        .admin-stat-card .stat-value { font-family: 'Syne', sans-serif; font-size: 1.9rem; font-weight: 800; line-height: 1; }
        /* NOTICE CARD */
        .notice-card { background: var(--surface-2); border: 1px solid var(--border-light); border-right: 3px solid var(--blue); border-radius: var(--r-md); padding: 15px 17px; margin-bottom: 9px; transition: box-shadow 0.17s; }
        .notice-card:hover { box-shadow: var(--shadow-xs); }
        .notice-card .notice-text { font-size: 0.94rem; line-height: 1.65; color: var(--ink); margin-bottom: 9px; }
        .notice-card .notice-meta { display: flex; justify-content: space-between; font-size: 0.76rem; color: var(--muted); }
        /* LOADING */
        .loading-text { text-align: center; color: var(--muted); padding: 28px; font-size: 0.88rem; animation: blinker 1.2s ease-in-out infinite; }
        /* ATTENDANCE STATES */
        .bg-blink-warn { background: linear-gradient(135deg, #fffdf4, #fffbe8); border: 1.5px solid var(--amber) !important; animation: blinker 1.6s ease-in-out infinite; }
        .bg-absent-static { background: var(--surface-3); border-right: 3px solid #d1d5db !important; }
        .exc-intense { background: linear-gradient(135deg, #fff1f1, #ffe4e4) !important; border: 2px solid var(--danger) !important; border-right: 5px solid var(--red-dark) !important; animation: intenseBlinker 1.2s ease-in-out infinite; }
        .exc-intense .exc-detail { display: block; font-size: 0.74rem; color: var(--danger); margin-top: 3px; font-weight: 600; }
        .exc-pending-card  { border-right: 4px solid var(--amber)  !important; background: linear-gradient(135deg, #fffceb 0%, #ffffff 60%) !important; }
        .exc-approved-card { border-right: 4px solid var(--green)  !important; background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 60%) !important; }
        .exc-denied-card   { border-right: 4px solid var(--danger) !important; background: linear-gradient(135deg, #fef2f2 0%, #ffffff 60%) !important; }
        .session-alert-card { border-right: 4px solid var(--red) !important; }
        .session-alert-card .attend-btn { background: linear-gradient(135deg, var(--red), var(--red-dark)); font-size: 1.02rem; padding: 14px; border-radius: var(--r-md); box-shadow: 0 4px 18px rgba(220,38,38,0.28); font-weight: 700; }
        .session-alert-card .attend-btn:hover { box-shadow: 0 8px 28px rgba(220,38,38,0.40); transform: translateY(-2px); }
        /* Dark mode overrides for attendance state cards */
        html[data-theme="dark"] .exc-pending-card  { background: linear-gradient(135deg, rgba(217,119,6,0.15) 0%, var(--surface) 60%) !important; }
        html[data-theme="dark"] .exc-approved-card { background: linear-gradient(135deg, rgba(5,150,105,0.15) 0%, var(--surface) 60%) !important; }
        html[data-theme="dark"] .exc-denied-card   { background: linear-gradient(135deg, rgba(220,38,38,0.15) 0%, var(--surface) 60%) !important; }
        html[data-theme="dark"] .bg-blink-warn { background: linear-gradient(135deg, rgba(217,119,6,0.12), rgba(217,119,6,0.06)) !important; }
        html[data-theme="dark"] .exc-intense { background: linear-gradient(135deg, rgba(220,38,38,0.2), rgba(220,38,38,0.12)) !important; }
        /* LOG */
        .log-entry { padding: 10px 14px; border-bottom: 1px solid var(--border-light); font-size: 0.84rem; line-height: 1.5; color: var(--ink-3); }
        .log-entry:last-child { border-bottom: none; }
        .log-entry .log-time { font-size: 0.73rem; color: var(--subtle); display: block; margin-top: 2px; }
        .log-entry.log-delete { border-right: 3px solid var(--danger); background: #fff9f9; }
        .log-entry.log-edit   { border-right: 3px solid var(--blue); }
        .log-entry.log-attend { border-right: 3px solid var(--green); }
        html[data-theme="dark"] .log-entry.log-delete { background: rgba(220,38,38,0.1); }
        /* MESSAGES */
        .msg-card { padding: 15px 17px; border-radius: var(--r-md); border: 1px solid var(--border-light); margin-bottom: 9px; background: var(--surface); transition: box-shadow 0.15s; }
        .msg-card:hover { box-shadow: var(--shadow-sm); }
        .msg-card.msg-unread   { border-right: 4px solid var(--red);   background: #fff9f9; }
        .msg-card.msg-has-reply{ border-right: 4px solid var(--green); background: #f6fef9; }
        .msg-card .msg-meta    { font-size: 0.74rem; color: var(--muted); margin-bottom: 6px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
        .msg-card .msg-body    { font-size: 0.92rem; color: var(--ink); line-height: 1.62; margin-bottom: 7px; }
        .msg-card .msg-reply-box { background: #f0fdf7; border: 1px solid #a7f3d0; border-radius: var(--r-sm); padding: 9px 13px; font-size: 0.86rem; color: #065f46; margin-top: 8px; line-height: 1.5; }
        /* Dark mode overrides for msg-card */
        html[data-theme="dark"] .msg-card.msg-unread   { background: rgba(220,38,38,0.1); }
        html[data-theme="dark"] .msg-card.msg-has-reply{ background: rgba(5,150,105,0.1); }
        html[data-theme="dark"] .msg-card .msg-reply-box { background: rgba(5,150,105,0.15); border-color: rgba(5,150,105,0.35); color: #6ee7b7; }

        /* ── INSTRUCTOR HOME INBOX WIDGET ──────────────────────────── */
        #instructor-inbox-home-card {
            background: var(--surface);
            border-radius: var(--r-xl);
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            margin-bottom: 20px;
            animation: fadeInUp 0.28s var(--ease-out) both;
        }
        #instructor-inbox-home-card .inbox-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 18px 20px 14px;
            border-bottom: 1px solid var(--border-light);
        }
        #instructor-inbox-home-card .inbox-header-left {
            display: flex; align-items: center; gap: 10px;
        }
        #instructor-inbox-home-card .inbox-title {
            font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.05rem;
            color: var(--ink); letter-spacing: -0.3px;
            display: flex; align-items: center; gap: 8px;
        }
        #instructor-inbox-home-card .inbox-title::before {
            content: ''; width: 4px; height: 18px;
            background: linear-gradient(180deg, var(--blue), #60a5fa);
            border-radius: 3px; flex-shrink: 0;
        }
        .inbox-unread-pill {
            background: var(--red); color: white;
            border-radius: 99px; font-size: 0.65rem; font-weight: 800;
            padding: 2px 8px; line-height: 1.5;
            box-shadow: 0 2px 6px rgba(220,38,38,0.35);
            animation: blinker 2s ease-in-out infinite;
        }
        .inbox-see-all-btn {
            font-size: 0.78rem; font-weight: 700; color: var(--blue);
            background: var(--blue-soft); border: none !important;
            padding: 6px 12px !important; border-radius: 99px !important;
            width: auto !important; box-shadow: none !important;
            cursor: pointer; white-space: nowrap;
            transition: background 0.15s, transform 0.1s;
        }
        .inbox-see-all-btn:hover { background: rgba(37,99,235,0.16) !important; transform: none !important; box-shadow: none !important; }
        .inbox-see-all-btn:active { transform: scale(0.95) !important; }
        /* Enhanced message item in inbox widget */
        .inbox-msg-item {
            display: flex; align-items: flex-start; gap: 12px;
            padding: 13px 20px; border-bottom: 1px solid var(--border-light);
            transition: background 0.12s; cursor: default;
            position: relative;
        }
        .inbox-msg-item:last-child { border-bottom: none; }
        .inbox-msg-item:hover { background: var(--surface-2); }
        .inbox-msg-item.is-unread { background: rgba(220,38,38,0.03); }
        .inbox-msg-item.is-unread::after {
            content: ''; position: absolute;
            right: 0; top: 0; bottom: 0; width: 3px;
            background: var(--red); border-radius: 0 3px 3px 0;
        }
        .inbox-msg-avatar {
            width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.95rem; font-weight: 800; color: white;
            background: linear-gradient(135deg, var(--blue), #60a5fa);
        }
        .inbox-msg-avatar.unread-avatar {
            background: linear-gradient(135deg, var(--red), #f87171);
        }
        .inbox-msg-content { flex: 1; min-width: 0; }
        .inbox-msg-top {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 2px; gap: 8px;
        }
        .inbox-msg-sender {
            font-size: 0.9rem; font-weight: 700; color: var(--ink);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .inbox-msg-time { font-size: 0.7rem; color: var(--subtle); flex-shrink: 0; }
        .inbox-msg-group-tag {
            display: inline-flex; align-items: center; gap: 4px;
            background: var(--blue-soft); color: var(--blue);
            border-radius: 99px; font-size: 0.65rem; font-weight: 800;
            padding: 2px 8px; margin-bottom: 3px; max-width: 100%;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .inbox-msg-text {
            font-size: 0.85rem; color: var(--muted); line-height: 1.45;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .inbox-msg-text.has-reply { color: var(--green); font-weight: 600; }
        .inbox-empty-state {
            padding: 28px 20px; text-align: center;
            color: var(--subtle); font-size: 0.88rem;
        }
        .inbox-empty-state .empty-icon { font-size: 2rem; display: block; margin-bottom: 8px; opacity: 0.4; }
        /* Dark mode for inbox widget */
        html[data-theme="dark"] #instructor-inbox-home-card { background: var(--surface); }
        html[data-theme="dark"] .inbox-msg-item.is-unread { background: rgba(220,38,38,0.06); }
        html[data-theme="dark"] .inbox-see-all-btn { background: rgba(37,99,235,0.15) !important; color: #60a5fa; }
        html[data-theme="dark"] .inbox-msg-group-tag { background: rgba(37,99,235,0.15); color: #60a5fa; }
        /* BADGE */
        .menu-badge { display: inline-block; background: var(--red); color: white; border-radius: 99px; font-size: 0.62rem; font-weight: 800; padding: 1px 6px; margin-right: 4px; vertical-align: middle; box-shadow: 0 2px 6px rgba(220,38,38,0.35); }
        /* RADIUS PRESETS */
        .radius-preset { flex: 1; font-size: 0.8rem !important; padding: 7px 3px !important; text-align: center; }
        .radius-preset.active-preset, .es-radius-preset.active-preset { background: var(--ink-2) !important; color: white !important; border-color: var(--ink-2) !important; }
        /* SPLASH */
        #splash-screen { background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%) !important; }
        #splash-screen h1 { font-family: 'Syne', sans-serif !important; font-size: 2.5rem !important; font-weight: 800 !important; color: #ffffff !important; letter-spacing: -1px !important; margin-bottom: 6px !important; }
        #splash-screen p { color: rgba(255,255,255,0.7) !important; font-size: 0.82rem !important; letter-spacing: 1.5px !important; text-transform: uppercase !important; }
        /* FAB */
        #fab-install { background: linear-gradient(135deg, var(--red), var(--red-dark)) !important; border-radius: 18px !important; padding: 14px 20px !important; box-shadow: 0 8px 28px rgba(220,38,38,0.38) !important; font-size: 0.86rem !important; line-height: 1.45 !important; text-align: right !important; }
        /* AUTH */
        .auth-card { max-width: 420px; margin: 0 auto 20px; padding: 36px 30px; }
        .auth-card h2 { font-size: 1.45rem; justify-content: center; margin-bottom: 24px; }
        .auth-card h2::before { display: none; }
        #view-auth { max-width: 420px; margin: 0 auto 20px; padding: 36px 30px; }
        .small-date { font-size: 0.74rem; color: var(--muted); display: block; margin-top: 4px; }
        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #9ca3af; }
        /* ANIMATIONS */
        @keyframes blinker { 50% { opacity: 0.5; } }
        @keyframes intenseBlinker { 0% { background-color: #fee2e2; transform: scale(1); } 50% { background-color: #ef4444; color: white; transform: scale(1.012); } 100% { background-color: #fee2e2; transform: scale(1); } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes overlayFadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes sheetSlideUp { from { transform: translateY(100%); opacity: 0.6; } to { transform: translateY(0); opacity: 1; } }
        /* class that JS adds on open to trigger entry animation */
        .modal-overlay > .card.sheet-entering,
        #app-dialog-box.sheet-entering,
        #profile-modal-box.sheet-entering { animation: sheetSlideUp 0.32s cubic-bezier(0.32,0.72,0,1) forwards; }
        /* HIDDEN */
        .hidden { display: none !important; }
        section { animation: fadeInUp 0.28s var(--ease-out) both; }
        .card   { animation: fadeInUp 0.28s var(--ease-out) both; }
        /* מודאלים מקבלים animation משלהם — מבטלים fadeInUp כדי שה-JS יוכל לשלוט ב-transform */
        .modal-overlay > .card,
        .modal-center  > .card { animation: none !important; will-change: transform; }
        #report-container .list-item { animation: none !important; }
        /* Multi-round attendance - legacy dots kept for non-multiround contexts */
        .round-progress { display:flex; gap:4px; align-items:center; margin-top:4px; }
        .round-dot {
            width:10px; height:10px; border-radius:50%;
            flex-shrink:0; transition: background 0.2s;
        }
        .round-dot.present { background: var(--green); }
        .round-dot.absent  { background: #d1d5db; }
        .round-fraction {
            font-size:0.75rem; font-weight:700; color:var(--muted);
            margin-right:2px; white-space:nowrap;
        }
        .round-tab {
            padding: 5px 12px; border-radius: 99px; font-size: 0.8rem;
            font-weight: 700; cursor: pointer; border: 1.5px solid var(--border);
            background: var(--surface); color: var(--muted);
            transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.1s ease, box-shadow 0.15s;
            white-space: nowrap;
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
        }
        .round-tab.active { background: var(--red); color: white; border-color: var(--red); box-shadow: 0 2px 8px rgba(220,38,38,0.25); }
        .round-tab:hover:not(.active) { background: var(--surface-2); color: var(--ink); }
        .round-tab:active { transform: scale(0.90) !important; opacity: 0.85; transition-duration: 0.06s !important; }

        /* ── MULTI-ROUND INLINE ROW ──────────────────────────────────────── */
        .mr-row {
            display: flex; align-items: center;
            padding: 11px 16px; margin-bottom: 6px;
            border-radius: var(--r-md);
            background: var(--surface); border: 1px solid var(--border-light);
            gap: 10px;
            transition: box-shadow 0.15s, border-color 0.15s;
            cursor: default;
        }
        .mr-row:last-child { margin-bottom: 0; }
        .mr-row:hover { border-color: var(--border); box-shadow: var(--shadow-xs); }
        .mr-name {
            font-weight: 700; font-size: 0.93rem; color: var(--ink);
            flex: 1; min-width: 0;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .mr-chips { display: flex; gap: 5px; align-items: center; flex-wrap: nowrap; flex-shrink: 0; }
        .mr-chip {
            display: inline-flex; flex-direction: column; align-items: center;
            padding: 4px 9px; border-radius: 10px;
            font-size: 0.72rem; font-weight: 800; line-height: 1.2;
            cursor: pointer; border: 1.5px solid transparent;
            transition: transform 0.12s var(--ease-bounce), box-shadow 0.12s, opacity 0.1s;
            -webkit-tap-highlight-color: transparent; touch-action: manipulation;
            user-select: none; -webkit-user-select: none;
            white-space: nowrap; min-width: 48px; text-align: center;
        }
        .mr-chip:hover  { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
        .mr-chip:active { transform: scale(0.88) !important; transition-duration: 0.06s !important; }
        .mr-chip-label  { font-size: 0.58rem; font-weight: 600; opacity: 0.75; margin-bottom: 1px; letter-spacing: 0.2px; }
        .mr-chip.c-green  { background: var(--green-soft);          color: var(--green);  border-color: rgba(5,150,105,0.25); }
        .mr-chip.c-red    { background: rgba(220,38,38,0.10);        color: var(--danger); border-color: rgba(220,38,38,0.25); }
        .mr-chip.c-yellow { background: var(--amber-soft);           color: var(--amber);  border-color: rgba(217,119,6,0.25); }
        .mr-chip.c-blue   { background: var(--blue-soft);            color: var(--blue);   border-color: rgba(37,99,235,0.25); }
        .mr-chip.c-grey   { background: var(--surface-3);            color: var(--muted);  border-color: var(--border); }
        .mr-chip.c-warn   { background: var(--amber-soft);           color: var(--amber);  border-color: rgba(217,119,6,0.4); animation: blinker 1.6s ease-in-out infinite; }
        .mr-chip.c-exc    { background: rgba(220,38,38,0.12);        color: var(--danger); border-color: var(--danger);        animation: blinker 1.2s ease-in-out infinite; }
        .mr-chip.is-live  { box-shadow: 0 0 0 2px var(--red-soft); }
        html[data-theme="dark"] .mr-row  { background: var(--surface); }
        html[data-theme="dark"] .mr-chip.c-grey { background: var(--surface-2); }

        /* ── SORT DROPDOWN ───────────────────────────────────────────────── */
        #btn-sort-report { display:flex; align-items:center; }
        .sort-opt {
            padding: 12px 16px;
            font-size: 0.88rem; font-weight: 600; color: var(--ink);
            cursor: pointer;
            border-bottom: 1px solid var(--border-light);
            transition: background 0.12s;
            -webkit-tap-highlight-color: transparent;
        }
        .sort-opt:last-child { border-bottom: none; }
        .sort-opt:hover  { background: var(--surface-2); }
        .sort-opt:active { background: var(--surface-3); }
        .sort-opt.active { color: var(--red); font-weight: 800; background: rgba(220,38,38,0.04); }
        html[data-theme="dark"] .sort-opt:hover  { background: var(--surface-2); }
        html[data-theme="dark"] .sort-opt.active { background: rgba(220,38,38,0.08); }

        /* RESPONSIVE */
        @media (hover: none) {
            /* On touch devices :hover is sticky — suppress hover lifts, rely on :active only */
            button:hover   { transform: none; box-shadow: 0 2px 8px rgba(220,38,38,0.22); }
            button.secondary:hover { box-shadow: 0 2px 8px rgba(13,17,23,0.25); }
            button.outline:hover { transform: none; box-shadow: 0 1px 4px rgba(13,17,23,0.05); }
            .clickable:hover { transform: none; box-shadow: var(--shadow-sm); }
            .tab:hover { background: none; }
        }
        @media (max-width: 380px) { main { padding: 14px 10px 28px; } .card { padding: 18px 16px; } h2 { font-size: 1.15rem; } .tab { padding: 7px 10px; font-size: 0.82rem; } }
            /* העיצוב הזה יפעל רק על השורה עם השם main-admin-row */
.main-admin-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    width: 100%;
}

/* הגדרה לכפתורי ההוספה רק בתוך השורה הזו */
.main-admin-row #btn-add-student, 
.main-admin-row #btn-add-instructor {
    flex: 1;
    min-width: 140px;
}

/* הגדרה לכפתור האקסל רק בתוך השורה הזו */
.main-admin-row #btn-export-csv {
    flex-basis: 100%;
            }
            
        /* ── ADMIN LOG ──────────────────────────────────────── */
        .log-entry {
            display: flex; flex-direction: column; gap: 5px;
            padding: 14px 16px; border-bottom: 1px solid var(--border-light);
            transition: background 0.15s;
            position: relative; overflow: hidden;
        }
        .log-entry:last-child { border-bottom: none; }
        .log-entry:hover { background: var(--surface-2); }
        .log-entry::before {
            content: ''; position: absolute; right: 0; top: 0; bottom: 0; width: 4px;
        }
        .log-attend::before  { background: var(--green); }
        .log-edit::before    { background: var(--blue); }
        .log-delete::before  { background: var(--danger); }
        .log-admin::before   { background: var(--amber); }
        .log-session::before { background: #7c3aed; }
        .log-user::before    { background: #0891b2; }

        .log-header {
            display: flex; align-items: center; justify-content: space-between;
            flex-wrap: wrap; gap: 6px;
        }
        .log-actor {
            display: flex; align-items: center; gap: 8px; font-weight: 700;
            font-size: 0.92rem; color: var(--ink);
        }
        .log-badge {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 2px 10px; border-radius: 99px; font-size: 0.7rem;
            font-weight: 800; white-space: nowrap;
        }
        .log-badge-attend  { background: var(--green-soft);  color: var(--green); }
        .log-badge-edit    { background: var(--blue-soft);   color: var(--blue); }
        .log-badge-delete  { background: var(--red-soft);    color: var(--danger); }
        .log-badge-admin   { background: var(--amber-soft);  color: var(--amber); }
        .log-badge-session { background: rgba(124,58,237,0.10); color: #7c3aed; }
        .log-badge-user    { background: rgba(8,145,178,0.10);  color: #0891b2; }

        .log-details {
            font-size: 0.85rem; color: var(--ink-3); line-height: 1.5;
            padding: 7px 10px; background: var(--surface-3);
            border-radius: var(--r-sm); border: 1px solid var(--border-light);
        }
        .log-time {
            font-size: 0.76rem; color: var(--subtle); font-weight: 600;
            white-space: nowrap;
        }
        .log-stats-bar {
            display: flex; gap: 8px; flex-wrap: wrap; padding: 10px 14px;
            background: var(--surface-2); border-bottom: 1px solid var(--border);
            border-radius: var(--r-md) var(--r-md) 0 0;
        }
        .log-stat-chip {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 10px; border-radius: 99px; font-size: 0.75rem;
            font-weight: 700; background: var(--surface); border: 1px solid var(--border);
            color: var(--ink-3);
        }

        /* ── SVG ICON SYSTEM ────────────────────────────────── */
        .icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 1em; height: 1em; flex-shrink: 0; vertical-align: -0.125em;
            line-height: 1;
        }
        .icon svg { width: 100%; height: 100%; stroke: currentColor; }
        .icon-lg { font-size: 1.35rem; }
        .icon-xl { font-size: 2rem; }
        .icon-2xl { font-size: 2.8rem; }
        .icon-3xl { font-size: 3.5rem; }
        .search-wrap .icon-search {
            position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
            font-size: 0.85rem; pointer-events: none; color: var(--subtle);
        }


        /* ── SVG ICON SYSTEM ────────────────────────────────── */
        .icon {
            display: inline-flex; align-items: center; justify-content: center;
            width: 1em; height: 1em; flex-shrink: 0; vertical-align: -0.125em;
            line-height: 1;
        }
        .icon svg { width: 100%; height: 100%; stroke: currentColor; }
        .icon-lg { font-size: 1.35rem; }
        .icon-xl { font-size: 2rem; }
        .icon-2xl { font-size: 2.8rem; }
        .icon-3xl { font-size: 3.5rem; }
        .search-wrap .icon-search {
            position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
            font-size: 0.85rem; pointer-events: none; color: var(--subtle);
        }

    </style>


        <meta name="google" content="notranslate">
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0"> 
        
</head>
<body>

    <!-- Splash Screen -->
    <div id="splash-screen" style="position:fixed;top:0;left:0;width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;z-index:99999;transition:opacity 0.7s ease;">
        <img id="splash-logo" src="micon2.png" alt="I'm Here" style="width:160px;height:160px;object-fit:contain;border-radius:28px;">
        <div id="splash-divider"></div>
        <h1 style="margin-bottom:4px;">I'm Here</h1>
        <p>מערכת נוכחות חכמה | v1.0.1</p>
    </div>

    <!-- FAB Install -->
    <button id="fab-install" class="hidden" style="position:fixed;bottom:76px;right:20px;z-index:10000;background:var(--red);color:white;border:none;padding:12px 20px;border-radius:30px;box-shadow:0 4px 15px rgba(0,0,0,0.2);cursor:pointer;font-weight:bold;display:flex;flex-direction:column;align-items:center;gap:8px;">
    <span><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></span> שים לב! האפליקציה עדיין לא מותקנת אצלך במכשיר.</span>
    <strong>לחוויה הטובה ביותר התקן קיצור דרך בקליק בלחיצה על הבאנר...</strong>
    </button>
        
    <!-- Header -->
    <header id="app-header" class="hidden">
        <div class="profile-area" id="profile-area-btn">
            <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> <span id="user-display-name">טוען...</span>
            <div id="profile-dropdown" class="dropdown-menu">
                <div class="dropdown-item" id="nav-profile-btn">איזור אישי</div>
                <div id="nav-contact-btn" class="dropdown-item"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span> צור קשר</div>
                <div class="dropdown-item hidden" id="nav-settings-btn"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span> הגדרות</div>
                <div class="dropdown-item" id="nav-info-btn"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg></span> מידע על האפליקציה</div>
                <div id="nav-admin-btn" class="dropdown-item hidden">פאנל ניהול</div>
                <div class="dropdown-item" style="color:var(--danger);" id="nav-logout-btn">התנתקות מהמערכת</div>
            </div>
        </div>
        <div style="font-weight:700;font-size:1.1rem;">I'm Here</div>
    </header>

    <main>
        <!-- AUTH -->
        <section id="view-auth" class="card auth-card">
            <div id="login-section">
                    <!-- Admin login message banner -->
                <div id="login-admin-message" class="hidden" style="background:linear-gradient(135deg,rgba(220,38,38,0.08),rgba(220,38,38,0.04));border:1.5px solid rgba(220,38,38,0.25);border-radius:var(--r-md);padding:14px 16px;margin-bottom:18px;display:flex;gap:10px;align-items:flex-start;">
                    <span style="font-size:1.3rem;flex-shrink:0;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span></span>
                    <p id="login-admin-message-text" style="font-size:0.92rem;color:var(--ink);line-height:1.65;margin:0;font-weight:500;"></p>
                </div>
                <h2 style="display:block;text-align:center;">התחברות מהירה</h2>            
                <form id="form-login">
    <input type="text" id="login-email" placeholder="תעודת זהות" required autocomplete="username">
    <input type="password" id="login-pass" placeholder="סיסמה" required autocomplete="current-password">
    <button type="submit" id="btn-login-submit">היכנס למערכת</button>
    
    <div style="display: flex; gap: 10px; margin-top: 10px;">
        <button type="button" class="outline" id="btn-forgot-password" style="flex: 1; margin: 0;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> שכחתי סיסמה</button>
        <button type="button" class="outline" id="btn-go-register" style="flex: 1; margin: 0;">הרשמה למערכת</button>
    </div>
</form>

            </div>
            <div id="register-section" class="hidden">
                <h2 style="display:block;text-align:center;">הרשמת תלמיד חדש</h2>
                <form id="form-register">
                    <input type="text" id="reg-id" placeholder="תעודת זהות (9 ספרות)" required pattern="[0-9]{8,9}" title="נא להזין תעודת זהות תקינה" autocomplete="username">
                    <input type="text" id="reg-name" placeholder="שם מלא" required autocomplete="name">
                    <input type="password" id="reg-pass" placeholder="בחר סיסמה (לפחות 6 תווים)" required minlength="6" autocomplete="new-password">
                    <button type="submit" id="btn-reg-submit">צור משתמש</button>
                    <button type="button" class="outline" style="margin-top:15px;" id="btn-go-login">חזור למסך ההתחברות</button>
                </form>
            </div>
        </section>

        <!-- PROFILE MODAL — Bottom Sheet -->
        <div id="profile-modal-overlay" class="hidden">
            <div id="profile-modal-box">
                <div id="profile-modal-scroll">
                    <div class="action-row">
                        <button class="outline action-btn-small" id="btn-profile-back"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span> סגור</button>
                    </div>
                    <h2>פרטים אישיים</h2>
                    <div>
                        <label>שם מלא:</label>
                        <input type="text" id="prof-name" disabled>
                        <label>תעודת זהות (כולל מזהה מערכת):</label>
                        <input type="text" id="prof-email" disabled>
                        <h3 style="margin-top:20px;">החלפת סיסמה</h3>
                        <input type="password" id="prof-current-pass" placeholder="סיסמה נוכחית" autocomplete="current-password">
                        <input type="password" id="prof-new-pass" placeholder="סיסמה חדשה (מינימום 6 תווים)" autocomplete="new-password">
                        <input type="password" id="prof-confirm-pass" placeholder="אימות סיסמה חדשה" autocomplete="new-password">
                        <button id="btn-update-password"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span> עדכן סיסמה</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- PROFILE (hidden section, kept for backward-compat with showView calls) -->
        <section id="view-profile" class="hidden" style="display:none!important;"></section>

        <!-- FROZEN USER VIEW -->
        <section id="view-frozen" class="hidden" style="max-width:500px;margin:40px auto;">
            <div class="card" style="text-align:center;padding:40px 28px;">
                <div style="font-size:3.5rem;margin-bottom:16px;"><span class="icon icon-3xl" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span></div>
                <h2 style="justify-content:center;margin-bottom:12px;">חשבונך ממתין לאישור</h2>
                <p style="color:var(--muted);font-size:0.95rem;line-height:1.7;margin-bottom:28px;">
                    כדי לגשת למערכת, שלח הודעה לתמיכה הטכנית עם הפרטים הבאים ומלל רלוונטי והמתן לאישור חשבונך.
                </p>
                <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);padding:18px;margin-bottom:24px;text-align:right;">
                    <label style="margin-bottom:6px;">שם הקורס:</label>
                    <input type="text" id="frozen-course-name" placeholder="לדוגמה: קורס חובשים בכירים מרץ 25 ירקון" style="margin-bottom:12px;">
                    <label style="margin-bottom:6px;">מספר הקורס:</label>
                    <input type="text" id="frozen-course-number" placeholder="6 ספרות, ניתן למצוא במסך הקורס במודל" style="margin-bottom:12px;">
                    <label style="margin-bottom:6px;">פרטים נוספים:</label>
                    <input type="text" id="frozen-instructor-name" placeholder="פרטים נוספים שאתה חושב שרלוונטיים" style="margin-bottom:0;">
                </div>
                <button id="btn-frozen-send" style="margin-bottom:12px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></span> שלח פנייה לתמיכה</button>
                <button class="outline" id="btn-frozen-logout" style="margin-top:0;">התנתקות מהמערכת</button>
            </div>
        </section>

        <!-- ADMIN -->
        <section id="view-admin" class="card hidden">
            <h2>מערכת ניהול</h2>
            <div class="tab-container">
                <div class="tab active" data-admin-tab="users">ניהול משתמשים</div>
                <div class="tab" data-admin-tab="groups">ניהול קבוצות</div>
                <div class="tab" data-admin-tab="dashboard">סקירה מערכתית</div>
                <div class="tab" data-admin-tab="messages"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span> הודעות</div>
                <div class="tab" data-admin-tab="broadcasts">הודעות מערכת</div>
                <div class="tab" data-admin-tab="login-settings"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span> הגדרות כניסה</div>
                <div class="tab" data-admin-tab="log">לוג עריכות</div>
            </div>
            <div id="admin-tab-users">
                <div class="search-wrap"><span class="icon-search"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span></span><input type="text" id="admin-search-user" placeholder="חפש משתמש לפי שם או ת.ז"></div>
                <div id="admin-users-list" style="max-height:400px;overflow-y:auto;"></div>
            </div>
            <div id="admin-tab-groups" class="hidden">
                <button class="secondary action-btn-small" style="margin-bottom:15px;" id="btn-admin-create-group"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span> פתח קבוצה חדשה</button>
                <div id="admin-groups-list" style="max-height:400px;overflow-y:auto;"></div>
            </div>
            <div id="admin-tab-dashboard" class="hidden">
                <div id="admin-stats-container" style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-top:15px;"></div>
            </div>
            <div id="admin-tab-messages" class="hidden">
                <div id="admin-messages-list" style="max-height:500px;overflow-y:auto;"></div>
            </div>
            <div id="admin-tab-broadcasts" class="hidden">
                <button class="secondary action-btn-small" style="margin-bottom:15px;" id="btn-open-broadcast-compose"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> שלח הודעת מערכת חדשה</button>
                <div id="admin-broadcasts-list" style="max-height:450px;overflow-y:auto;"></div>
            </div>
            <!-- LOGIN SETTINGS TAB -->
            <div id="admin-tab-login-settings" class="hidden">
                <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);padding:20px;margin-bottom:16px;">
                    <h3 style="margin-bottom:6px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> הודעה במסך הכניסה</h3>
                    <p style="font-size:0.83rem;color:var(--muted);margin-bottom:14px;line-height:1.6;">הודעה זו תוצג לכל המשתמשים בחלק העליון של מסך ההתחברות. השאר ריק כדי להסתיר את הבאנר.</p>
                    <label>תוכן ההודעה:</label>
                    <textarea id="admin-login-msg-text" rows="4" placeholder="לדוגמה: המערכת תהיה בתחזוקה ביום שישי בין 14:00-16:00. מצטערים על אי הנוחות."></textarea>
                    <button id="btn-save-login-message" style="margin-top:4px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg></span> שמור הודעה</button>
                    <button class="outline" style="margin-top:10px;" id="btn-clear-login-message"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></span> הסר הודעה ממסך הכניסה</button>
                </div>
                <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md);padding:20px;">
                    <h3 style="margin-bottom:6px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> בקשות איפוס סיסמה</h3>
                    <p style="font-size:0.83rem;color:var(--muted);margin-bottom:14px;">בקשות שנשלחו דרך כפתור "שכחתי סיסמה" במסך הכניסה.</p>
                    <button class="outline action-btn-small" style="margin-bottom:14px;" id="btn-refresh-password-requests"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span> רענן</button>
                    <div id="admin-password-requests-list" style="max-height:400px;overflow-y:auto;"></div>
                </div>
            </div>
            <div id="admin-tab-log" class="hidden">
                <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center;">
                    <select id="log-filter-type" style="width:auto;margin-bottom:0;font-size:0.85rem;padding:8px 12px;">
                        <option value="all">כל הפעולות</option>
                        <option value="attend"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> רישומי נוכחות</option>
                        <option value="edit"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span> עריכות נוכחות</option>
                        <option value="delete"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></span> מחיקות</option>
                        <option value="session"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span> ניהול מפגשים</option>
                        <option value="user"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> ניהול משתמשים</option>
                        <option value="admin"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span> הגדרות מערכת</option>
                    </select>
                    <input type="text" id="log-search" placeholder="חיפוש לפי שם / פרטים..." style="flex:1;min-width:140px;margin-bottom:0;font-size:0.85rem;padding:8px 12px;">
                    <button class="outline action-btn-small" id="btn-refresh-log"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span> רענן</button>
                    <button class="outline action-btn-small" id="btn-export-log" style="border-color:var(--green);color:var(--green);"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span> CSV</button>
                </div>
                <div id="admin-log-list" style="max-height:500px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--r-md);background:var(--surface);"></div>
            </div>
        </section>

        <!-- INSTRUCTOR -->
            
<section id="view-instructor" class="hidden">
    <div id="instructor-main">

        <div class="card">
            <h2>הקבוצות שלי</h2>
            <button class="secondary" id="btn-instructor-create-group" style="margin-bottom:20px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span> יצירת קבוצה חדשה</button>
            <div id="instructor-groups-container"></div>
        </div>

        <!-- ── INBOX WIDGET (home screen) ───────────────────────────── -->
        <div id="instructor-inbox-home-card">
            <div class="inbox-header">
                <div class="inbox-header-left">
                    <div class="inbox-title">הודעות נכנסות</div>
                    <span id="inbox-home-unread-pill" class="inbox-unread-pill hidden"></span>
                </div>
                <button class="inbox-see-all-btn" id="btn-inbox-see-all">כל ההודעות ›</button>
            </div>
            <div id="instructor-inbox-home-list">
                <div class="inbox-empty-state"><span class="empty-icon"><span class="icon icon-xl" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span></span>טוען הודעות...</div>
            </div>
        </div>
    </div>

    <div id="instructor-group-details" class="hidden">
        <div class="card">
            <div class="action-row" style="justify-content:space-between;align-items:center;">
                <div style="display:flex;gap:8px;">
                    <button class="outline action-btn-small" id="btn-back-from-group"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span> חזור</button>
                    <button class="outline action-btn-small" id="btn-home-from-group"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span> ראשי</button>
                    <button class="outline action-btn-small" id="btn-refresh-group" title="רענן"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span></button>
                </div>
                <button id="btn-open-inbox" class="outline action-btn-small" style="padding:8px 12px;font-size:1rem;border-color:var(--blue);color:var(--blue);" title="הודעות נכנסות"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span><span id="inbox-badge" class="hidden" style="background:var(--red);color:white;border-radius:99px;font-size:0.65rem;font-weight:800;padding:1px 5px;margin-right:3px;vertical-align:top;"></span></button>
            </div>
            <h2 id="group-name-header">שם הקבוצה</h2>
            <div class="tab-container">
                <div class="tab active" data-group-tab="sessions">מפגשים</div>
                <div class="tab" data-group-tab="students">ניהול הקבוצה</div>
                <div class="tab" data-group-tab="notices">לוח מודעות</div>
            </div>
            <div id="tab-sessions">
                <div class="action-row">
                    <button class="secondary action-btn-small" id="btn-new-session"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span> פתח מפגש</button>
                    <button class="outline action-btn-small" id="btn-toggle-sort"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/><polyline points="5 12 12 5 19 12"/></svg></span> סדר עולה/ יורד</button>
                </div>
                <div id="instructor-sessions-list"></div>
            </div>
            <div id="tab-students" class="hidden">
                <div class="action-row main-admin-row">
    <button class="secondary action-btn-small" id="btn-add-instructor"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span> הוסף מדריך לקורס</button>
    <button class="secondary action-btn-small" id="btn-add-student"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> הוסף חניך (לפי ת.ז)</button>
    
    <button class="outline action-btn-small" id="btn-export-csv"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span> דוח נוכחות מלא (אקסל)</button>
</div>

                <div id="instructor-students-list"></div>
            </div>
            <div id="tab-notices" class="hidden">
                <button class="secondary action-btn-small" style="margin-bottom:15px;" id="btn-add-notice"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span> פרסם הודעה חדשה לחניכים</button>
                <div id="instructor-notices-list"></div>
            </div>
        </div>
    </div>

    <div id="session-report-view" class="hidden">
        <div class="card">
            <div style="display:flex; flex-direction:column; gap:12px; margin-bottom:20px;">
                <div class="action-row" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; width:100%;">
                    <button class="outline action-btn-small" id="btn-back-to-group" style="flex: 1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span> חזור</button>
                    <button class="outline action-btn-small" id="btn-home-from-session" style="flex: 1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span> ראשי</button>
                    <button class="outline action-btn-small" id="btn-refresh-session" title="רענן" style="padding:8px 10px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span></button>
                    <button id="btn-edit-session" class="outline action-btn-small" style="flex: 1; border-color:var(--blue); color:var(--blue);"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span> ערוך</button>
                    <button id="btn-lock-session" class="action-btn-small" style="flex: 1; background:#b91c1c; padding:9px 12px; font-size:0.85rem;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span> סגור</button>
                </div>
            </div>

            <h2 id="report-title">נוכחות חיה</h2>
            <!-- round-nav-bar removed: rounds now shown inline per student row -->
            <p id="bypass-status-text" class="text-orange hidden" style="margin-bottom:10px; font-weight:bold;"></p>
            <p id="session-radius-info" class="hidden" style="font-size:0.85rem; color:var(--muted); margin-bottom:10px;"></p>
            
            <div class="action-row" style="display:flex; gap:8px; margin-bottom:8px;">
                <button class="outline action-btn-small" id="btn-copy-session" style="flex:1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></span> העתק דו"ח מהיר</button>
                <button class="outline action-btn-small" id="btn-download-session-csv" style="flex:1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></span> הורד אקסל (CSV)</button>
                <button class="secondary action-btn-small" id="btn-add-round" style="flex:1;display:none;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></span>🔔 בדיקה נוספת</button>
            </div>

            <!-- Sort bar -->
            <div style="position:relative; margin-bottom:12px;">
                <button class="outline action-btn-small" id="btn-sort-report" style="width:100%; justify-content:center; gap:6px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
                    <span id="sort-btn-label">מיין לפי</span>
                </button>
                <div id="sort-dropdown" class="hidden" style="position:absolute;top:calc(100% + 4px);right:0;left:0;z-index:200;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-md);box-shadow:var(--shadow-md);overflow:hidden;">
                    <div class="sort-opt" data-key="status" data-dir="asc">סטטוס — עולה</div>
                    <div class="sort-opt" data-key="status" data-dir="desc">סטטוס — יורד</div>
                    <div class="sort-opt" data-key="name" data-dir="asc">שם — א׳ עד ת׳</div>
                    <div class="sort-opt" data-key="name" data-dir="desc">שם — ת׳ עד א׳</div>
                    <div class="sort-opt" data-key="time" data-dir="asc">זמן הגעה — מוקדם לאחרון</div>
                    <div class="sort-opt" data-key="time" data-dir="desc">זמן הגעה — מאוחר לראשון</div>
                </div>
            </div>

            <div id="report-container"></div>
        </div> </div> </section> 



        <!-- STUDENT -->
        <section id="view-student" class="hidden">
            <div id="student-main-dashboard">
                <div id="student-stats-container" style="margin-bottom:20px;"></div>
                <div id="student-active-alerts"></div>
                <div class="card">
                    <h2>הקורסים שלי</h2>
                    <div id="student-groups-container"></div>
                </div>
            </div>
            <div id="student-group-details" class="hidden">
                <div class="card">
                    <div class="action-row">
                        <button class="outline action-btn-small" id="btn-student-back"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></span> חזור</button>
                        <button class="outline action-btn-small" id="btn-student-home"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span> ראשי</button>
                        <button class="outline action-btn-small" id="btn-refresh-student-group" title="רענן"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></span></button>
                    </div>
                    <h2 id="student-group-name-header">שם הקבוצה</h2>
                    <h3 style="margin-top:15px;margin-bottom:10px;">מפגשים קודמים</h3>
                    <div id="student-history-list"></div>
                </div>
            </div>
        </section>
    </main>

    <!-- MODALS -->
    <div id="create-group-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;margin:0;">
            <h3>פתיחת קבוצה חדשה</h3>
            <input type="text" id="cg-name" placeholder="שם הקבוצה">
            <button id="btn-submit-new-group">שמור קבוצה</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-group-modal">ביטול</button>
        </div>
    </div>

    <div id="new-session-modal" class="modal-center hidden">
        <div class="card" style="width:100%;max-width:460px;margin:0;">
            <h3>יצירת מפגש חדש</h3>
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">מספר מפגש:</label>
            <input type="number" id="ns-num">
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">שעת התחלה (לרישום איחור):</label>
            <input type="time" id="ns-start">
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">שעת סיום (אופציונלי):</label>
            <input type="time" id="ns-end">
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">רדיוס נוכחות במטרים:</label>
            <div style="position:relative;">
                <input type="number" id="ns-radius" min="10" max="2000" value="50" step="5">
                <span style="position:absolute;left:14px;top:50%;transform:translateY(-60%);font-size:0.82rem;color:var(--muted);font-weight:600;pointer-events:none;">מ׳</span>
            </div>
            <div style="display:flex;gap:8px;margin-bottom:14px;">
                <button type="button" class="radius-preset outline action-btn-small" data-val="25">25 מ׳</button>
                <button type="button" class="radius-preset outline action-btn-small active-preset" data-val="50">50 מ׳</button>
                <button type="button" class="radius-preset outline action-btn-small" data-val="150">150 מ׳</button>
                <button type="button" class="radius-preset outline action-btn-small" data-val="300">300 מ׳</button>
            </div>
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> קוד כניסה (אופציונלי):</label>
            <div style="display:flex;gap:8px;margin-bottom:14px;">
                <input type="text" id="ns-access-code" placeholder="ריק = ללא קוד" style="margin-bottom:0;flex:1;letter-spacing:2px;font-size:1.1rem;font-weight:700;">
                <button type="button" class="outline action-btn-small" id="btn-gen-code" style="width:auto;flex-shrink:0;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4" ry="4"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="16" cy="8" r="1.5" fill="currentColor"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/></svg></span> הגרל</button>
            </div>
            <button id="btn-create-session">פתח ודגום מיקום <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span></button>
            <button id="btn-create-session-no-gps" class="outline" style="margin-top:10px;border-color:var(--amber);color:var(--amber);"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span> פתח ללא GPS (תלמידים לא יאומתו)</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-session-modal">ביטול</button>
        </div>
    </div>

    <div id="edit-student-modal" class="modal-center hidden">
        <div class="card" style="width:100%;max-width:380px;margin:0;">
            <h3 id="es-name">עדכון חניך</h3>
            <p id="es-exception-info" style="color:var(--danger);font-weight:bold;margin-bottom:10px;"></p>
            <!-- es-late-mins hidden — shown only via late-minutes prompt dialog -->
            <input type="number" id="es-late-mins" placeholder="0" style="display:none;">
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:15px;">
                <button class="bg-green" id="btn-status-on-time">נוכח <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></button>
                <button class="bg-yellow" id="btn-status-late">איחור <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span></button>
                <button class="bg-blue" id="btn-status-excused">חיסור באישור</button>
                <button class="secondary" id="btn-snooze-action">לטיפול בהמשך <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg></span></button>
                <button class="bg-red" id="btn-status-absent">חיסור <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span></button>
                <button class="outline" id="btn-close-edit-student">סגור</button>
            </div>
        </div>
    </div>

    <div id="exception-alert-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;margin:0;text-align:center;border-top:4px solid var(--danger);">
            <h3 style="color:var(--danger);margin-bottom:10px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span> התקבלה בקשה חריגה</h3>
            <p id="eam-text" style="font-size:1.1rem;margin-bottom:20px;"></p>
            <button class="outline" id="btn-close-exception-alert">הבנתי, עבור לטיפול</button>
        </div>
    </div>

    <div id="student-history-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;max-height:80vh;overflow-y:auto;margin:0;">
            <h3 id="sh-name">היסטוריה</h3>
            <div id="sh-list"></div>
            <button class="outline" id="btn-close-history-modal" style="margin-top:15px;">סגור</button>
        </div>
    </div>

    <!-- ACCESS CODE ENTRY MODAL -->
    <div id="access-code-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:360px;text-align:center;margin:0;">
            <h3 style="margin-bottom:8px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> קוד כניסה למפגש</h3>
            <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px;">המדריך הגדיר קוד כניסה. הזן אותו כדי לדווח נוכחות.</p>
            <input type="number" id="student-access-code-input" placeholder="הזן קוד" style="text-align:center;font-size:1.5rem;font-weight:800;letter-spacing:4px;margin-bottom:12px;">
            <button id="btn-submit-access-code">אשר קוד <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></button>
            <button class="outline" style="margin-top:8px;" id="btn-cancel-access-code">ביטול</button>
        </div>
    </div>

    <div id="location-retry-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;text-align:center;margin:0;">
            <h3 style="color:var(--danger);">שגיאת מיקום <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span></h3>
            <p style="margin-bottom:15px;font-size:0.95rem;line-height:1.5;">
                המערכת לא הצליחה לזהות אותך במיקום המפגש.<br>
                <b>מה לעשות?</b><br>
                1. ודא שה-GPS שלך דולק.<br>
                2. גש למיקום קרוב יותר למדריך.<br>
                3. כבה מצב חיסכון בסוללה.
            </p>
            <button id="btn-retry-location" class="bg-yellow" style="color:white;">נסה שוב</button>
            <button id="btn-send-exception" class="secondary hidden" style="margin-top:10px;">שלח בקשה חריגה למדריך <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg></span></button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-retry-modal">ביטול</button>
        </div>
    </div>

    <div id="add-notice-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;margin:0;">
            <h3>הודעה חדשה לחניכים</h3>
            <textarea id="notice-text" rows="4" placeholder="תוכן ההודעה..."></textarea>
            <button id="btn-submit-notice">פרסם הודעה</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-notice-modal">ביטול</button>
        </div>
    </div>

    <div id="admin-edit-user-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:400px;margin:0;">
            <h3>עריכת משתמש</h3>
            <input type="hidden" id="admin-eu-id">
            <label>שם:</label>
            <input type="text" id="admin-eu-name">
            <label>תפקיד:</label>
            <select id="admin-eu-role">
                <option value="frozen">קפוא (ממתין לאישור)</option>
                <option value="student">תלמיד</option>
                <option value="instructor">מדריך</option>
                <option value="admin">מנהל מערכת</option>
            </select>
            <button id="btn-save-admin-user">שמור שינויים</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-admin-user-modal">ביטול</button>
        </div>
    </div>

    <div id="ios-install-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:350px;text-align:center;margin:0;">
            <h3>התקנת האפליקציה במכשיר אייפון</h3>
            <p style="margin:15px 0;">כדי להתקין את המערכת על האייפון שלך:</p>
            <ol style="text-align:right;margin-bottom:20px;padding-right:20px;">
                <li>לחץ על כפתור השיתוף (Share) בתחתית המסך.</li>
                <li>גלול למטה ולחץ על <strong>"הוסף למסך הבית" (Add to Home Screen)</strong>.</li>
            </ol>
            <button id="btn-close-ios-modal">הבנתי, אני אעשה את זה</button>
        </div>
    </div>

    <!-- FORGOT PASSWORD MODAL -->
    <div id="forgot-password-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:440px;margin:0;max-height:90vh;overflow-y:auto;">
            <div style="text-align:center;margin-bottom:20px;">
                <div style="font-size:2.8rem;margin-bottom:10px;"><span class="icon icon-2xl" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span></div>
                <h3 style="font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;margin-bottom:6px;">בקשת איפוס סיסמה</h3>
                <p style="font-size:0.85rem;color:var(--muted);line-height:1.6;">מלא את הפרטים הבאים ובקשתך תישלח לצוות התמיכה לטיפול.</p>
            </div>
            <label>שם מלא:</label>
            <input type="text" id="fp-fullname" placeholder="הזן שם פרטי ומשפחה">
            <label>תעודת זהות:</label>
            <input type="text" id="fp-id" placeholder="9 ספרות" maxlength="9" pattern="[0-9]{8,9}">
            <label>מספר טלפון:</label>
            <input type="tel" id="fp-phone" placeholder="לדוגמה: 050-1234567">
            <label>סיבת הבקשה:</label>
            <textarea id="fp-reason" rows="3" placeholder="לדוגמה: שכחתי את הסיסמה שלי, לא הצלחתי להתחבר..."></textarea>
            <button id="btn-send-forgot-password" style="margin-top:4px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></span> שלח בקשה לתמיכה</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-forgot-password">ביטול</button>
        </div>
    </div>

    <!-- APP DIALOG (replaces alert / confirm / prompt) -->
    <div id="app-dialog-overlay" class="hidden">
        <div id="app-dialog-box">
            <div id="app-dialog-title"></div>
            <div id="app-dialog-message"></div>
            <input type="text" id="app-dialog-input" placeholder="">
            <div id="app-dialog-actions"></div>
        </div>
    </div>

    <!-- SYSTEM BROADCAST MODAL -->
    <div id="broadcast-modal-overlay" class="hidden">
        <div id="broadcast-modal-box">
            <div id="broadcast-modal-title"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> הודעת מערכת</div>
            <div id="broadcast-modal-body"></div>
            <button id="broadcast-confirm-btn">קראתי ומאשר <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></button>
        </div>
    </div>

    <!-- ADMIN BROADCAST COMPOSE MODAL -->
    <div id="admin-broadcast-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:460px;margin:0;max-height:90vh;overflow-y:auto;">
            <h3><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> שליחת הודעת מערכת</h3>
            <label>תוכן ההודעה:</label>
            <textarea id="bc-text" rows="4" placeholder="הקלד את תוכן ההודעה..."></textarea>
            <label>שלח אל:</label>
            <select id="bc-target">
                <option value="all">כל המשתמשים</option>
                <option value="students">תלמידים בלבד</option>
                <option value="instructors">מדריכים בלבד</option>
                <option value="group">קבוצה ספציפית</option>
                <option value="specific_students">חניכים ספציפיים (בחירה)</option>
            </select>
            <div id="bc-group-select-wrap" class="hidden">
                <label>בחר קבוצה:</label>
                <select id="bc-group-id"></select>
            </div>
            <div id="bc-students-select-wrap" class="hidden">
                <label>בחר חניכים (ניתן לבחור כמה):</label>
                <div id="bc-students-list" style="max-height:200px;overflow-y:auto;border:1.5px solid var(--border);border-radius:var(--r-md);padding:8px;background:var(--surface-2);"></div>
            </div>
            <button id="btn-send-broadcast">שלח הודעה לכולם <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span></button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-broadcast-modal">ביטול</button>
        </div>
    </div>

    <!-- CONTACT COMPOSE MODAL -->
    <div id="contact-compose-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:440px;margin:0;max-height:90vh;overflow-y:auto;">
            <h3><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span> צור קשר</h3>
            <label>שלח אל:</label>
            <select id="contact-recipient">
                <option value="instructor">המדריך שלי</option>
                <option value="support">תמיכה</option>
            </select>
            <div id="contact-instructor-select-wrap" class="hidden">
                <label>בחר מדריך:</label>
                <select id="contact-instructor-id"></select>
            </div>
            <label>תוכן ההודעה:</label>
            <textarea id="contact-text" rows="5" placeholder="כתוב את הודעתך כאן..."></textarea>
            <button id="btn-send-contact">שלח הודעה <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg></span></button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-contact-modal">ביטול</button>
        </div>
    </div>

    <!-- CONTACT REPLY MODAL (instructor / admin) -->
    <div id="contact-reply-modal" class="modal-overlay hidden" style="z-index:25000;">
        <div class="card" style="width:100%;max-width:440px;margin:0;max-height:90vh;overflow-y:auto;">
            <h3 id="reply-modal-title">השב להודעה</h3>
            <input type="hidden" id="reply-msg-id">
            <div id="reply-original-msg" style="background:var(--surface-2);border-radius:var(--r-sm);padding:12px;margin-bottom:16px;font-size:0.9rem;color:var(--ink-3);line-height:1.6;border-right:3px solid var(--blue);"></div>
            <label>תגובה:</label>
            <textarea id="reply-text" rows="4" placeholder="כתוב תגובה..."></textarea>
            <button id="btn-send-reply">שלח תגובה</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-reply-modal">ביטול</button>
        </div>
    </div>

    <!-- CONTACT REPLY POPUP (student/instructor sees reply) -->
    <div id="contact-reply-popup-overlay" class="hidden" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(10,15,25,0.65);backdrop-filter:blur(6px);display:flex;align-items:flex-end;justify-content:center;z-index:35000;padding:0;">
        <div style="background:var(--surface);border-radius:22px 22px 0 0;border-top:4px solid var(--green);padding:8px 28px 36px;width:100%;max-width:560px;box-shadow:0 -8px 40px rgba(0,0,0,0.18);animation:sheetSlideUp 0.32s cubic-bezier(0.32,0.72,0,1) forwards;">
            <div style="width:36px;height:4px;background:rgba(5,150,105,0.3);border-radius:99px;margin:10px auto 18px;"></div>
            <p style="font-size:0.8rem;font-weight:700;color:var(--green);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span> תגובה להודעתך</p>
            <p id="reply-popup-from" style="font-size:0.85rem;color:var(--muted);margin-bottom:12px;"></p>
            <p id="reply-popup-text" style="font-size:1rem;color:var(--ink);line-height:1.7;margin-bottom:20px;"></p>
            <button id="btn-confirm-reply-popup">מאשר <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></button>
        </div>
    </div>

    <!-- INSTRUCTOR INBOX MODAL -->
    <div id="instructor-inbox-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:460px;margin:0;max-height:88vh;display:flex;flex-direction:column;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <h3 style="margin:0;font-family:'Syne',sans-serif;font-weight:800;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg></span> הודעות נכנסות</h3>
                    <span id="inbox-modal-unread-pill" class="inbox-unread-pill hidden" style="font-size:0.6rem;"></span>
                </div>
                <button class="outline action-btn-small" id="btn-close-inbox-modal" style="width:auto;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span> סגור</button>
            </div>
            <div id="instructor-inbox-list" style="overflow-y:auto;flex:1;"></div>
        </div>
    </div>


    <!-- EDIT SESSION MODAL -->
    <div id="edit-session-modal" class="modal-center hidden">
        <div class="card" style="width:100%;max-width:460px;margin:0;">
            <h3><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span> עריכת פרטי מפגש</h3>
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">שעת התחלה:</label>
            <input type="time" id="es-session-start">
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">שעת סיום:</label>
            <input type="time" id="es-session-end">
            <label style="font-weight:500;font-size:0.9rem;margin-bottom:4px;display:block;">רדיוס נוכחות במטרים:</label>
            <div style="position:relative;">
                <input type="number" id="es-session-radius" min="10" max="2000" step="5">
                <span style="position:absolute;left:14px;top:50%;transform:translateY(-60%);font-size:0.82rem;color:var(--muted);font-weight:600;pointer-events:none;">מ׳</span>
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 14px; width: 100%; flex-wrap: nowrap;">
    <button type="button" class="es-radius-preset outline action-btn-small" data-val="25" style="flex: 1 1 auto; white-space: nowrap;">25 מ</button>
    <button type="button" class="es-radius-preset outline action-btn-small" data-val="50" style="flex: 1 1 auto; white-space: nowrap;">50 מ</button>
    <button type="button" class="es-radius-preset outline action-btn-small" data-val="150" style="flex: 1 1 auto; white-space: nowrap;">150 מ</button>
    <button type="button" class="es-radius-preset outline action-btn-small" data-val="300" style="flex: 1 1 auto; white-space: nowrap;">300 מ</button>
    <button id="btn-bypass-gps" class="action-btn-small bg-purple" style="flex: 3 1 auto; white-space: nowrap;">שחרר ל-5 דק' <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></span></button>
</div>

            <button id="btn-resample-location" class="secondary" style="margin-bottom:10px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span> דגום מיקום מחדש</button>
            <p id="es-location-status" style="font-size:0.82rem;color:var(--muted);margin-bottom:14px;text-align:center;"></p>
            <div style="margin-top:10px;padding-top:12px;border-top:1px solid var(--border);">
                <label style="font-weight:600;font-size:0.88rem;margin-bottom:6px;display:block;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> קוד כניסה:</label>
                <div id="es-current-code-display" style="font-size:1.3rem;font-weight:800;letter-spacing:3px;text-align:center;background:var(--surface-3);border:1.5px solid var(--border);border-radius:var(--r-md);padding:8px 12px;margin-bottom:8px;"></div>
                <div style="display:flex;gap:8px;margin-bottom:8px;">
                    <input type="text" id="es-new-code" placeholder="קוד חדש (ריק = הסר קוד)" style="margin-bottom:0;flex:1;letter-spacing:2px;font-size:1.05rem;">
                    <button type="button" class="outline action-btn-small" id="btn-es-gen-code" style="width:auto;flex-shrink:0;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="4" ry="4"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="16" cy="8" r="1.5" fill="currentColor"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/></svg></span></button>
                </div>
                <button type="button" class="secondary action-btn-small" id="btn-update-code" style="width:100%;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></span> עדכן קוד</button>
            </div>
            <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">
                <label style="font-weight:600;font-size:0.88rem;margin-bottom:6px;display:block;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg></span> דקות חסד לאיחור:</label>
                <div style="display:flex;gap:8px;align-items:center;margin-bottom:8px;">
                    <input type="number" id="es-grace-mins" min="0" max="60" style="margin-bottom:0;flex:1;text-align:center;font-size:1.1rem;font-weight:700;">
                    <span style="font-size:0.88rem;color:var(--muted);flex-shrink:0;">דקות</span>
                </div>
                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=0">0</button>
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=5">5</button>
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=10">10</button>
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=15">15</button>
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=20">20</button>
                    <button type="button" class="outline action-btn-small" onclick="document.getElementById('es-grace-mins').value=30">30</button>
                </div>
            </div>
            <button id="btn-save-session-edit" style="margin-top:12px;">שמור שינויים</button>
            <button class="outline" style="margin-top:10px;" id="btn-cancel-edit-session-modal">ביטול</button>
        </div>
    </div>


    <!-- SETTINGS MODAL -->
    <div id="settings-modal" class="modal-overlay hidden">
        <div class="card" style="width:100%;max-width:420px;margin:0;">
            <h3 style="margin-bottom:16px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span> הגדרות</h3>

            <!-- INSTRUCTOR: grace minutes -->
            <div id="settings-instructor-section">
                <label style="font-weight:700;font-size:0.9rem;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22v-4.172a2 2 0 0 0-.586-1.414L12 12l-4.414 4.414A2 2 0 0 0 7 17.828V22"/><path d="M7 2v4.172a2 2 0 0 0 .586 1.414L12 12l4.414-4.414A2 2 0 0 0 17 6.172V2"/></svg></span> דקות חסד לאיחור</label>
                <p style="font-size:0.8rem;color:var(--muted);margin-bottom:10px;">כמה דקות אחרי שעת ההתחלה יחשב התלמיד כמאחר (כברירת מחדל: 15 דקות)</p>
                <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center;">
                    <input type="number" id="settings-grace-mins" min="0" max="60" value="15" style="margin-bottom:0;flex:1;text-align:center;font-size:1.2rem;font-weight:700;">
                    <span style="font-size:0.9rem;color:var(--muted);flex-shrink:0;">דקות</span>
                </div>
                <div style="display:flex;gap:6px;margin-bottom:18px;">
                    <button type="button" class="outline action-btn-small" data-grace="5">5</button>
                    <button type="button" class="outline action-btn-small" data-grace="10">10</button>
                    <button type="button" class="outline action-btn-small" data-grace="15">15</button>
                    <button type="button" class="outline action-btn-small" data-grace="20">20</button>
                    <button type="button" class="outline action-btn-small" data-grace="30">30</button>
                </div>
            </div>

            <!-- APPEARANCE & LANGUAGE (all users) -->
            <div style="padding-top:14px;border-top:1px solid var(--border-light);margin-bottom:16px;">
                <label style="font-weight:700;font-size:0.9rem;margin-bottom:10px;display:block;">מצב תצוגה</label>
                <div style="display:flex;gap:8px;margin-bottom:16px;">
                    <button type="button" class="outline action-btn-small" id="btn-theme-light" style="flex:1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></span> בהיר</button>
                    <button type="button" class="outline action-btn-small" id="btn-theme-dark" style="flex:1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span> כהה</button>
                    <button type="button" class="outline action-btn-small" id="btn-theme-system" style="flex:1;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></span> מערכת</button>
                </div>
                <label style="font-weight:700;font-size:0.9rem;margin-bottom:10px;display:block;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span> שפה</label>
                <div style="display:flex;gap:8px;">
                    <button type="button" class="outline action-btn-small" id="btn-lang-he" style="flex:1;">עברית</button>
                    <button type="button" class="outline action-btn-small" id="btn-lang-en" style="flex:1;">English</button>
                    <button type="button" class="outline action-btn-small" id="btn-lang-ar" style="flex:1;">العربية</button>
                </div>
            </div>

            <button id="btn-save-settings">שמור הגדרות <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></button>
            <button class="outline" style="margin-top:10px;" id="btn-close-settings">סגור</button>
        </div>
    </div>

    <!-- APP INFO MODAL (center dialog, mandatory on first load) -->


<div id="app-info-modal" class="modal-center hidden">
    <div class="card" style="width:100%; max-width:440px; margin:0; padding:0 !important; border-radius:var(--r-xl) !important; overflow:hidden; display:flex; flex-direction:column; max-height:90vh;">

        <div style="text-align:center; padding:28px 24px 16px; flex-shrink:0;">
            <div style="font-size:2.8rem; margin-bottom:8px;"><span class="icon icon-2xl" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></span></div>
            <h3 style="font-family:'Syne',sans-serif; font-size:1.4rem; font-weight:800; margin-bottom:4px; color:var(--ink);">I'm Here</h3>
            <p style="font-size:0.85rem; color:var(--muted); margin:0;">מערכת נוכחות חכמה | v1.0.1</p>
            <p style="font-size:0.8rem; color:var(--green); font-weight:700; margin-top:4px;"><span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg></span> קוד פתוח (Open Source)</p>
        </div>

        <div style="flex:1; overflow-y:auto; padding:0 24px 16px; -webkit-overflow-scrolling:touch;">
            <div style="display:flex; flex-direction:column; gap:12px;">

                <div style="display:flex; gap:12px; align-items:flex-start; padding:14px; background:var(--surface-2); border-radius:16px; border:1px solid var(--border-light);">
                    <span style="font-size:1.4rem; flex-shrink:0;"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span></span>
                    <div>
                        <p style="font-weight:700; font-size:0.92rem; margin-bottom:3px;">מאובטח לחלוטין</p>
                        <p style="font-size:0.83rem; color:var(--muted); line-height:1.5;">האפליקציה לא ניגשת לאנשי הקשר שלך, לתמונות, למיקרופון, לנתונים אישיים או לכל מידע אחר פרט למיקום GPS לאימות נוכחות בלבד.</p>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:flex-start; padding:14px; background:var(--surface-2); border-radius:16px; border:1px solid var(--border-light);">
                    <span style="font-size:1.4rem; flex-shrink:0;"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span></span>
                    <div>
                        <p style="font-weight:700; font-size:0.92rem; margin-bottom:3px;">GPS לאימות נוכחות בלבד</p>
                        <p style="font-size:0.83rem; color:var(--muted); line-height:1.5;">המיקום נמדד רק לצורך אימות מיקום המשתמש בזמן אמת לפי הוראתו ולא מתבצע בזמן שהאפליקציה לא פעילה.</p>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:flex-start; padding:14px; background:var(--surface-2); border-radius:16px; border:1px solid var(--border-light);">
                    <span style="font-size:1.4rem; flex-shrink:0;"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg></span></span>
                    <div>
                        <p style="font-weight:700; font-size:0.92rem; margin-bottom:3px;">לא מבזבז מקום</p>
                        <p style="font-size:0.83rem; color:var(--muted); line-height:1.5;">האפליקציה היא Web App — אין הורדה, אין עדכונים ידניים, ותופסת פחות מ-1MB. ניתן להתקין על מסך הבית לנוחות מרבית.</p>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:flex-start; padding:14px; background:var(--surface-2); border-radius:16px; border:1px solid var(--border-light);">
                    <span style="font-size:1.4rem; flex-shrink:0;"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span></span>
                    <div>
                        <p style="font-weight:700; font-size:0.92rem; margin-bottom:3px;">ללא הרשאות מיוחדות</p>
                        <p style="font-size:0.83rem; color:var(--muted); line-height:1.5;">ההרשאה היחידה שנדרשת היא GPS לאימות מיקום. שאר ההרשאות (מצלמה, אנשי קשר, מיקרופון) לא נדרשות ולא מבוקשות.</p>
                    </div>
                </div>

                <div style="display:flex; gap:12px; align-items:flex-start; padding:14px; background:var(--surface-2); border-radius:16px; border:1px solid var(--border-light);">
                    <span style="font-size:1.4rem; flex-shrink:0;"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg></span></span>
                    <div>
                        <p style="font-weight:700; font-size:0.92rem; margin-bottom:3px;">קוד פתוח (Open Source)</p>
                        <p style="font-size:0.83rem; color:var(--muted); line-height:1.5;">האפליקציה היא פרויקט קוד פתוח — הקוד שלה זמין לעיון, ביקורת ושיפור על ידי כל אחד. שקיפות מלאה, ללא סודות.</p>
                    </div>
                </div>

            </div>
        </div>

        <div style="padding:16px 24px 24px; flex-shrink:0; border-top:1px solid var(--border-light);">
            <button id="btn-close-info-modal" style="width:100%; padding:16px; border-radius:16px; font-weight:800; font-size:1rem; box-shadow:0 4px 12px rgba(220,38,38,0.2);">
                אהבתי, תודה! <span class="icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg></span>
            </button>
        </div>
    </div>
</div>


    <!-- BOTTOM NAV -->
    <nav id="bottom-nav">
        <button class="bn-item active" id="bn-home">
            <span class="bn-icon"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span></span>
            <span class="bn-label">ראשי</span>
        </button>
        <button class="bn-item" id="bn-contact">
            <span class="bn-icon"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span></span>
            <span class="bn-label" id="bn-contact-label">הודעות</span>
            <span id="bn-contact-badge" class="bn-badge hidden"></span>
        </button>
        <button class="bn-item" id="bn-profile">
            <span class="bn-icon"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span></span>
            <span class="bn-label">פרופיל</span>
        </button>
        <button class="bn-item hidden" id="bn-admin">
            <span class="bn-icon"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span></span>
            <span class="bn-label">ניהול</span>
        </button>
        <button class="bn-item" id="bn-settings">
            <span class="bn-icon"><span class="icon icon-lg" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span></span>
            <span class="bn-label">הגדרות</span>
        </button>
    </nav>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, createUserWithEmailAndPassword, onAuthStateChanged, signOut, updatePassword, reauthenticateWithCredential, EmailAuthProvider } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-auth.js";
        import { getFirestore, doc, getDoc, setDoc, collection, addDoc, query, where, getDocs, updateDoc, deleteField, orderBy, limit, serverTimestamp, onSnapshot, arrayUnion, arrayRemove, deleteDoc } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore.js";

        // =====================================================
        // FIREBASE CONFIG
        // =====================================================
        const firebaseConfig = {
            apiKey: "AIzaSyADVI0SVjJLWedUmfbqBYtlgw1BslfXtMY",
            authDomain: "attendancemda.firebaseapp.com",
            projectId: "attendancemda",
            storageBucket: "attendancemda.firebasestorage.app",
            messagingSenderId: "303165146059",
            appId: "1:303165146059:web:cf698f5837c0ee96702c4e"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        // =====================================================
        // APP STATE
        // =====================================================
        const state = {
            userData: null,
            curGroupId: null,
            curSessionId: null,
            curEditUid: null,
            liveUnsubscribe: null,
            sessionsUnsubscribe: null,
            membersCache: [],
            sessionSort: 'desc',
            allSessionsCache: [],
            liveSessionData: null,
            _loadingStudents: false,
            liveSessionNumber: null,
            adminUsersCache: [],
            pendingBroadcastId: null,
            pendingReplyMsgId: null,
            viewingRound: null,      // null = current live round; 0,1,2 = archived round index
            graceMins: parseInt(localStorage.getItem('imhere_grace_mins') || '15'), // instructor late grace period
            _curStudentGroupId: null,
            _curStudentGroupName: null,
            // OFFLINE QUEUE: attendance records saved to localStorage when offline,
            // automatically synced to Firestore when connectivity is restored.
            offlineQueue: JSON.parse(localStorage.getItem('attendanceOfflineQueue') || '[]'),
        };

        // =====================================================
        // OFFLINE ATTENDANCE QUEUE
        // =====================================================
        function saveOfflineQueue() {
            localStorage.setItem('attendanceOfflineQueue', JSON.stringify(state.offlineQueue));
        }

        function queueOfflineAttendance(gid, sid, uid, dataToSave) {
            // Remove any existing pending entry for the same session+user (dedup)
            state.offlineQueue = state.offlineQueue.filter(e => !(e.gid === gid && e.sid === sid && e.uid === uid));
            state.offlineQueue.push({ gid, sid, uid, dataToSave, queuedAt: Date.now() });
            saveOfflineQueue();
        }

        async function syncOfflineQueue() {
            if (state.offlineQueue.length === 0) return;
            const toSync = [...state.offlineQueue];
            let synced = 0, failed = 0;
            for (const entry of toSync) {
                try {
                    // Replace the client-side timestamp placeholder with a real serverTimestamp
                    const data = { ...entry.dataToSave, timestamp: serverTimestamp() };
                    await updateDoc(doc(db, "groups", entry.gid, "sessions", entry.sid), {
                        [`attendance.${entry.uid}`]: data,
                        [`exceptions.${entry.uid}`]: deleteField()
                    });
                    state.offlineQueue = state.offlineQueue.filter(e => e !== entry);
                    synced++;
                } catch (err) {
                    console.warn('Offline queue sync failed for entry:', entry, err);
                    failed++;
                }
            }
            saveOfflineQueue();
            if (synced > 0) {
                showToast(`${synced} רישום נוכחות מהתור האופליין סונכרן בהצלחה`, 'success');
                loadStudentMain();
            }
            if (failed > 0) {
                showToast(`${failed} רישומים לא הצליחו להתסנכרן — נסה שוב`, 'warning');
            }
        }

        // =====================================================
        // UTILITY: Safe text (prevents XSS)
        // =====================================================
        function safeText(el, text) {
            el.textContent = String(text ?? '');
        }
        function safeHTML(str) {
            const d = document.createElement('div');
            d.textContent = String(str ?? '');
            return d.innerHTML;
        }

        // =====================================================
        // UTILITY: App Dialog (replaces alert / confirm / prompt)
        // =====================================================
        function appDialog({ title = '', message = '', input = false, inputPlaceholder = '', confirmText = 'אישור', cancelText = null, danger = false }) {
            return new Promise((resolve) => {
                const overlay = document.getElementById('app-dialog-overlay');
                document.getElementById('app-dialog-title').textContent = title;
                document.getElementById('app-dialog-message').textContent = message;
                const inp = document.getElementById('app-dialog-input');
                if (input) {
                    inp.style.display = 'block';
                    inp.placeholder = inputPlaceholder || '';
                    inp.value = '';
                } else {
                    inp.style.display = 'none';
                }
                const actions = document.getElementById('app-dialog-actions');
                actions.innerHTML = '';

                const confirmBtn = document.createElement('button');
                confirmBtn.textContent = confirmText;
                if (danger) confirmBtn.style.background = 'var(--danger)';
                confirmBtn.style.flex = '1';
                confirmBtn.onclick = () => {
                    overlay.classList.add('hidden');
                    resolve(input ? inp.value.trim() : true);
                };
                actions.appendChild(confirmBtn);

                if (cancelText !== null) {
                    const cancelBtn = document.createElement('button');
                    cancelBtn.textContent = cancelText;
                    cancelBtn.className = 'outline';
                    cancelBtn.style.flex = '1';
                    cancelBtn.onclick = () => {
                        overlay.classList.add('hidden');
                        resolve(input ? null : false);
                    };
                    actions.appendChild(cancelBtn);
                }

                overlay.classList.remove('hidden');
                if (input) setTimeout(() => inp.focus(), 50);
            });
        }

        // =====================================================
        // UTILITY: Toast
        // =====================================================
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type === 'success' ? 'bg-green' : (type === 'error' ? 'bg-red' : 'bg-yellow')}`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 500); }, 4000);
        }

        // =====================================================
        // UTILITY: Close all modals
        // =====================================================
        function closeModals() {
            document.querySelectorAll('.modal-overlay, .modal-center').forEach(m => m.classList.add('hidden'));
            document.getElementById('forgot-password-modal').classList.add('hidden');
            document.getElementById('profile-modal-overlay').classList.add('hidden');
            // FIX 2: Guard against null — this element may not exist yet when closeModals
            // is called early (e.g. during auth flow before the DOM section is rendered).
            const exceptionInfoEl = document.getElementById('es-exception-info');
            if (exceptionInfoEl) safeText(exceptionInfoEl, '');
        }

        // =====================================================
        // SWIPE-TO-DISMISS — Bottom Sheet modals
        // Listens on the sheet card itself. If user drags down ≥ 80px → close.
        // Works for .modal-overlay cards, #app-dialog-overlay, #broadcast-modal-overlay.
        // Never interferes with scrollable content inside (only triggers when the
        // sheet's scrollTop is already 0 — i.e., user is at the top of the sheet).
        // =====================================================
        // =====================================================
        // BODY SCROLL LOCK — נועל גלילת ה-body כשמודאל פתוח,
        // משחרר כשכולם סגורים. כך הרקע לא גולל אבל הגלילה
        // בתוך המודאל עצמו עובדת תקין.
        // =====================================================
        (function initBodyScrollLock() {
            let lockCount = 0;
            let savedScrollY = 0;

            function lockBody() {
                if (lockCount === 0) {
                    savedScrollY = window.scrollY;
                    document.body.style.overflow = 'hidden';
                    document.body.style.position = 'fixed';
                    document.body.style.top = `-${savedScrollY}px`;
                    document.body.style.width = '100%';
                }
                lockCount++;
            }

            function unlockBody() {
                lockCount = Math.max(0, lockCount - 1);
                if (lockCount === 0) {
                    document.body.style.overflow = '';
                    document.body.style.position = '';
                    document.body.style.top = '';
                    document.body.style.width = '';
                    window.scrollTo(0, savedScrollY);
                }
            }

            const MODAL_SELECTORS = [
                '.modal-overlay', '.modal-center',
                '#app-dialog-overlay', '#broadcast-modal-overlay',
                '#profile-modal-overlay'
            ];

            function isAnyModalOpen() {
                return MODAL_SELECTORS.some(sel =>
                    [...document.querySelectorAll(sel)].some(el => !el.classList.contains('hidden'))
                );
            }

            let wasOpen = false;

            const observer = new MutationObserver(() => {
                const open = isAnyModalOpen();
                if (open && !wasOpen) { lockBody(); wasOpen = true; }
                else if (!open && wasOpen) { unlockBody(); wasOpen = false; }
            });

            setTimeout(() => {
                MODAL_SELECTORS.forEach(sel => {
                    document.querySelectorAll(sel).forEach(el => {
                        observer.observe(el, { attributes: true, attributeFilter: ['class'] });
                    });
                });
            }, 50);
        })();

        // =====================================================
        // SHEET ENTRY ANIMATION — כל פתיחה של modal-overlay מפעילה
        // animation חדשה על ה-card (גם בפתיחה חוזרת)
        // =====================================================
        (function initSheetEntryAnimation() {
            function triggerEntry(overlay) {
                const card = overlay.querySelector('.card');
                if (!card) return;
                card.classList.remove('sheet-entering');
                card.style.transform = '';
                card.style.opacity = '';
                card.style.transition = '';
                void card.offsetWidth;
                card.classList.add('sheet-entering');
                card.addEventListener('animationend', () => {
                    card.classList.remove('sheet-entering');
                }, { once: true });
            }

            const observer = new MutationObserver((mutations) => {
                mutations.forEach(({ target, oldValue }) => {
                    if (!target.classList.contains('modal-overlay')) return;
                    const wasHidden = (oldValue || '').split(' ').includes('hidden');
                    const isNowVisible = !target.classList.contains('hidden');
                    if (wasHidden && isNowVisible) {
                        triggerEntry(target);
                    }
                });
            });

            setTimeout(() => {
                document.querySelectorAll('.modal-overlay').forEach(overlay => {
                    observer.observe(overlay, { attributes: true, attributeFilter: ['class'], attributeOldValue: true });
                });

                const appDialog = document.getElementById('app-dialog-overlay');
                if (appDialog) {
                    const dialogObserver = new MutationObserver((mutations) => {
                        mutations.forEach(({ target, oldValue }) => {
                            const wasHidden = (oldValue || '').split(' ').includes('hidden');
                            const isNowVisible = !target.classList.contains('hidden');
                            if (wasHidden && isNowVisible) {
                                const box = document.getElementById('app-dialog-box');
                                if (!box) return;
                                box.style.transform = '';
                                box.style.opacity = '';
                                box.style.transition = '';
                                void box.offsetWidth;
                                box.classList.add('sheet-entering');
                                box.addEventListener('animationend', () => box.classList.remove('sheet-entering'), { once: true });
                            }
                        });
                    });
                    dialogObserver.observe(appDialog, { attributes: true, attributeFilter: ['class'], attributeOldValue: true });
                }

                const profileOverlay = document.getElementById('profile-modal-overlay');
                if (profileOverlay) {
                    const profileObserver = new MutationObserver((mutations) => {
                        mutations.forEach(({ target, oldValue }) => {
                            const wasHidden = (oldValue || '').split(' ').includes('hidden');
                            const isNowVisible = !target.classList.contains('hidden');
                            if (wasHidden && isNowVisible) {
                                const box = document.getElementById('profile-modal-box');
                                if (!box) return;
                                box.style.transform = '';
                                box.style.opacity = '';
                                box.style.transition = '';
                                void box.offsetWidth;
                                box.classList.add('sheet-entering');
                                box.addEventListener('animationend', () => box.classList.remove('sheet-entering'), { once: true });
                            }
                        });
                    });
                    profileObserver.observe(profileOverlay, { attributes: true, attributeFilter: ['class'], attributeOldValue: true });
                }
            }, 50);
        })();

        (function initSwipeToDismiss() {
    const DISMISS_MAP = [
        {
            selector: '.modal-overlay',
            getCard: (overlay) => overlay.querySelector('.card'),
            close: (overlay) => overlay.classList.add('hidden')
        },
        {
            selector: '.modal-center',
            getCard: (overlay) => overlay.querySelector('.card'),
            close: null
        },
        {
            selector: '#app-dialog-overlay',
            getCard: (overlay) => overlay.querySelector('#app-dialog-box'),
            close: (overlay) => {
                const cancel = overlay.querySelector('button.outline');
                const confirm = overlay.querySelector('button:not(.outline)');
                if (cancel) cancel.click(); else if (confirm) confirm.click();
            }
        },
        {
            selector: '#broadcast-modal-overlay',
            getCard: (overlay) => overlay.querySelector('#broadcast-modal-box'),
            close: null
        },
        {
            selector: '#profile-modal-overlay',
            getCard: (overlay) => overlay.querySelector('#profile-modal-box'),
            close: (overlay) => overlay.classList.add('hidden')
        },
    ];

    function wireOverlay(overlay, getCard, closeFn) {
        if (!closeFn) return;

        requestAnimationFrame(() => {
            const card = getCard(overlay);
            if (!card) return;

            if (!card.querySelector('.sheet-handle')) {
                const handle = document.createElement('div');
                handle.className = 'sheet-handle';
                card.insertBefore(handle, card.firstChild);
            }

            let startY = 0;
            let curY = 0;
            let dragging = false;
            let animating = false;
            let canDrag = false;

            // velocity tracking
            let lastY = 0;
            let lastTime = 0;
            let velocity = 0;

            function getScrollableParent(el) {
                while (el && el !== card) {
                    if (el.scrollHeight > el.clientHeight) return el;
                    el = el.parentElement;
                }
                return card;
            }

            card.addEventListener('touchstart', (e) => {
                if (animating) return;

                const scrollEl = getScrollableParent(e.target);

                if (scrollEl.scrollTop <= 0) {
                    canDrag = true;
                } else {
                    canDrag = false;
                    return;
                }

                startY = e.touches[0].clientY;
                curY = startY;
                lastY = startY;
                lastTime = performance.now();
                velocity = 0;

                dragging = false;

                card.classList.remove('sheet-entering');
                card.style.transition = '';
            }, { passive: true });

            card.addEventListener('touchmove', (e) => {
                if (animating || !canDrag) return;

                const y = e.touches[0].clientY;
                let dy = y - startY;

                if (dy <= 0) return;

                // velocity calc
                const now = performance.now();
                const dt = now - lastTime;
                if (dt > 0) {
                    velocity = (y - lastY) / dt; // px per ms
                    lastY = y;
                    lastTime = now;
                }

                dragging = true;
                curY = y;

                e.preventDefault();

                // rubber band effect
                const resistance = dy > 120 ? 120 + (dy - 120) * 0.35 : dy;

                card.style.transition = 'none';
                card.style.transform = `translateY(${resistance}px)`;

                const progress = Math.min(resistance / 300, 1);
                overlay.style.background = `rgba(8,12,20,${0.55 * (1 - progress)})`;
                card.style.opacity = `${1 - progress * 0.3}`;
            }, { passive: false });

            card.addEventListener('touchend', () => {
                if (!dragging) return;

                dragging = false;

                const dy = curY - startY;

                // תנאי סגירה: מרחק או מהירות
                const shouldClose = dy > 90 || velocity > 0.6;

                if (shouldClose) {
                    animating = true;

                    card.style.transition = 'transform 0.28s cubic-bezier(0.4,0,1,1), opacity 0.22s ease';
                    card.style.transform = `translateY(110vh)`;
                    card.style.opacity = '0';
                    overlay.style.background = 'rgba(8,12,20,0)';

                    setTimeout(() => {
                        animating = false;
                        card.style.transform = '';
                        card.style.opacity = '';
                        card.style.transition = '';
                        overlay.style.background = '';
                        closeFn(overlay);
                    }, 280);
                } else {
                    card.style.transition = 'transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s ease';
                    card.style.transform = '';
                    card.style.opacity = '';
                    overlay.style.background = '';

                    setTimeout(() => {
                        card.style.transition = '';
                    }, 400);
                }
            }, { passive: true });
        });
    }

    setTimeout(() => {
        DISMISS_MAP.forEach(({ selector, getCard, close }) => {
            if (selector === '.modal-overlay' || selector === '.modal-center') {
                document.querySelectorAll(selector).forEach(overlay => {
                    wireOverlay(overlay, getCard, close);
                });
            } else {
                const overlay = document.querySelector(selector);
                if (overlay) wireOverlay(overlay, getCard, close);
            }
        });
    }, 100);
})();




        // =====================================================
        // UTILITY: Show/hide views
        // FIX 8: Instead of a hardcoded querySelectorAll list that must be manually updated
        // every time a new view is added, we use a data-view-root attribute on each top-level
        // section. showView just hides all roots and reveals the requested one.
        // =====================================================
        function showView(id) {
            document.querySelectorAll('section, #instructor-main, #instructor-group-details, #session-report-view, #student-main-dashboard, #student-group-details, #view-frozen').forEach(e => e.classList.add('hidden'));
            document.getElementById(id).classList.remove('hidden');
            if (id === 'view-instructor') document.getElementById('instructor-main').classList.remove('hidden');
            if (id === 'view-student') document.getElementById('student-main-dashboard').classList.remove('hidden');
            // Update bottom nav active state
            updateBottomNavActive(id);
        }

        // ── BOTTOM NAV LOGIC ────────────────────────────────────────────────
        function showBottomNav(role) {
            const nav = document.getElementById('bottom-nav');
            nav.classList.add('visible');
            // Show admin button only for admins
            const adminBtn = document.getElementById('bn-admin');
            if (role === 'admin') adminBtn.classList.remove('hidden');
            else adminBtn.classList.add('hidden');
            // Update contact label per role
            const contactLabel = document.getElementById('bn-contact-label');
            if (contactLabel) {
                contactLabel.textContent = role === 'instructor' ? 'הודעות' : 'צור קשר';
            }
        }
        function hideBottomNav() {
            document.getElementById('bottom-nav').classList.remove('visible');
        }
        function updateBottomNavActive(viewId) {
            document.querySelectorAll('.bn-item').forEach(b => b.classList.remove('active'));
            const map = {
                'view-student': 'bn-home',
                'view-instructor': 'bn-home',
                'view-admin': 'bn-admin',
                'settings-modal': 'bn-settings',
            };
            const activeId = map[viewId];
            if (activeId) {
                const el = document.getElementById(activeId);
                if (el) el.classList.add('active');
            }
        }
        // Bottom nav button actions
        document.getElementById('bn-home').addEventListener('click', () => {
            const role = state.userData?.role;
            if (role === 'admin') { closeModals(); showView('view-admin'); }
            else if (role === 'instructor') { closeModals(); showView('view-instructor'); }
            else if (role === 'student') { closeModals(); showView('view-student'); loadStudentMain(); }
        });
        document.getElementById('bn-contact').addEventListener('click', () => {
            const role = state.userData?.role;
            if (role === 'instructor') {
                // Instructors see their inbox directly
                document.getElementById('instructor-inbox-modal').classList.remove('hidden');
                loadInstructorInbox();
            } else {
                openContactCompose();
            }
        });
        document.getElementById('bn-profile').addEventListener('click', () => {
            showProfileView();
        });
        document.getElementById('bn-admin').addEventListener('click', () => {
            closeModals(); showView('view-admin');
        });
        document.getElementById('bn-settings').addEventListener('click', () => {
            openSettingsModal();
        });

        // =====================================================
        // UTILITY: isAdmin check (role only, NOT email)
        // =====================================================
        function isAdmin() {
            return state.userData?.role === 'admin';
        }

        // =====================================================
        // UTILITY: Haversine distance (with validation)
        // =====================================================
        function haversineDistance(lat1, lng1, lat2, lng2) {
            if ([lat1, lng1, lat2, lng2].some(v => v == null || isNaN(v))) return null;
            const R = 6371e3;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lng2 - lng1) * Math.PI / 180;
            const a = Math.sin(dLat / 2) ** 2 + Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon / 2) ** 2;
            return Math.round(R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
        }

        // =====================================================
        // UTILITY: CSV cell sanitization (prevents CSV Injection)
        // FIX 5: Values starting with =, +, -, @ can be interpreted as formulas in Excel/Sheets.
        // Wrap them with a leading apostrophe to force plain-text treatment.
        // =====================================================
        function csvCell(value) {
            const str = String(value ?? '');
            if (['=', '+', '-', '@', '\t', '\r'].some(c => str.startsWith(c))) {
                return `'${str}`;
            }
            // Also escape any double-quotes and wrap in quotes if value contains commas/newlines
            if (str.includes(',') || str.includes('"') || str.includes('\n')) {
                return `"${str.replace(/"/g, '""')}"`;
            }
            return str;
        }

        // =====================================================
        // UTILITY: Batch fetch users by UID (avoids N+1)
        // =====================================================
        async function fetchUsersByUids(uids) {
            const results = {};
            // Firestore "in" query max 10 items at a time
            for (let i = 0; i < uids.length; i += 10) {
                const batch = uids.slice(i, i + 10);
                const snaps = await getDocs(query(collection(db, "users"), where("__name__", "in", batch)));
                snaps.forEach(d => { results[d.id] = d.data(); });
            }
            return results;
        }

        // =====================================================
        // SPLASH SCREEN
        // =====================================================
        let splashHidden = false;
        function hideSplashScreen() {
            if (splashHidden) return;
            splashHidden = true;
            const splash = document.getElementById('splash-screen');
            if (splash) {
                splash.style.opacity = '0';
                setTimeout(() => splash.classList.add('hidden'), 500);
            }
        }
        // Fallback: hide splash after 8 seconds even if Firebase/auth hangs
        setTimeout(() => {
            if (!splashHidden) {
                hideSplashScreen();
                showView('view-auth');
            }
        }, 8000);

        // =====================================================
        // FIX 6: Debounce helper — prevents rapid repeated calls (e.g. register button spam).
        // =====================================================
        function debounce(fn, delay = 2000) {
            let timer = null;
            return function (...args) {
                if (timer) return;
                timer = setTimeout(() => { timer = null; }, delay);
                return fn.apply(this, args);
            };
        }

        // =====================================================
        // UTILITY: withTimeout
        // Wraps an async fn with a 10-second hard timeout.
        // btn/origText are optional — if given, they are restored on timeout.
        // =====================================================
        async function withTimeout(fn, btn, origText, ms = 10000) {
            let timer;
            const race = new Promise((_, rej) => {
                timer = setTimeout(() => rej(new Error('TIMEOUT')), ms);
            });
            try {
                const res = await Promise.race([fn(), race]);
                clearTimeout(timer);
                return res;
            } catch (err) {
                clearTimeout(timer);
                if (btn) { btn.disabled = false; if (origText) btn.textContent = origText; }
                if (err.message === 'TIMEOUT') {
                    showToast('שגיאה בטעינת נתונים. אם הבעיה חוזרת — פנה לתמיכה.', 'error');
                } else {
                    throw err;
                }
            }
        }

            // =====================================================
// UTILITY: Mobile Developer Mode (Eruda)
// =====================================================
function loadMobileDevMode() {
    // מוודא שהסקריפט לא נטען פעמיים
    if (!document.getElementById('eruda-plugin')) {
        const script = document.createElement('script');
        script.id = 'eruda-plugin';
        script.src = 'https://cdn.jsdelivr.net/npm/eruda';
        script.onload = () => { 
            eruda.init(); 
            showToast('מצב מפתחים הופעל', 'success'); 
        };
        document.head.appendChild(script);
    }
}


        // =====================================================
        // PULL-TO-REFRESH GUARD
        // Allow Chrome's pull-to-refresh only when touch starts
        // in the top 10px of the screen AND no modal is open.
        // =====================================================
            

            (function initPullToRefreshGuard() {
    let touchStartY = 0;
    let isAtTopStart = false;
    let isModalOpen = false;

    document.addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;

        // בדיקה אם יש מודאל פתוח
        isModalOpen = [...document.querySelectorAll(
            '.modal-overlay, .modal-center, #app-dialog-overlay, #profile-modal-overlay'
        )].some(el => !el.classList.contains('hidden'));

        // התחלה רק מהחלק העליון + הדף בראש
        isAtTopStart = (touchStartY < 20 && window.scrollY <= 0);

    }, { passive: true });

    document.addEventListener('touchmove', (e) => {
        const dy = e.touches[0].clientY - touchStartY;

        // אם מודאל פתוח – לא חוסמים כלום (שלא ישבור swipe לסגירה)
        if (isModalOpen) return;

        // חוסמים רק pull-to-refresh אמיתי
        if (isAtTopStart && dy > 0) {
            e.preventDefault();
        }

    }, { passive: false });

})();

            
document.getElementById('profile-area-btn').addEventListener('click', (e) => {
    e.stopPropagation();
    document.getElementById('profile-dropdown').classList.toggle('show');
});

document.addEventListener('click', () => {
    const dd = document.getElementById('profile-dropdown');
    if (dd) dd.classList.remove('show');
});


        // =====================================================
        // AUTH STATE
        // =====================================================
        onAuthStateChanged(auth, async (user) => {
            try {
                if (user) {
                    const uDoc = await getDoc(doc(db, "users", user.uid));
                    if (uDoc.exists()) {
                        state.userData = uDoc.data();
                        safeText(document.getElementById('user-display-name'), state.userData.fullName);
                        document.getElementById('app-header').classList.remove('hidden');
                        showBottomNav(state.userData.role);

                        updateSettingsVisibility();
                        if (isAdmin()) {
                            document.getElementById('nav-admin-btn').classList.remove('hidden');
                            showView('view-admin');
                            loadAdminMain();     
                            loadMobileDevMode();
                        } else if (state.userData.role === 'instructor') {
                            showView('view-instructor');
                            loadInstructorMain();
                        } else if (state.userData.role === 'frozen') {
                            showView('view-frozen');
                        } else {
                            showView('view-student');
                            loadStudentMain();
                        }
                        // Cache user's group memberships for broadcast targeting
                        const gSnapsForUser = await getDocs(query(collection(db, "groups"), where("members", "array-contains", auth.currentUser.uid)));
                        state.userGroupIds = gSnapsForUser.docs.map(d => d.id);
                        // Check for pending mandatory broadcasts (all roles)
                        setTimeout(checkPendingBroadcasts, 2200);
                        // Check for unread replies
                        setTimeout(checkPendingReplies, 1200);
                    } else {
                        showView('view-auth');
                    }
                } else {
                    showView('view-auth');
                    document.getElementById('app-header').classList.add('hidden');
                    hideBottomNav();
                }
            } catch (error) {
                console.error("שגיאה בטעינת נתוני משתמש:", error);
                showView('view-auth');
            } finally {
                hideSplashScreen();
            }
        });

        // =====================================================
        // AUTH FORMS
        // =====================================================
        document.getElementById('btn-go-register').addEventListener('click', () => {
            document.getElementById('login-section').classList.add('hidden');
            document.getElementById('register-section').classList.remove('hidden');
        });
        document.getElementById('btn-go-login').addEventListener('click', () => {
            document.getElementById('login-section').classList.remove('hidden');
            document.getElementById('register-section').classList.add('hidden');
        });

        document.getElementById('form-login').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btn-login-submit');
            btn.disabled = true;
            btn.textContent = "מתחבר...";
            let loginInput = document.getElementById('login-email').value.trim();
            if (!loginInput.includes('@')) loginInput = loginInput + '@mada.system.local';
            try {
                await withTimeout(
                    () => signInWithEmailAndPassword(auth, loginInput, document.getElementById('login-pass').value),
                    btn, "היכנס למערכת"
                );
            } catch {
                await appDialog({ title: 'שגיאה', message: 'פרטים שגויים. נסה שוב.', confirmText: 'סגור' });
                btn.disabled = false;
                btn.textContent = "היכנס למערכת";
            }
        });

        // FIX 6: Wrap the register submit handler in a debounce so it cannot be fired
        // multiple times in quick succession (prevents creating duplicate accounts).
        document.getElementById('form-register').addEventListener('submit', debounce(async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btn-reg-submit');
            btn.disabled = true;
            btn.textContent = "יוצר משתמש...";
            const id = document.getElementById('reg-id').value.trim();
            const name = document.getElementById('reg-name').value.trim();
            const pass = document.getElementById('reg-pass').value;
            const email = id + '@mada.system.local';
            try {
                // FIX 3: Check if this ID number already exists in Firestore BEFORE
                // attempting to create an Auth user. This gives a clearer, specific error message.
                const existingSnap = await getDocs(query(collection(db, "users"), where("idNumber", "==", id)));
                if (!existingSnap.empty) {
                    await appDialog({ title: 'שגיאה', message: 'תעודת זהות זו כבר רשומה במערכת. אם שכחת את הסיסמה, פנה למנהל.', confirmText: 'סגור' });
                    btn.disabled = false;
                    btn.textContent = "צור משתמש";
                    return;
                }
            } catch (checkErr) {
                console.error("שגיאה בבדיקת תעודת זהות:", checkErr);
                await appDialog({ title: 'שגיאה', message: 'שגיאה בחיבור לשרת. בדוק את החיבור לאינטרנט ונסה שוב.', confirmText: 'סגור' });
                btn.disabled = false;
                btn.textContent = "צור משתמש";
                return;
            }
            let cred = null;
            try {
                cred = await createUserWithEmailAndPassword(auth, email, pass);
            } catch (authErr) {
                console.error("שגיאה ביצירת משתמש Firebase Auth:", authErr);
                let msg = 'שגיאה ביצירת משתמש. נסה שוב.';
                if (authErr.code === 'auth/email-already-in-use') {
                    msg = 'תעודת זהות זו כבר רשומה במערכת. אם שכחת את הסיסמה, פנה למנהל.';
                } else if (authErr.code === 'auth/weak-password') {
                    msg = 'הסיסמה חלשה מדי — יש להזין לפחות 6 תווים.';
                } else if (authErr.code === 'auth/network-request-failed') {
                    msg = 'שגיאת רשת — בדוק את החיבור לאינטרנט ונסה שוב.';
                }
                await appDialog({ title: 'שגיאה', message: msg, confirmText: 'סגור' });
                btn.disabled = false;
                btn.textContent = "צור משתמש";
                return;
            }
            try {
                await setDoc(doc(db, "users", cred.user.uid), {
                    idNumber: id, fullName: name, role: 'frozen', createdAt: serverTimestamp()
                });
                showToast("משתמש נוצר! חשבונך ממתין לאישור מנהל");
            } catch (dbErr) {
                console.error("שגיאה בשמירת נתוני משתמש ב-Firestore:", dbErr);
                // Auth user was created but Firestore write failed — user is now logged in
                // with a partial profile. Try to write the profile doc again before giving up.
                try {
                    await setDoc(doc(db, "users", cred.user.uid), {
                        idNumber: id, fullName: name, role: 'frozen', createdAt: serverTimestamp()
                    });
                    showToast("משתמש נוצר! חשבונך ממתין לאישור מנהל");
                } catch (retryErr) {
                    console.error("ניסיון חוזר נכשל:", retryErr);
                    await appDialog({ title: 'שגיאה חלקית', message: 'החשבון נוצר אך אירעה שגיאה בשמירת הפרופיל. פנה למנהל המערכת עם תעודת הזהות שלך.', confirmText: 'סגור' });
                    btn.disabled = false;
                    btn.textContent = "צור משתמש";
                }
            }
        }));

