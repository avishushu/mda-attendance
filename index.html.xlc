                document.getElementById('admin-tab-log').classList.toggle('hidden', t !== 'log');
                if (t === 'users') loadAdminUsers();
                if (t === 'groups') loadAdminGroups();
                if (t === 'dashboard') loadAdminDashboard();
                if (t === 'messages') loadAdminMessages();
