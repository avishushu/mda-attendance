        // ── SORT BUTTON ─────────────────────────────────────────────────────
        (function initSortReport() {
            const sortBtn   = document.getElementById('btn-sort-report');
            const sortDrop  = document.getElementById('sort-dropdown');
            const sortLabel = document.getElementById('sort-btn-label');

            // Default: status ascending (same as original getRank order)
            state.reportSort = { key: 'status', dir: 'asc' };

            const LABELS = {
                'status-asc':  'סטטוס — עולה',
                'status-desc': 'סטטוס — יורד',
                'name-asc':    'שם — א׳ עד ת׳',
                'name-desc':   'שם — ת׳ עד א׳',
                'time-asc':    'זמן הגעה — מוקדם לאחרון',
                'time-desc':   'זמן הגעה — מאוחר לראשון',
            };

            function applyActiveClass() {
                const cur = `${state.reportSort.key}-${state.reportSort.dir}`;
                sortDrop.querySelectorAll('.sort-opt').forEach(o => {
                    const k = `${o.dataset.key}-${o.dataset.dir}`;
                    o.classList.toggle('active', k === cur);
                });
                sortLabel.textContent = LABELS[cur] || 'מיין לפי';
            }

            sortBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                sortDrop.classList.toggle('hidden');
                applyActiveClass();
            });

            sortDrop.querySelectorAll('.sort-opt').forEach(opt => {
                opt.addEventListener('click', (e) => {
                    e.stopPropagation();
                    state.reportSort = { key: opt.dataset.key, dir: opt.dataset.dir };
                    applyActiveClass();
                    sortDrop.classList.add('hidden');
                    // Re-render with new sort
                    if (state.liveSessionData) renderReport(state.liveSessionData);
                });
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', () => {
                if (sortDrop && !sortDrop.classList.contains('hidden')) {
                    sortDrop.classList.add('hidden');
                }
            });
        })();

